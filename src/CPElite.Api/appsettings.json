{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Supabase": ""
  },
  "Database": {
    "Provider": "Postgres"
  },
  "EaApi": {
    "BaseUrl": "https://proclubs.ea.com/api/fc"
  },
  "EaSync": {
    "Enabled": true,
    "IntervalMinutes": 120
  },
