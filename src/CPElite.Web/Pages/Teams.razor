@page "/teams"
@inject ApiClient Api
@inject AuthState AuthState
@inject NavigationManager Navigation
@inject IWebAssemblyHostEnvironment HostEnvironment

<PageTitle>TS Tournament - Clubs</PageTitle>

<section class="team-hero">
    <div class="team-hero-copy">
        <p class="eyebrow">Club house</p>
        <h1>Lie ton club, verrouille l'EA ID, construis ton effectif.</h1>
        <p>Le owner recherche son club par nom, TS Tournament recupere les donnees utiles, les stocke chez nous et les garde a jour avec la synchro periodique.</p>
    </div>
    <div class="club-data-ticket">
        <span>Prochaine evolution</span>
        <strong>EA ID joueur</strong>
        <p>Meme logique cote joueur : premiere liaison depuis l'EA Sports ID, stockage local, puis mise a jour par le cron.</p>
    </div>
</section>

<section class="club-branding-editor">
    <article class="club-preview">
        <div class="club-banner-preview" style="@BannerPreviewStyle">
            <div class="club-logo-preview">
                @if (!string.IsNullOrWhiteSpace(Team.LogoUrl))
                {
                    <img src="@Team.LogoUrl" alt="Logo equipe" />
                }
                else
                {
                    <span>@Team.ShortName</span>
                }
            </div>
            <div>
                <p class="eyebrow">Identite club</p>
                <h2>@Team.Name</h2>
                <p>@Team.Description</p>
                @if (Team.EaClubId is not null)
                {
                    <div class="ea-data-strip">
                        <b>EA ID @Team.EaClubId</b>
                        <b>@Team.Region</b>
                        <b>@(SelectedEaClub?.MembersCount?.ToString() ?? "-") joueurs EA</b>
                    </div>
                }
            </div>
        </div>
    </article>

    <article class="panel">
        <div class="panel-heading">
            <p class="eyebrow">Logo & banniere</p>
            <h2>Image du club</h2>
        </div>
        <div class="upload-grid">
            <label class="upload-card">
                <span>Logo equipe</span>
                <InputFile OnChange="UploadLogoAsync" accept="image/png,image/jpeg,image/webp,image/gif" />
                <small>@(string.IsNullOrWhiteSpace(Team.LogoUrl) ? "PNG, JPG ou WebP" : "Logo uploade")</small>
            </label>
            <label class="upload-card banner-upload">
                <span>Banniere equipe</span>
                <InputFile OnChange="UploadBannerAsync" accept="image/png,image/jpeg,image/webp,image/gif" />
                <small>@(string.IsNullOrWhiteSpace(Team.BannerUrl) ? "Image large recommandee" : "Banniere uploadee")</small>
            </label>
        </div>
    </article>
</section>

<section class="section-grid">
    <article class="panel club-search-card">
        <div class="panel-heading">
            <p class="eyebrow">Creation equipe</p>
            <h2>Rechercher le club EA</h2>
        </div>

        <div class="search-row">
            <label>Nom du club
                <InputText @bind-Value="EaSearchTerm" placeholder="Ex: TheSurvivors" />
            </label>
            <button class="primary-action" @onclick="SearchEaClubAsync" disabled="@Busy">Rechercher</button>
        </div>

        @if (EaSearchResults.Count > 0)
        {
            <div class="ea-result-grid">
                @foreach (var club in EaSearchResults)
                {
                    <button class="ea-result-card @(SelectedEaClub?.EaClubId == club.EaClubId ? "selected" : "")" @onclick="() => OnEaClubResultClickedAsync(club)">
                        <span>@club.Source</span>
                        <strong>@club.Name</strong>
                        <small>@(club.EaClubId > 0 ? $"ID {club.EaClubId}" : "Club TS existant")</small>
                        @if (club.IsInApplication)
                        {
                            <em class="app-status is-linked">Deja dans l'app: @club.ApplicationTeamName</em>
                        }
                        <div class="ea-data-strip">
                            <b>DIV @(club.Division?.ToString() ?? "-")</b>
                            <b>@(club.MembersCount?.ToString() ?? "-") joueurs</b>
                            <b>@club.Platform</b>
                        </div>
                        @if (club.IsInApplication && club.ApplicationTeamId is not null)
                        {
                            <span class="mini-action strong join-existing-club-action">Rejoindre ce club</span>
                        }
                    </button>
                }
            </div>
        }
        else
        {
            <p class="muted">Tape le nom du club pour recuperer les donnees disponibles et selectionner le bon EA club ID.</p>
        }

        <EditForm Model="Team" OnValidSubmit="CreateTeamAsync">
            <div class="form-grid">
                <label>Nom <InputText @bind-Value="Team.Name" /></label>
                <label>Short name <InputText @bind-Value="Team.ShortName" /></label>
                <label>Region <InputText @bind-Value="Team.Region" /></label>
                <label>EA club ID
                    <InputNumber @bind-Value="Team.EaClubId" disabled="@EaClubLocked" />
                    @if (EaClubLocked)
                    {
                        <small class="locked-ea-id">Verrouille depuis la recherche club</small>
                    }
                </label>
            </div>

            <label>Description <InputTextArea @bind-Value="Team.Description" /></label>
            <button class="primary-action" disabled="@Busy">Creer equipe et stocker les donnees</button>
        </EditForm>
    </article>

    <article class="panel club-selector-panel">
        <div class="panel-heading">
            <p class="eyebrow">@(ManagedMemberships.Count > 0 ? "Mes clubs" : "Mon club")</p>
            <h2>@(ManagedMemberships.Count > 0 ? "Selection club owner" : "Club actif")</h2>
            <button class="ghost-action" @onclick="LoadMeAsync">Rafraichir</button>
        </div>
        @if (Memberships.Count == 0)
        {
            <p class="muted">Aucune equipe chargee pour cette session.</p>
        }
        else
        {
            @if (ManagedMemberships.Count > 1)
            {
                <label>Club a piloter
                    <select @onchange="SelectTeamFromDropdownAsync">
                        @foreach (var member in ManagedMemberships)
                        {
                            <option value="@member.TeamId" selected="@(SelectedTeamId == member.TeamId)">@member.TeamName - @member.Role</option>
                        }
                    </select>
                </label>
            }
            else
            {
                <div class="active-club-strip">
                    <strong>@(CurrentMembership?.TeamName ?? SelectedTeamName ?? "Club actif")</strong>
                    <span>@(CurrentMembership?.Role.ToString() ?? "Joueur")</span>
                    <small>L'effectif et les donnees EA s'ouvrent automatiquement.</small>
                </div>
            }
        }

        @if (!HostEnvironment.IsProduction())
        {
            <button class="demo-club-card @(DemoMode ? "selected" : "")" @onclick="SelectDemoTeam">
                <span>Mode demo EA</span>
                <strong>TheSurvivors</strong>
                <small>11 joueurs, profils enrichis, amicaux et detail match stockes.</small>
            </button>
        }
    </article>
</section>

@if (SelectedTeamId.HasValue)
{
    <section class="panel team-data-panel">
        <div class="panel-heading">
            <p class="eyebrow">Donnees stockees</p>
            <h2>@(SelectedTeamName ?? "Equipe selectionnee")</h2>
            <button class="ghost-action" @onclick="SyncSelectedTeamAsync" disabled="@Busy">@EaRefreshButtonLabel</button>
        </div>

        <div class="team-data-grid">
            <div class="stat-tile">
                <span>EA club</span>
                <strong>@(ClubSnapshot?.Name ?? "Non synchronise")</strong>
                <small>@(ClubSnapshot is null ? "Lance une mise a jour apres creation." : $"ID {ClubSnapshot.EaClubId} - {ClubSnapshot.Platform}")</small>
            </div>
            <div class="stat-tile">
                <span>Division</span>
                <strong>@(ClubSnapshot?.Division?.ToString() ?? "-")</strong>
                <small>Donnee issue de la derniere synchro</small>
            </div>
            <div class="stat-tile">
                <span>Effectif EA</span>
                <strong>@(EaProfiles.Count > 0 ? EaProfiles.Count.ToString() : EaMembers?.PlayerCount.ToString() ?? "-")</strong>
                <small>@(EaProfiles.Count == 0 ? "En attente de donnees membres." : "Profils EA actifs normalises stockes")</small>
            </div>
            <div class="stat-tile">
                <span>Friendly</span>
                <strong>@EaFriendlies.Count</strong>
                <small>Derniers matchs stockes avec details joueurs</small>
            </div>
        </div>

        <div class="club-stats-split">
            <article class="club-stat-panel">
                <span class="result-kind">Stats generales EA</span>
                <h3>@(ClubSnapshot?.Name ?? SelectedTeamName ?? "Club")</h3>
                <div class="drawer-metrics inline">
                    <div><span>Forme recente</span><strong>@RecentEaRecord</strong></div>
                    <div><span>Buts / match</span><strong>@GoalsPerFriendly.ToString("0.0")</strong></div>
                    <div><span>Joueurs suivis</span><strong>@EaProfiles.Count</strong></div>
                    <div><span>Derniere synchro</span><strong>@(ClubSnapshot?.SyncedAt.LocalDateTime.ToString("HH:mm") ?? "--")</strong></div>
                </div>
            </article>
            <article class="club-stat-panel accent">
                <span class="result-kind">Stats TS Tournament</span>
                <h3>Performance dans nos tournois</h3>
                <div class="drawer-metrics inline">
                    <div><span>Tournois</span><strong>@AppTournamentStats.TournamentsPlayed</strong></div>
                    <div><span>Record</span><strong>@AppTournamentStats.Record</strong></div>
                    <div><span>Meilleur resultat</span><strong>@AppTournamentStats.BestRun</strong></div>
                    <div><span>Joueur cle</span><button type="button" class="inline-player-link strong-link" @onclick="() => OpenPlayerSheet(AppTournamentStats.KeyPlayer)">@AppTournamentStats.KeyPlayer</button></div>
                </div>
            </article>
        </div>

        @if (EaProfiles.Count > 0)
        {
            <h3>Effectif actif complet (@EaProfiles.Count)</h3>
            <div class="roster-grid">
                @foreach (var player in EaProfiles)
                {
                    <article class="player-stat-card clickable-card" @onclick="() => OpenPlayerSheet(player)">
                        <button type="button" class="inline-player-link strong-link" @onclick:stopPropagation @onclick="() => OpenPlayerSheet(player)">@player.PlayerName</button>
                        <span>@(player.Position ?? "Poste inconnu") · @(player.ProName ?? player.EaPlayerId)</span>
                        <div class="ea-data-strip">
                            <b class="@(IsPlayerInApp(player) ? "app-badge-ok" : "app-badge-missing")">@(IsPlayerInApp(player) ? "Dans l'app" : "Hors app")</b>
                            <b>@(player.Matches?.ToString() ?? "-") MJ</b>
                            <b>@(player.Goals?.ToString() ?? "-") buts</b>
                            <b>@(player.Assists?.ToString() ?? "-") assists</b>
                            <b>@(player.AverageRating?.ToString("0.0") ?? "-") note</b>
                            <b>@(player.PassSuccessRate?.ToString("0") ?? "-")% passes</b>
                        </div>
                        @if (!IsPlayerInApp(player) && CanInvitePlayers)
                        {
                            <button type="button" class="mini-action strong" @onclick="() => CreatePersonalInvite(player)">Inviter</button>
                        }
                    </article>
                }
            </div>
        }

        @if (EaFriendlies.Count > 0)
        {
            <div class="panel-heading compact">
                <div>
                    <p class="eyebrow">Matchs amicaux EA</p>
                    <h3>Matchs stockes</h3>
                </div>
                <button class="ghost-action" @onclick="SyncSelectedTeamAsync" disabled="@Busy">@FriendlyRefreshButtonLabel</button>
            </div>
            <div class="friendly-match-pager">
                <div class="friendly-match-list">
                    @foreach (var match in PagedFriendlies)
                    {
                        <button type="button" class="friendly-match-card @(SelectedFriendlyDetails?.Match.EaMatchId == match.EaMatchId ? "selected" : "")" @onclick="() => SelectFriendlyMatchAsync(match)">
                            <span>@match.PlayedAt.LocalDateTime.ToString("dd/MM HH:mm")</span>
                            <strong>@match.HomeClubName @match.HomeScore - @match.AwayScore @match.AwayClubName</strong>
                            <small>@match.PlayerStatCount stats joueurs - ID @match.EaMatchId</small>
                        </button>
                    }
                </div>
                <div class="pager-actions">
                    <button type="button" class="ghost-action" @onclick="PreviousFriendlyPage" disabled="@(FriendlyPage <= 0)">Precedent</button>
                    <span>Page @(FriendlyPage + 1) / @FriendlyTotalPages</span>
                    <button type="button" class="ghost-action" @onclick="NextFriendlyPage" disabled="@(FriendlyPage >= FriendlyTotalPages - 1)">Suivant</button>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                <strong>Aucun amical EA stocke</strong>
                <p>Rafraichis les donnees EA du club pour recuperer les derniers matchs amicaux et leurs details joueurs.</p>
                <button class="primary-action" @onclick="SyncSelectedTeamAsync" disabled="@Busy">@FriendlyRefreshButtonLabel</button>
            </div>
        }

        @if (SelectedFriendlyDetails is not null)
        {
            <div class="player-detail friendly-match-detail">
                <div class="friendly-match-header">
                    <div>
                        <p class="eyebrow">Detail match EA</p>
                        <h3>@SelectedFriendlyDetails.Match.HomeClubName @SelectedFriendlyDetails.Match.HomeScore - @SelectedFriendlyDetails.Match.AwayScore @SelectedFriendlyDetails.Match.AwayClubName</h3>
                    </div>
                    <span>@SelectedFriendlyDetails.Match.PlayedAt.LocalDateTime.ToString("dd/MM HH:mm")</span>
                </div>

                <div class="friendly-match-body">
                    <aside class="friendly-match-aside">
                        <p class="eyebrow">Match selectionne</p>
                        <h4>@SelectedFriendlyDetails.Match.HomeClubName vs @SelectedFriendlyDetails.Match.AwayClubName</h4>
                        <div class="match-side-score">
                            <span>@SelectedFriendlyDetails.Match.HomeClubName</span>
                            <strong>@SelectedFriendlyDetails.Match.HomeScore - @SelectedFriendlyDetails.Match.AwayScore</strong>
                            <span>@SelectedFriendlyDetails.Match.AwayClubName</span>
                        </div>
                        <div class="match-side-grid">
                            <div><span>ID match</span><strong>@SelectedFriendlyDetails.Match.EaMatchId</strong></div>
                            <div><span>Date</span><strong>@SelectedFriendlyDetails.Match.PlayedAt.LocalDateTime.ToString("dd/MM HH:mm")</strong></div>
                            <div><span>Joueurs stats</span><strong>@SelectedFriendlyDetails.Match.PlayerStatCount</strong></div>
                            <div><span>Type</span><strong>Amical EA</strong></div>
                        </div>
                        <small>Les joueurs du match sont ranges par club. Clique un joueur pour ouvrir sa fiche detaillee.</small>
                    </aside>

                    <div class="friendly-team-sections">
                    @foreach (var teamSection in FriendlyTeamSections)
                    {
                        <section class="friendly-team-section @(teamSection.IsCurrentTeam ? "current-team" : "opponent-team")">
                            <div class="friendly-team-heading">
                                <div>
                                    <p class="eyebrow">@(teamSection.IsCurrentTeam ? "Mon equipe" : "Adversaire")</p>
                                    <h4>@teamSection.ClubName</h4>
                                </div>
                                <div class="friendly-team-score">
                                    <span>@(teamSection.IsHome ? "Domicile" : "Exterieur")</span>
                                    <strong>@teamSection.Score</strong>
                                </div>
                            </div>

                            @if (teamSection.ClubStats is not null)
                            {
                                <div class="friendly-club-metrics">
                                    <span>@(teamSection.ClubStats.Score?.ToString() ?? teamSection.Score.ToString()) score</span>
                                    <span>@(teamSection.ClubStats.Rating?.ToString("0.0") ?? "-") note</span>
                                    <span>@(teamSection.ClubStats.Shots?.ToString() ?? "-") tirs</span>
                                    <span>@(teamSection.ClubStats.PassSuccessRate?.ToString("0") ?? "-")% passes</span>
                                    <span>@(teamSection.ClubStats.TackleSuccessRate?.ToString("0") ?? "-")% tacles</span>
                                    <span>@(teamSection.ClubStats.GoalsConceded?.ToString() ?? "-") buts encaisses</span>
                                    @if (!string.IsNullOrWhiteSpace(teamSection.ClubStats.StadiumName))
                                    {
                                        <span>@teamSection.ClubStats.StadiumName</span>
                                    }
                                </div>
                            }

                            @if (teamSection.Players.Count == 0)
                            {
                                <div class="empty-state compact">
                                    <strong>Aucun joueur detaille</strong>
                                    <p>EA n'a pas retourne les stats individuelles pour cette equipe sur ce match.</p>
                                </div>
                            }
                            else
                            {
                                <div class="roster-grid friendly-roster-grid">
                                    @foreach (var stat in teamSection.Players)
                                    {
                                        <article class="player-stat-card friendly-player-card clickable-card @(teamSection.IsCurrentTeam ? "current-team" : "opponent-team") @(stat.PlayerOfTheMatch ? "selected" : "")" @onclick="() => OpenPlayerSheet(stat)">
                                            <span class="team-player-badge">@teamSection.ClubName</span>
                                            <button type="button" class="inline-player-link strong-link" @onclick:stopPropagation @onclick="() => OpenPlayerSheet(stat)">@stat.PlayerName</button>
                                            <span>@(stat.Position ?? "poste ?") @(stat.PlayerOfTheMatch ? "- Homme du match" : "")</span>
                                            <p class="position-smart-line">@BuildMatchPlayerSmartLine(stat)</p>
                                            <div class="ea-data-strip">
                                                <b>@(stat.Goals?.ToString() ?? "0") B</b>
                                                <b>@(stat.Assists?.ToString() ?? "0") A</b>
                                                <b>@(stat.Rating?.ToString("0.0") ?? "-") note</b>
                                                <b>@(stat.PassSuccessRate?.ToString("0") ?? "-")% passes</b>
                                                <b>@(stat.TackleSuccessRate?.ToString("0") ?? "-")% tacles</b>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                        </section>
                    }
                    </div>
                </div>
            </div>
        }

    </section>
}

@if (SelectedPlayerSheet is not null)
{
    <section class="detail-drawer">
        <div class="detail-drawer-card">
            <div class="drawer-heading">
                <div>
                    <p class="eyebrow">Fiche joueur</p>
                    <h2>@SelectedPlayerSheet.Name</h2>
                </div>
                <button class="ghost-action" @onclick="ClosePlayerSheet">Fermer</button>
            </div>

            <div class="player-focus-card">
                <div class="player-focus-main">
                    <div class="club-avatar large">@GetInitials(SelectedPlayerSheet.Name)</div>
                    <div>
                        <span class="result-kind">@SelectedPlayerSheet.Source</span>
                        <h3>@SelectedPlayerSheet.ProName</h3>
                        <p>EA Sports ID @SelectedPlayerSheet.EaPlayerId - @SelectedPlayerSheet.Position - @(SelectedPlayerSheet.HasApp ? "compte app actif" : "hors app")</p>
                    </div>
                </div>
                <div class="player-focus-rating">
                    <span>Note</span>
                    <strong>@SelectedPlayerSheet.RatingLabel</strong>
                </div>
            </div>

            <div class="player-position-panel">
                <div>
                    <p class="eyebrow">@SelectedPlayerSheet.PositionFocusTitle</p>
                    <h3>@SelectedPlayerSheet.PositionFocusText</h3>
                </div>
                <span class="presence-pill @(SelectedPlayerSheet.HasApp ? "confirmed" : "pending")">@(SelectedPlayerSheet.HasApp ? "Dans l'app" : "A inviter")</span>
            </div>

            <div class="drawer-metrics player-priority-metrics">
                @foreach (var metric in SelectedPlayerSheet.PriorityMetrics)
                {
                    <div><span>@metric.Label</span><strong>@metric.Value</strong></div>
                }
            </div>

            <div class="drawer-data-grid player-identity-stats">
                <article>
                    <span class="result-kind">Donnees EA stockees</span>
                    <dl>
                        <div><dt>Nom pro</dt><dd>@SelectedPlayerSheet.ProName</dd></div>
                        <div><dt>Poste</dt><dd>@SelectedPlayerSheet.Position</dd></div>
                        <div><dt>Taille</dt><dd>@SelectedPlayerSheet.HeightLabel</dd></div>
                        <div><dt>OVR</dt><dd>@SelectedPlayerSheet.OverallLabel</dd></div>
                        <div><dt>Matchs</dt><dd>@SelectedPlayerSheet.Matches</dd></div>
                        <div><dt>Homme du match</dt><dd>@SelectedPlayerSheet.PlayerOfTheMatchLabel</dd></div>
                    </dl>
                </article>
                <article>
                    <span class="result-kind">Impact sportif</span>
                    <div class="player-skill-grid">
                        <div><span>Buts</span><strong>@SelectedPlayerSheet.Goals</strong></div>
                        <div><span>Assists</span><strong>@SelectedPlayerSheet.Assists</strong></div>
                        <div><span>Passes</span><strong>@SelectedPlayerSheet.PassRateLabel</strong></div>
                        <div><span>Tacles</span><strong>@SelectedPlayerSheet.TackleRateLabel</strong></div>
                    </div>
                </article>
            </div>
            @if (SelectedPlayerSheet.MetricGroups.Count > 0)
            {
                <div class="drawer-data-grid player-deep-stats">
                    @foreach (var group in SelectedPlayerSheet.MetricGroups)
                    {
                        <article>
                            <span class="result-kind">@group.Title</span>
                            <div class="player-skill-grid">
                                @foreach (var metric in group.Metrics)
                                {
                                    <div><span>@metric.Label</span><strong>@metric.Value</strong></div>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="notice">@Message</div>
}

@code {
    private TeamModel Team { get; } = new();
    private JoinModel Join { get; } = new();
    private List<TeamMemberResponse> Memberships { get; } = new();
    private List<TeamMemberResponse> TeamMembers { get; } = new();
    private List<EaClubSearchResultResponse> EaSearchResults { get; } = new();
    private string EaSearchTerm { get; set; } = "";
    private EaClubSearchResultResponse? SelectedEaClub;
    private EaClubSnapshotResponse? ClubSnapshot;
    private EaMemberStatsSummaryResponse? EaMembers;
    private List<EaPlayerProfileSnapshotResponse> EaProfiles { get; } = new();
    private List<EaFriendlyMatchResponse> EaFriendlies { get; } = new();
    private Dictionary<string, EaFriendlyMatchDetailsResponse> DemoFriendlyDetails { get; } = new();
    private EaFriendlyMatchDetailsResponse? SelectedFriendlyDetails;
    private TeamMemberResponse? SelectedPlayer;
    private PlayerSheetModel? SelectedPlayerSheet;
    private TeamResponse? SelectedTeamProfile;
    private Guid? SelectedTeamId;
    private string? SelectedTeamName;
    private bool DemoMode;
    private bool EaClubLocked;
    private bool Busy;
    private bool EaSyncBusy;
    private string? Message;
    private IReadOnlyList<TeamMemberResponse> ManagedMemberships => Memberships
        .Where(member => member.Role is TeamRole.Owner or TeamRole.Manager)
        .ToArray();
    private TeamMemberResponse? CurrentMembership => Memberships.FirstOrDefault(member => member.TeamId == SelectedTeamId);
    private bool CanInvitePlayers => DemoMode || CurrentMembership?.Role is TeamRole.Owner or TeamRole.Manager;
    private string EaRefreshButtonLabel => EaSyncBusy ? "Synchro EA..." : "Rafraichir donnees EA";
    private string FriendlyRefreshButtonLabel => EaSyncBusy ? "Actualisation..." : "Rafraichir amicaux EA";
    private const int FriendlyPageSize = 2;
    private int FriendlyPage;
    private IReadOnlyList<EaFriendlyMatchResponse> PagedFriendlies => EaFriendlies
        .OrderByDescending(match => match.PlayedAt)
        .Skip(FriendlyPage * FriendlyPageSize)
        .Take(FriendlyPageSize)
        .ToArray();
    private int FriendlyTotalPages => Math.Max(1, (int)Math.Ceiling((double)EaFriendlies.Count / FriendlyPageSize));
    private IReadOnlyList<FriendlyTeamSectionModel> FriendlyTeamSections => SelectedFriendlyDetails is null
        ? Array.Empty<FriendlyTeamSectionModel>()
        : BuildFriendlyTeamSections(SelectedFriendlyDetails);
    private DemoTournamentTeamStats AppTournamentStats { get; } = new(4, "9V 2N 3D", "Finaliste Friday Goodies Cup #3", "KoffiMarvelous");
    private static readonly Guid DemoTeamId = Guid.Parse("37d9a7d7-8b8b-47d3-9e25-214820700001");
    private const long DemoClubId = 2148207;
    private static readonly HashSet<string> DemoAppPlayers = new(StringComparer.OrdinalIgnoreCase)
    {
        "KoffiMarvelous",
        "ginga_blaze",
        "caboss_238",
        "Le_Siak69",
        "zerug0_",
        "Tchollismo",
        "Moussi00777",
        "KiMeST__"
    };
    private string BannerPreviewStyle => string.IsNullOrWhiteSpace(Team.BannerUrl)
        ? ""
        : $"background-image: linear-gradient(90deg, rgba(7,17,29,.84), rgba(7,17,29,.42)), url('{Team.BannerUrl}');";
    private int EaWins => EaFriendlies.Count(match => (match.HomeEaClubId == DemoClubId && match.HomeScore > match.AwayScore) || (match.AwayEaClubId == DemoClubId && match.AwayScore > match.HomeScore));
    private int EaDraws => EaFriendlies.Count(match => match.HomeScore == match.AwayScore);
    private int EaLosses => Math.Max(EaFriendlies.Count - EaWins - EaDraws, 0);
    private string RecentEaRecord => EaFriendlies.Count == 0 ? "--" : $"{EaWins}V {EaDraws}N {EaLosses}D";
    private double GoalsPerFriendly => EaFriendlies.Count == 0 ? 0 : EaFriendlies.Average(match => match.HomeEaClubId == DemoClubId ? match.HomeScore : match.AwayScore);

