    private async Task LoadMeAsync()
    {
        if (!AuthState.IsAuthenticated)
        {
            if (!HostEnvironment.IsProduction())
            {
                SelectDemoTeam();
                Message = "Mode demo TheSurvivors charge pour visualiser Mon equipe sans compte connecte.";
            }
            else
            {
                SelectedTeamId = null;
                SelectedTeamName = null;
                DemoMode = false;
                Message = "Connecte-toi ou cree ton compte pour voir ton club.";
            }

            return;
        }

        var result = await Api.GetMeAsync();
        Memberships.Clear();
        if (result.Value is not null)
        {
            Memberships.AddRange(result.Value.Memberships.Where(member => member.TeamId.HasValue));
            Message = $"Profil charge: {Memberships.Count} membership(s).";
            if (!SelectedTeamId.HasValue && Memberships.Count > 0)
            {
                var defaultClub = ManagedMemberships.FirstOrDefault() ?? Memberships.First();
