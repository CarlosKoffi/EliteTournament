    private void OpenPlayerSheet(string playerName)
    {
        var profile = EaProfiles.FirstOrDefault(player =>
            string.Equals(player.PlayerName, playerName, StringComparison.OrdinalIgnoreCase)
            || string.Equals(player.ProName, playerName, StringComparison.OrdinalIgnoreCase));

        if (profile is not null)
        {
            OpenPlayerSheet(profile);
            return;
        }

        var member = TeamMembers.FirstOrDefault(item =>
            string.Equals(item.DisplayName, playerName, StringComparison.OrdinalIgnoreCase)
            || string.Equals(item.Gamertag, playerName, StringComparison.OrdinalIgnoreCase));

        SelectedPlayerSheet = member is null
            ? PlayerSheetModel.FromName(playerName)
            : PlayerSheetModel.FromMember(member);
    }

