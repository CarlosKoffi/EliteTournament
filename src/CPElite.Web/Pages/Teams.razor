    private async Task SyncSelectedTeamAsync()
    {
        if (!SelectedTeamId.HasValue)
        {
            return;
        }

        if (DemoMode)
        {
            LoadDemoTeamData();
            await LoadLatestFriendlyDetailsAsync();
            Message = "Demo rafraichie depuis le cache local TheSurvivors.";
            return;
        }

        Busy = true;
        EaSyncBusy = true;
        Message = "Synchronisation EA en cours: club, effectif, joueurs et matchs amicaux...";
        var result = await Api.SyncTeamEaAsync(SelectedTeamId.Value, forceRefresh: true);
        EaSyncBusy = false;
        Busy = false;

        if (!result.Success)
        {
            Message = result.Error;
            return;
        }

        var sync = result.Value;
        await LoadStoredEaDataAsync();
        await LoadLatestFriendlyDetailsAsync();
        Message = EaFriendlies.Count == 0
            ? $"Synchro terminee: club={(sync?.ClubInfoSynced == true ? "ok" : "non")}, membres={(sync?.MemberStatsSynced == true ? "ok" : "non")}, types matchs={sync?.MatchTypesSynced ?? 0}. Aucun amical stocke pour ce club pour le moment."
            : $"Synchro terminee: {EaProfiles.Count} joueur(s), {EaFriendlies.Count} match(s) amicaux stockes, dernier match ouvert.";
    }

