        var profile = EaProfiles.FirstOrDefault(player =>
            string.Equals(player.EaPlayerId, stat.EaPlayerId, StringComparison.OrdinalIgnoreCase)
            || string.Equals(player.PlayerName, stat.PlayerName, StringComparison.OrdinalIgnoreCase));

