    private async Task UploadAssetAsync(InputFileChangeEventArgs args, Action<string> applyUrl, string successMessage)
    {
        if (!AuthState.IsAuthenticated)
        {
            Message = "Connecte-toi avant d'uploader une image.";
            return;
        }

        Busy = true;
        var file = args.File;
        await using var stream = file.OpenReadStream(5_000_000);
        var result = await Api.UploadTeamAssetAsync(stream, file.Name, file.ContentType);
        Busy = false;
        if (result.Value is null)
        {
            Message = result.Error;
            return;
        }

        applyUrl(result.Value.Url);
        if (SelectedTeamId.HasValue && !DemoMode)
        {
            await SaveSelectedTeamProfileAsync(successMessage);
            return;
        }

        Message = successMessage;
    }

    private async Task SaveSelectedTeamProfileAsync(string successMessage)
    {
        if (!SelectedTeamId.HasValue)
        {
            Message = successMessage;
            return;
        }

        var request = new UpdateTeamProfileRequest(
            Team.Name,
            Team.ShortName,
            Platform.CrossPlay,
            Team.Region,
            Team.Description,
            Team.EaClubId,
            Team.LogoUrl,
            Team.BannerUrl);

        var update = await Api.UpdateTeamProfileAsync(SelectedTeamId.Value, request);
        if (update.Value is null)
        {
            Message = update.Error;
            return;
        }

        ApplyTeamProfile(update.Value);
        Message = successMessage;
    }

