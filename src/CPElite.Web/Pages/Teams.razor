    private IReadOnlyList<FriendlyTeamSectionModel> BuildFriendlyTeamSections(EaFriendlyMatchDetailsResponse details)
    {
        var match = details.Match;
        var sections = new[]
        {
            BuildFriendlyTeamSection(details, match.HomeEaClubId, match.HomeClubName, match.HomeScore, isHome: true),
            BuildFriendlyTeamSection(details, match.AwayEaClubId, match.AwayClubName, match.AwayScore, isHome: false)
        };

        return sections
            .OrderByDescending(section => section.IsCurrentTeam)
            .ThenBy(section => section.IsHome ? 0 : 1)
            .ToArray();
    }

    private FriendlyTeamSectionModel BuildFriendlyTeamSection(EaFriendlyMatchDetailsResponse details, long eaClubId, string? clubName, int score, bool isHome)
    {
        var players = details.PlayerStats
            .Where(stat => stat.EaClubId == eaClubId)
            .OrderByDescending(stat => stat.PlayerOfTheMatch)
            .ThenByDescending(stat => stat.Rating ?? 0)
            .ThenBy(stat => stat.PlayerName)
            .ToArray();

        var clubStats = details.ClubStats.FirstOrDefault(stat => stat.EaClubId == eaClubId);
        return new FriendlyTeamSectionModel(
            eaClubId,
            string.IsNullOrWhiteSpace(clubName) ? $"Club {eaClubId}" : clubName,
            score,
            isHome,
            IsCurrentFriendlyClub(eaClubId),
            clubStats,
            players);
    }

    private bool IsCurrentFriendlyClub(long eaClubId)
    {
        if (ClubSnapshot?.EaClubId == eaClubId)
        {
            return true;
        }

        if (Team.EaClubId == eaClubId)
        {
            return true;
        }

        return DemoMode && eaClubId == DemoClubId;
    }

