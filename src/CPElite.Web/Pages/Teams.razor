    private sealed record PlayerSheetModel(
        string Name,
        string EaPlayerId,
        string ProName,
        string Position,
        string Source,
        bool HasApp,
        string Matches,
        string Goals,
        string Assists,
        string HeightLabel,
        string OverallLabel,
        string RatingLabel,
        string PlayerOfTheMatchLabel,
        string PassRateLabel,
        string TackleRateLabel,
        string ShotRateLabel,
        IReadOnlyCollection<PlayerMetricGroup> MetricGroups)
    {
        public string PositionFocusTitle => NormalizeSheetPosition(Position) switch
        {
            "goalkeeper" => "Lecture gardien",
            "defender" => "Lecture defenseur",
            "midfielder" => "Lecture milieu",
            "forward" => "Lecture offensif",
            _ => "Lecture joueur"
        };

        public string PositionFocusText => NormalizeSheetPosition(Position) switch
        {
            "goalkeeper" => "Priorite aux arrets, buts encaisses et clean sheets.",
            "defender" => "Priorite aux tacles, clean sheets, relance et discipline.",
            "midfielder" => "Priorite aux passes, assists, recuperation et volume de jeu.",
            "forward" => "Priorite aux buts, assists, tirs et note du match.",
            _ => "Priorite aux actions decisives et a l'impact global."
        };

        public IReadOnlyCollection<PlayerMetric> PriorityMetrics => NormalizeSheetPosition(Position) switch
        {
            "goalkeeper" => new[] { new PlayerMetric("Note", RatingLabel), new PlayerMetric("Matchs", Matches), new PlayerMetric("MOTM", PlayerOfTheMatchLabel), new PlayerMetric("Passes", PassRateLabel) },
            "defender" => new[] { new PlayerMetric("Tacles", TackleRateLabel), new PlayerMetric("Note", RatingLabel), new PlayerMetric("MOTM", PlayerOfTheMatchLabel), new PlayerMetric("Passes", PassRateLabel) },
            "midfielder" => new[] { new PlayerMetric("Passes", PassRateLabel), new PlayerMetric("Assists", Assists), new PlayerMetric("Tacles", TackleRateLabel), new PlayerMetric("Note", RatingLabel) },
            "forward" => new[] { new PlayerMetric("Buts", Goals), new PlayerMetric("Assists", Assists), new PlayerMetric("Tirs", ShotRateLabel), new PlayerMetric("Note", RatingLabel) },
            _ => new[] { new PlayerMetric("Buts", Goals), new PlayerMetric("Assists", Assists), new PlayerMetric("Passes", PassRateLabel), new PlayerMetric("Note", RatingLabel) }
        };

        private static string NormalizeSheetPosition(string? value)
        {
            if (string.IsNullOrWhiteSpace(value))
            {
                return string.Empty;
            }

            var normalized = value.Trim().ToLowerInvariant();
            if (normalized.Contains("goal") || normalized.Contains("keeper") || normalized.Contains("gardien")) return "goalkeeper";
            if (normalized.Contains("def") || normalized.Contains("back") || normalized.Contains("dc") || normalized.Contains("dd") || normalized.Contains("dg")) return "defender";
            if (normalized.Contains("mid") || normalized.Contains("mil") || normalized.Contains("moc") || normalized.Contains("mdc") || normalized.Contains("mc")) return "midfielder";
            if (normalized.Contains("for") || normalized.Contains("att") || normalized.Contains("ailier") || normalized.Contains("buteur") || normalized.Contains("striker")) return "forward";
            return normalized;
        }

        public static PlayerSheetModel FromProfile(EaPlayerProfileSnapshotResponse player, bool hasApp)
        {
            return new PlayerSheetModel(
                player.PlayerName,
                player.EaPlayerId,
                player.ProName ?? player.PlayerName,
                player.Position ?? "Poste inconnu",
                "Profil EA enrichi",
                hasApp,
                player.Matches?.ToString() ?? "-",
                player.Goals?.ToString() ?? "-",
                player.Assists?.ToString() ?? "-",
                player.Height?.ToString() is { } height ? $"{height} cm" : "-",
                player.Overall?.ToString() ?? "-",
                player.AverageRating?.ToString("0.0") ?? "-",
                player.PlayerOfTheMatch?.ToString() ?? "-",
                player.PassSuccessRate?.ToString("0") is { } pass ? $"{pass}%" : "-",
                player.TackleSuccessRate?.ToString("0") is { } tackle ? $"{tackle}%" : "-",
                player.ShotSuccessRate?.ToString() is { } shot ? $"{shot}%" : "-",
                BuildProfileMetricGroups(player));
        }

        public static PlayerSheetModel FromMatchStat(EaMatchPlayerStatResponse stat, EaPlayerProfileSnapshotResponse? profile, bool hasApp)
        {
            return new PlayerSheetModel(
                stat.PlayerName,
                stat.EaPlayerId,
                profile?.ProName ?? stat.PlayerName,
                stat.Position ?? profile?.Position ?? "Poste inconnu",
                stat.PlayerOfTheMatch ? "Detail match EA - homme du match" : "Detail match EA",
                hasApp,
                profile?.Matches?.ToString() ?? "Match selectionne",
                stat.Goals?.ToString() ?? "0",
                stat.Assists?.ToString() ?? "0",
                profile?.Height?.ToString() is { } height ? $"{height} cm" : "-",
                profile?.Overall?.ToString() ?? "-",
                stat.Rating?.ToString("0.0") ?? profile?.AverageRating?.ToString("0.0") ?? "-",
                stat.PlayerOfTheMatch ? "Oui" : profile?.PlayerOfTheMatch?.ToString() ?? "-",
                stat.PassSuccessRate?.ToString("0") is { } pass ? $"{pass}%" : "-",
                stat.TackleSuccessRate?.ToString("0") is { } tackle ? $"{tackle}%" : "-",
                stat.Shots?.ToString() ?? "-",
                profile is null ? BuildMatchMetricGroups(stat) : BuildProfileMetricGroups(profile));
        }

        private static IReadOnlyCollection<PlayerMetricGroup> BuildProfileMetricGroups(EaPlayerProfileSnapshotResponse player)
        {
            return new[]
            {
                new PlayerMetricGroup("Current club", new[]
                {
                    Metric("Matchs", player.Matches),
                    Metric("Win rate", Percent(player.WinRate)),
                    Metric("Buts / match", Decimal(player.GoalsPerMatch)),
                    Metric("Assists / match", Decimal(player.AssistsPerMatch)),
                    Metric("G+A", player.GoalContributions),
                    Metric("G+A / match", Decimal(player.GoalContributionsPerMatch)),
                    Metric("MOTM rate", Percent(player.PlayerOfTheMatchRate))
                }),
                new PlayerMetricGroup("Attaque", new[]
                {
                    Metric("Buts", player.Goals),
                    Metric("Assists", player.Assists),
                    Metric("Tirs", player.Shots),
                    Metric("Reussite tirs", Percent(player.ShotSuccessRate)),
                    Metric("Prev goals", player.PrevGoals)
                }),
                new PlayerMetricGroup("Jeu collectif", new[]
                {
                    Metric("Passes reussies", player.PassesMade),
                    Metric("Passes tentees", player.PassAttempts),
                    Metric("Passes / match", Decimal(player.PassesMadePerMatch)),
                    Metric("Reussite passes", Percent(player.PassSuccessRate))
                }),
                new PlayerMetricGroup("Defense & gardien", new[]
                {
                    Metric("Tacles reussis", player.TacklesMade),
                    Metric("Tacles tentes", player.TackleAttempts),
                    Metric("Tacles / match", Decimal(player.TacklesMadePerMatch)),
                    Metric("Reussite tacles", Percent(player.TackleSuccessRate)),
                    Metric("Saves", player.Saves),
                    Metric("Clean sheets DEF", player.CleanSheets),
                    Metric("Clean sheets DEF rate", Percent(player.CleanSheetsDefRate)),
                    Metric("Clean sheets GK", player.CleanSheetsGk),
                    Metric("Clean sheets GK rate", Percent(player.CleanSheetsGkRate)),
                    Metric("Cartons rouges", player.RedCards)
                }),
                new PlayerMetricGroup("All clubs", new[]
                {
                    Metric("Matchs", player.AllClubsMatches),
                    Metric("Note", Decimal(player.AllClubsAverageRating)),
                    Metric("Buts", player.AllClubsGoals),
                    Metric("Assists", player.AllClubsAssists),
                    Metric("G+A", player.AllClubsGoalContributions),
                    Metric("G+A / match", Decimal(player.AllClubsGoalContributionsPerMatch)),
                    Metric("MOTM", player.AllClubsPlayerOfTheMatch),
                    Metric("MOTM rate", Percent(player.AllClubsPlayerOfTheMatchRate))
                })
            };
        }

        private static IReadOnlyCollection<PlayerMetricGroup> BuildMatchMetricGroups(EaMatchPlayerStatResponse stat)
        {
            return new[]
            {
                new PlayerMetricGroup("Match selectionne", new[]
                {
                    Metric("Buts", stat.Goals),
                    Metric("Assists", stat.Assists),
                    Metric("Note", Decimal(stat.Rating)),
                    Metric("Tirs", stat.Shots),
                    Metric("Passes", $"{stat.PassesMade?.ToString() ?? "-"}/{stat.PassAttempts?.ToString() ?? "-"}"),
                    Metric("Tacles", $"{stat.TacklesMade?.ToString() ?? "-"}/{stat.TackleAttempts?.ToString() ?? "-"}"),
                    Metric("Saves", stat.Saves),
                    Metric("Carton rouge", stat.RedCards)
                })
            };
        }

        private static PlayerMetric Metric(string label, int? value) => new(label, value?.ToString() ?? "-");

        private static PlayerMetric Metric(string label, string value) => new(label, string.IsNullOrWhiteSpace(value) ? "-" : value);

        private static string Decimal(double? value) => value?.ToString("0.##") ?? "-";

        private static string Percent(double? value) => value?.ToString("0.#") is { } percent ? $"{percent}%" : "-";
