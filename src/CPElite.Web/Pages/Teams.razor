    private static string BuildMatchPlayerSmartLine(EaMatchPlayerStatResponse stat)
    {
        return NormalizeMatchPosition(stat.Position) switch
        {
            "goalkeeper" => $"{FormatMatchNumber(stat.Saves)} arrets - {FormatMatchNumber(stat.GoalsConceded)} but(s) encaisse(s) - {CleanSheetLabel(stat.CleanSheetsGk)} - {FormatMatchRating(stat.Rating)} note",
            "defender" => $"{FormatMatchNumber(stat.TacklesMade)} tacles - {FormatMatchPercent(stat.TackleSuccessRate)} tacles - {CleanSheetLabel(stat.CleanSheetsDef)} - {FormatMatchRating(stat.Rating)} note",
            "midfielder" => $"{FormatMatchPercent(stat.PassSuccessRate)} passes - {FormatMatchNumber(stat.PassesMade)} passes reussies - {FormatMatchNumber(stat.TacklesMade)} tacles - {FormatMatchNumber(stat.Assists)} assist",
            "forward" => $"{FormatMatchNumber(stat.Goals)} but(s) - {FormatMatchNumber(stat.Assists)} assist - {FormatMatchNumber(stat.Shots)} tirs - {FormatMatchRating(stat.Rating)} note",
            _ => $"{FormatMatchNumber(stat.Goals)} B - {FormatMatchNumber(stat.Assists)} A - {FormatMatchPercent(stat.PassSuccessRate)} passes - {FormatMatchRating(stat.Rating)} note"
        };
    }

    private static string CleanSheetLabel(int? value) => value.GetValueOrDefault() > 0 ? "clean sheet" : "pas de clean sheet";

    private static string FormatMatchNumber(int? value) => value?.ToString() ?? "-";

    private static string FormatMatchRating(double? value) => value?.ToString("0.0") ?? "-";

    private static string FormatMatchPercent(double? value) => value is null ? "-" : $"{value:0.#}%";

    private static string NormalizeMatchPosition(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var normalized = value.Trim().ToLowerInvariant();
        if (normalized.Contains("goal") || normalized.Contains("keeper") || normalized.Contains("gardien")) return "goalkeeper";
        if (normalized.Contains("def") || normalized.Contains("back") || normalized.Contains("dc") || normalized.Contains("dd") || normalized.Contains("dg")) return "defender";
        if (normalized.Contains("mid") || normalized.Contains("mil") || normalized.Contains("moc") || normalized.Contains("mdc") || normalized.Contains("mc")) return "midfielder";
        if (normalized.Contains("for") || normalized.Contains("att") || normalized.Contains("ailier") || normalized.Contains("buteur") || normalized.Contains("striker")) return "forward";
        return normalized;
    }

    private bool IsPlayerInApp(EaPlayerProfileSnapshotResponse player)
    {
        if (DemoMode)
        {
            return DemoAppPlayers.Contains(player.PlayerName)
                || (!string.IsNullOrWhiteSpace(player.ProName) && DemoAppPlayers.Contains(player.ProName));
        }

        return TeamMembers.Any(member =>
            string.Equals(member.Gamertag, player.PlayerName, StringComparison.OrdinalIgnoreCase)
            || string.Equals(member.Gamertag, player.ProName, StringComparison.OrdinalIgnoreCase)
            || string.Equals(member.DisplayName, player.PlayerName, StringComparison.OrdinalIgnoreCase)
            || string.Equals(member.DisplayName, player.ProName, StringComparison.OrdinalIgnoreCase));
    }

