    private async Task LoadSelectedTeamDataAsync()
    {
        if (!SelectedTeamId.HasValue)
        {
            return;
        }

        if (DemoMode)
        {
            LoadDemoTeamData();
            return;
        }

        var members = await Api.GetTeamMembersAsync(SelectedTeamId.Value);
        TeamMembers.Clear();
        if (members.Value is not null)
        {
            TeamMembers.AddRange(members.Value);
        }

        var profile = await Api.GetTeamAsync(SelectedTeamId.Value);
        if (profile.Value is not null)
        {
            ApplyTeamProfile(profile.Value);
        }

        await LoadStoredEaDataAsync();
        if (!HasStoredEaData)
        {
            await EnsureEaDataAvailableAsync();
        }

        await LoadLatestFriendlyDetailsAsync();

        Message = HasStoredEaData
            ? $"Equipe chargee depuis la base: {TeamMembers.Count} membre(s) app, {EaProfiles.Count} profil(s) EA, {EaFriendlies.Count} amical(aux)."
            : $"Equipe chargee: {TeamMembers.Count} membre(s) app. Aucune donnee EA stockee pour le moment.";
    }

    private bool HasStoredEaData => ClubSnapshot is not null || EaMembers is not null || EaProfiles.Count > 0 || EaFriendlies.Count > 0;

    private async Task EnsureEaDataAvailableAsync()
    {
        if (!SelectedTeamId.HasValue || DemoMode)
        {
            return;
        }

        EaSyncBusy = true;
        Message = "Aucune donnee EA en base pour ce club. Premiere synchronisation en cours...";
        var sync = await Api.SyncTeamEaAsync(SelectedTeamId.Value, forceRefresh: false);
        EaSyncBusy = false;

        if (!sync.Success)
        {
            Message = sync.Error;
            return;
        }

        await LoadStoredEaDataAsync();
    }

    private async Task LoadStoredEaDataAsync()
    {
        if (!SelectedTeamId.HasValue || DemoMode)
        {
            return;
        }

        var club = await Api.GetTeamEaClubAsync(SelectedTeamId.Value);
        ClubSnapshot = club.Value;

        var eaPlayers = await Api.GetTeamEaMembersAsync(SelectedTeamId.Value);
