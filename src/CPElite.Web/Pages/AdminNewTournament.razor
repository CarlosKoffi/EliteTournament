@page "/admin/tournaments/new"
@inject ApiClient Api
@inject AuthState AuthState

<PageTitle>TS Tournament Admin - Nouveau tournoi</PageTitle>

<section class="admin-hero">
    <div>
        <p class="eyebrow">Admin TS Tournament</p>
        <h1>Nouveau tournoi.</h1>
        <p>Cette page sert uniquement a creer un tournoi, fixer les inscriptions, les lots, les restrictions de taille et les restrictions de playstyles.</p>
    </div>
    <div class="admin-status">
        <span>Retour</span>
        <strong>Pilotage</strong>
        <nav class="admin-page-nav">
            <a href="admin/tournaments">Pilotage</a>
            <a class="active" href="admin/tournaments/new">Nouveau tournoi</a>
            <a href="admin/tournaments/tracking">Suivi tournois</a>
        </nav>
    </div>
</section>

@if (!AuthState.IsAuthenticated)
{
    <section class="panel">
        <p class="eyebrow">Connexion requise</p>
        <h2>Connecte-toi en admin pour creer un tournoi.</h2>
        <p class="muted">La creation du tournoi et l'upload de banniere sont proteges. Une fois connecte, tu pourras verifier la sauvegarde et l'affichage public.</p>
        <a class="button-link primary" href="login">Se connecter</a>
    </section>
}
else
{
    <section class="section-grid admin-grid">
        <article class="panel admin-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Configuration</p>
                    <h2>Nouveau tournoi</h2>
                </div>
            </div>

            <EditForm Model="Tournament" OnValidSubmit="CreateTournamentAsync">
            <div class="segmented-control">
                <button type="button" class="@(Tournament.Type == TournamentType.Normal ? "active" : "")" @onclick="() => SetType(TournamentType.Normal)">Simple</button>
                <button type="button" class="@(Tournament.Type == TournamentType.Goodies ? "active" : "")" @onclick="() => SetType(TournamentType.Goodies)">Goodies</button>
            </div>

            <div class="form-grid">
                <label>Nom <input value="@Tournament.Name" @oninput="value => Tournament.Name = ReadText(value)" /></label>
                <label>Tier
                    <select @bind="Tournament.Tier">
                        <option value="@TournamentTier.Diamond">Diamant</option>
                        <option value="@TournamentTier.Gold">Or</option>
                        <option value="@TournamentTier.Silver">Argent</option>
                        <option value="@TournamentTier.Bronze">Bronze</option>
                    </select>
                </label>
                <label>Banniere URL <input value="@Tournament.BannerUrl" placeholder="https://..." @oninput="value => Tournament.BannerUrl = ReadNullableText(value)" /></label>
                <label>Date <input type="date" value="@FormatDate(Tournament.StartsDate)" @oninput="value => Tournament.StartsDate = ReadDate(value, Tournament.StartsDate)" /></label>
                <label>Heure CET <input value="@Tournament.StartsTime" @oninput="value => Tournament.StartsTime = ReadText(value)" /></label>
                <label>Debut inscription <input type="date" value="@FormatDate(Tournament.RegistrationStartDate)" @oninput="value => Tournament.RegistrationStartDate = ReadDate(value, Tournament.RegistrationStartDate)" /></label>
                <label>Heure ouverture <input value="@Tournament.RegistrationStartTime" @oninput="value => Tournament.RegistrationStartTime = ReadText(value)" /></label>
                <label>Fin inscription <input type="date" value="@FormatDate(Tournament.RegistrationEndDate)" @oninput="value => Tournament.RegistrationEndDate = ReadDate(value, Tournament.RegistrationEndDate)" /></label>
                <label>Heure fermeture <input value="@Tournament.RegistrationEndTime" @oninput="value => Tournament.RegistrationEndTime = ReadText(value)" /></label>
                <label>Max teams <input type="number" value="@Tournament.MaxTeams" @oninput="value => Tournament.MaxTeams = ReadInt(value, Tournament.MaxTeams)" /></label>
                <label>Min teams <input type="number" value="@Tournament.MinTeams" @oninput="value => Tournament.MinTeams = ReadInt(value, Tournament.MinTeams)" /></label>
                <label>Participation equipe <input type="number" step="0.01" value="@Tournament.EntryFee" @oninput="value => Tournament.EntryFee = ReadDecimal(value, Tournament.EntryFee)" /></label>
                <label>Budget lots calcule <input value="@Tournament.PrizeBudget.ToString("0.##")" readonly /></label>
            </div>

            <label class="asset-upload compact-upload">
                Upload banniere tournoi
                <InputFile OnChange="UploadTournamentBannerAsync" accept="image/png,image/jpeg,image/webp,image/gif" />
                <small>Cette image sera affichee en fond de la carte tournoi.</small>
            </label>

            <label class="checkbox-line locked-check"><InputCheckbox @bind-Value="Tournament.IsCashPrize" disabled /> Cash prize / Goodies</label>
            <label>Lots / description automatique
                <textarea class="readonly-textarea" readonly>@Tournament.PrizeDescription</textarea>
            </label>

            <div class="admin-restriction-panel">
                <div>
                    <p class="eyebrow">Restrictions joueurs</p>
                    <h3>Taille & playstyles</h3>
                    <small>Ces regles seront visibles par les owners, mais non modifiables pendant l'inscription.</small>
                </div>
                <div class="form-grid">
                    <label>Taille max generale <input type="number" value="@Tournament.DefaultMaxHeightCm" @oninput="value => Tournament.DefaultMaxHeightCm = ReadInt(value, Tournament.DefaultMaxHeightCm)" /></label>
                    <label>Taille max DC <input type="number" value="@Tournament.CenterBackMaxHeightCm" @oninput="value => Tournament.CenterBackMaxHeightCm = ReadInt(value, Tournament.CenterBackMaxHeightCm)" /></label>
                    <label class="checkbox-line"><InputCheckbox @bind-Value="Tournament.EnablePlaystyleRestrictions" /> Activer restriction playstyles</label>
                    <label>Playstyles interdits <input value="@Tournament.ForbiddenPlaystyles" placeholder="Ex: Aerial+, Power Header+" @oninput="value => Tournament.ForbiddenPlaystyles = ReadText(value)" /></label>
                </div>
                <div class="restriction-preview">
                    <span>Regle publiee</span>
                    <strong>@Tournament.DefaultMaxHeightCm cm max - DC @Tournament.CenterBackMaxHeightCm cm</strong>
                    <small>@PlaystyleRestrictionPreview</small>
                </div>
            </div>

            <div class="admin-restriction-panel">
                <div>
                    <p class="eyebrow">Scores EA</p>
                    <h3>Recuperation par tournoi</h3>
                    <small>Ce reglage controle uniquement ce tournoi: manuel, toutes les X minutes, fin de match, fin de tour ou fin de tournoi.</small>
                </div>
                <div class="form-grid">
                    <label>Mode recuperation
                        <select @bind="Tournament.ScoreRecoveryMode">
                            <option value="@TournamentScoreRecoveryMode.ManualOnly">Manuel uniquement</option>
                            <option value="@TournamentScoreRecoveryMode.AutomaticEveryInterval">Automatique toutes les X minutes</option>
                            <option value="@TournamentScoreRecoveryMode.AfterEachMatch">Fin de chaque match</option>
                            <option value="@TournamentScoreRecoveryMode.EndOfRound">Fin de chaque tour</option>
                            <option value="@TournamentScoreRecoveryMode.EndOfTournament">Fin du tournoi</option>
                        </select>
                    </label>
                    <label>Intervalle minutes <input type="number" value="@Tournament.ScoreRecoveryIntervalMinutes" @oninput="value => Tournament.ScoreRecoveryIntervalMinutes = ReadInt(value, Tournament.ScoreRecoveryIntervalMinutes)" /></label>
                    <label class="checkbox-line"><InputCheckbox @bind-Value="Tournament.AutoPublishPerfectScore" /> Auto-valider si match parfait</label>
                </div>
                <div class="restriction-preview">
                    <span>Audit obligatoire</span>
                    <strong>@ScoreRecoveryPreview</strong>
                    <small>Chaque tentative loggue timestamp, equipes, score, joueurs annonces/joues, duree et doublons.</small>
                </div>
            </div>

                <button class="primary-action" disabled="@Busy">Creer le tournoi</button>
            </EditForm>
        </article>

        <article class="panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Apercu</p>
                    <h2>@Tournament.Name</h2>
                </div>
            </div>
            <div class="tournament-banner-preview" style="@TournamentBannerStyle">
                <div>
                    <span>@Tournament.Type</span>
                    <strong>@Tournament.Name</strong>
                    <small>@Tournament.StartsDate.ToString("dd/MM") @Tournament.StartsTime - @Tournament.MinTeams/@Tournament.MaxTeams equipes</small>
                </div>
            </div>
            <div class="metric-grid compact-metrics">
                <div class="metric-card"><span>Type</span><strong>@Tournament.Type</strong></div>
                <div class="metric-card"><span>Debut</span><strong>@Tournament.StartsDate.ToString("dd/MM") @Tournament.StartsTime</strong></div>
                <div class="metric-card"><span>Inscription</span><strong>@Tournament.RegistrationEndDate.ToString("dd/MM") @Tournament.RegistrationEndTime</strong></div>
                <div class="metric-card"><span>Equipes</span><strong>@Tournament.MinTeams - @Tournament.MaxTeams</strong></div>
                <div class="metric-card"><span>Participation</span><strong>@Tournament.EntryFee EUR</strong></div>
                <div class="metric-card"><span>1er</span><strong>@Tournament.FirstPrize EUR</strong></div>
                <div class="metric-card"><span>2e</span><strong>@Tournament.SecondPrize EUR</strong></div>
                <div class="metric-card"><span>3e</span><strong>Credit @Tournament.ThirdPrizeCredit EUR</strong></div>
                <div class="metric-card admin-only-metric"><span>Reste apres lots</span><strong>@Tournament.EstimatedNetAfterPrizes EUR</strong></div>
                <div class="metric-card"><span>Restrictions</span><strong>@Tournament.DefaultMaxHeightCm cm / DC @Tournament.CenterBackMaxHeightCm cm</strong></div>
                <div class="metric-card admin-only-metric"><span>Recup scores</span><strong>@ScoreRecoveryPreview</strong></div>
            </div>
            <div class="prize-preview-card">
                <span class="result-kind">Description sauvegardee</span>
                <p>@Tournament.PrizeDescription</p>
            </div>
        </article>
    </section>
}

@if (!string.IsNullOrWhiteSpace(Message))
{
    <div class="notice">@Message</div>
}

@code {
    private TournamentModel Tournament { get; } = new();
    private bool Busy;
    private string? Message;

    private string PlaystyleRestrictionPreview => Tournament.EnablePlaystyleRestrictions
        ? $"Interdits: {Tournament.ForbiddenPlaystyles}"
        : "Aucune restriction playstyle active.";

    private string ScoreRecoveryPreview => Tournament.ScoreRecoveryMode switch
    {
        TournamentScoreRecoveryMode.ManualOnly => "Manuel uniquement",
        TournamentScoreRecoveryMode.AutomaticEveryInterval => $"Toutes les {Tournament.ScoreRecoveryIntervalMinutes} min",
        TournamentScoreRecoveryMode.AfterEachMatch => "Fin de chaque match",
        TournamentScoreRecoveryMode.EndOfRound => "Fin de chaque tour",
        TournamentScoreRecoveryMode.EndOfTournament => "Fin du tournoi",
        _ => "Manuel uniquement"
    };

    private static string ReadText(ChangeEventArgs args) => args.Value?.ToString() ?? string.Empty;

    private static string? ReadNullableText(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        return string.IsNullOrWhiteSpace(value) ? null : value;
    }

    private static int ReadInt(ChangeEventArgs args, int fallback) =>
        int.TryParse(args.Value?.ToString(), out var value) ? value : fallback;

    private static decimal ReadDecimal(ChangeEventArgs args, decimal fallback) =>
        decimal.TryParse(args.Value?.ToString(), out var value) ? value : fallback;

    private static DateTime ReadDate(ChangeEventArgs args, DateTime fallback) =>
        DateTime.TryParse(args.Value?.ToString(), out var value) ? value : fallback;

    private static string FormatDate(DateTime value) => value.ToString("yyyy-MM-dd");

    private void SetType(TournamentType type)
    {
        Tournament.Type = type;
        if (type == TournamentType.Normal)
        {
            Tournament.Name = "Nouveau tournoi simple";
            Tournament.EntryFee = 0;
            Tournament.IsCashPrize = false;
        }
        else
        {
            Tournament.Name = "Nouveau tournoi goodies";
            Tournament.EntryFee = 50;
            Tournament.IsCashPrize = true;
        }
    }

    private async Task CreateTournamentAsync()
    {
        Busy = true;
        var request = new CreateTournamentRequest(
            Tournament.Name,
            Tournament.Type,
            Tournament.BuildStartsAt(),
            "Europe/Zurich",
            Tournament.MaxTeams,
            Tournament.EntryFee,
            "EUR",
            Tournament.PrizeDescription,
            Tournament.MinTeams,
            Tournament.BuildRegistrationEndsAt(),
            Tournament.PrizeBudget,
            15,
            60,
            Tournament.BuildRestrictionsJson(),
            Tournament.IsCashPrize,
            Tournament.BuildRegistrationStartsAt(),
            Tournament.BuildRegistrationEndsAt(),
            Tournament.BannerUrl,
            Tournament.ScoreRecoveryMode,
            Tournament.ScoreRecoveryIntervalMinutes,
            Tournament.AutoPublishPerfectScore,
            Tournament.Tier);

        var result = await Api.CreateTournamentAsync(request);
        Busy = false;
        Message = result.Success
            ? $"Tournoi cree: {result.Value?.Name}. Tu peux revenir au tableau de bord."
            : result.Error;
    }

    private async Task UploadTournamentBannerAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        await using var stream = file.OpenReadStream(5_000_000);
        var result = await Api.UploadTournamentBannerAsync(stream, file.Name, file.ContentType);
        if (result.Value is null)
        {
            Message = result.Error;
            return;
        }

        Tournament.BannerUrl = result.Value.Url;
        Message = "Banniere tournoi uploadee.";
    }

    private sealed class TournamentModel
    {
        public string Name { get; set; } = "Nouveau tournoi goodies";
        public TournamentType Type { get; set; } = TournamentType.Goodies;
        public TournamentTier Tier { get; set; } = TournamentTier.Gold;
        public DateTime StartsDate { get; set; } = DateTime.Today.AddDays(1);
        public string StartsTime { get; set; } = "22:30";
        public DateTime RegistrationStartDate { get; set; } = DateTime.Today;
        public string RegistrationStartTime { get; set; } = "12:00";
        public DateTime RegistrationEndDate { get; set; } = DateTime.Today.AddDays(1);
        public string RegistrationEndTime { get; set; } = "18:00";
        public int MaxTeams { get; set; } = 32;
        public int MinTeams { get; set; } = 24;
        public decimal EntryFee { get; set; } = 50m;
        public decimal PrizeBudget => FirstPrize + SecondPrize + ThirdPrizeCredit;
        public decimal GrossParticipation => IsCashPrize ? decimal.Round(EntryFee * MaxTeams, 2) : 0m;
        public decimal FirstPrize => IsCashPrize ? decimal.Round(EntryFee * 11m, 2) : 0m;
        public decimal SecondPrize => IsCashPrize ? decimal.Round(EntryFee * 5.5m, 2) : 0m;
        public decimal ThirdPrizeCredit => IsCashPrize ? decimal.Round(EntryFee, 2) : 0m;
        public decimal EstimatedNetAfterPrizes => decimal.Round(GrossParticipation - PrizeBudget, 2);
        public bool IsCashPrize { get; set; } = true;
        public string? BannerUrl { get; set; } = "/images/tournaments/friday-goodies.svg";
        public int DefaultMaxHeightCm { get; set; } = 182;
        public int CenterBackMaxHeightCm { get; set; } = 187;
        public bool EnablePlaystyleRestrictions { get; set; }
        public string ForbiddenPlaystyles { get; set; } = "";
        public TournamentScoreRecoveryMode ScoreRecoveryMode { get; set; } = TournamentScoreRecoveryMode.AutomaticEveryInterval;
        public int ScoreRecoveryIntervalMinutes { get; set; } = 2;
        public bool AutoPublishPerfectScore { get; set; }
        public string PrizeDescription => IsCashPrize
            ? $"Lots automatiques: 1er {FirstPrize:0.##} EUR de lots, 2e {SecondPrize:0.##} EUR de lots, 3e inscription offerte au prochain tournoi jusqu'a {ThirdPrizeCredit:0.##} EUR. Si le prochain tournoi coute plus cher, l'equipe paiera uniquement la difference."
            : "Tournoi simple sans goodies payants. Participation gratuite, classement et stats TS Tournament uniquement.";

        public DateTimeOffset BuildStartsAt()
        {
            var time = TimeSpan.Parse(StartsTime);
            return new DateTimeOffset(StartsDate.Date.Add(time), TimeSpan.FromHours(2));
        }

        public DateTimeOffset BuildRegistrationStartsAt()
        {
            var time = TimeSpan.Parse(RegistrationStartTime);
            return new DateTimeOffset(RegistrationStartDate.Date.Add(time), TimeSpan.FromHours(2));
        }

        public DateTimeOffset BuildRegistrationEndsAt()
        {
            var time = TimeSpan.Parse(RegistrationEndTime);
            return new DateTimeOffset(RegistrationEndDate.Date.Add(time), TimeSpan.FromHours(2));
        }

        public string BuildRestrictionsJson()
        {
            var playstyles = ForbiddenPlaystyles
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Select(value => value.Replace("\"", "\\\""))
                .ToArray();
            var forbidden = string.Join(",", playstyles.Select(value => $"\"{value}\""));
            var playstyleEnabled = EnablePlaystyleRestrictions ? "true" : "false";

            return "{"
                + "\"height\":{"
                + "\"enabled\":true,"
                + $"\"defaultMaxCm\":{DefaultMaxHeightCm},"
                + "\"positionOverrides\":{"
                + $"\"DC\":{CenterBackMaxHeightCm}"
                + "},"
                + "\"requiresProofWhenUnknown\":true"
                + "},"
                + "\"playstyles\":{"
                + $"\"enabled\":{playstyleEnabled},"
                + $"\"forbidden\":[{forbidden}],"
                + "\"requiresOwnerWarning\":true"
                + "}"
                + "}";
        }
    }

    private string TournamentBannerStyle => string.IsNullOrWhiteSpace(Tournament.BannerUrl)
        ? ""
        : $"background-image: linear-gradient(90deg, rgba(0,0,0,.82), rgba(0,0,0,.32)), url('{Tournament.BannerUrl}');";
}
