@page "/"
@implements IDisposable
@using CPElite.Contracts.Rankings
@inject AuthState AuthState
@inject IWebAssemblyHostEnvironment HostEnvironment
@inject ApiClient Api

<PageTitle>Elite Tournament</PageTitle>

<main class="et-home">
    <section class="et-hero">
        <div class="et-hero-copy">
            <span class="et-live-dot">Saison ouverte</span>
            <span class="et-hero-kicker">EAFC Club Pro Tournaments</span>
            <h1>Elite <span>Tournament</span></h1>
            <p>La plateforme competitive pour inscrire ton club, preparer les 11 joueurs, suivre les donnees EA et transformer chaque soiree tournoi en vrai evenement.</p>
            <div class="et-hero-actions">
                <a class="button-link primary" href="tournaments">Voir les tournois</a>
                <a class="button-link" href="account">Rejoindre la league</a>
            </div>
            <div class="et-hero-metrics" aria-label="Regles principales">
                <span>32 equipes max</span>
                <span>24 minimum</span>
                <span>22:30 CET</span>
                <span>EA data ready</span>
            </div>
        </div>

        <aside class="et-card et-featured-tournament">
            <div class="et-card-head">
                <div>
                    <span class="et-pill gold">Prochain tournoi</span>
                    <h2>@NextTournamentName</h2>
                </div>
                <span class="et-pill">Goodies</span>
            </div>

            <div class="et-countdown" aria-label="Compte a rebours du prochain tournoi">
                <div><strong>@CountdownDays</strong><span>Jours</span></div>
                <div><strong>@CountdownHours</strong><span>Heures</span></div>
                <div><strong>@CountdownMinutes</strong><span>Min</span></div>
                <div><strong>@CountdownSeconds</strong><span>Sec</span></div>
            </div>

            <div class="et-tournament-meta">
                <div class="et-meta-row"><span>Coup d'envoi</span><strong>@NextTournamentKickoff</strong></div>
                <div class="et-meta-row"><span>Places restantes</span><strong>@RemainingSlotsLabel</strong></div>
                <div class="et-progress-track" aria-label="Remplissage tournoi"><span class="et-progress-fill"></span></div>
            </div>
        </aside>
    </section>

    <section class="et-home-grid">
        <div>
            <div class="et-section-head">
                <div>
                    <span class="et-pill">Experience</span>
                    <h2>Tout le parcours tournoi au meme endroit.</h2>
                </div>
                <p>Du club EA jusqu'au suivi des matchs.</p>
            </div>

            <div class="et-feature-grid">
                <article class="et-card et-feature-card">
                    <span class="et-feature-number">01</span>
                    <div>
                        <strong>Inscription club</strong>
                        <p>Le owner choisit son club, selectionne les 11 et genere les liens pour les joueurs sans compte.</p>
                    </div>
                </article>
                <article class="et-card et-feature-card">
                    <span class="et-feature-number">02</span>
                    <div>
                        <strong>Presence des joueurs</strong>
                        <p>Chaque joueur confirme sa disponibilite, son retard ou son absence avant le coup d'envoi.</p>
                    </div>
                </article>
                <article class="et-card et-feature-card">
                    <span class="et-feature-number">03</span>
                    <div>
                        <strong>Donnees EA stockees</strong>
                        <p>Les clubs et profils joueurs sont recuperes puis sauvegardes pour eviter les appels inutiles.</p>
                    </div>
                </article>
                <article class="et-card et-feature-card">
                    <span class="et-feature-number">04</span>
                    <div>
                        <strong>Pont Discord</strong>
                        <p>Le bot servira au depart de relais, avec l'objectif de ramener les equipes vers l'application.</p>
                    </div>
                </article>
            </div>
        </div>

        <aside class="et-table-card et-leaderboard">
            <div class="et-card-head">
                <div>
                    <span class="et-pill">Leaderboard</span>
                    <h2>Top equipes</h2>
                </div>
            </div>

            <div class="et-table">
                <div class="et-table-row et-table-head"><span>#</span><span>Equipe</span><span>PTS</span></div>
                @if (TopTeams.Count == 0)
                {
                    <div class="et-table-row">
                        <span class="et-rank">-</span>
                        <span>@(LeaderboardMessage ?? "Classement disponible apres les premiers tournois.")</span>
                        <span class="et-points">-</span>
                    </div>
                }
                @foreach (var team in TopTeams)
                {
                    <div class="et-table-row @(team.Rank == 1 ? "active" : "")">
                        <span class="et-rank">@team.Rank</span>
                        <button type="button" class="et-team-button" @onclick="() => OpenClubSheet(team)">@team.TeamName</button>
                        <span class="et-points">@team.Points</span>
                    </div>
                }
            </div>
        </aside>
    </section>

    <section class="et-card et-home-search">
        <div class="et-section-head">
            <div>
                <span class="et-pill">Recherche</span>
                <h2>Trouver une equipe, un joueur ou une annonce.</h2>
            </div>
        </div>

        @if (AuthState.IsAuthenticated)
        {
            <div class="search-row">
                <input @bind="SearchQuery" placeholder="Ex: BU ce soir, TheSurvivors, tournoi goodies..." />
                <select @bind="SearchType">
                    <option>Tout</option>
                    <option>Equipes</option>
                    <option>Joueurs</option>
                    <option>Mercato</option>
                    <option>Tournois</option>
                </select>
                <button class="primary-action">Rechercher</button>
            </div>
            @if (!GlobalResults.Any())
            {
                <div class="et-locked-search">
                    <strong>Aucun resultat pour le moment</strong>
                    <p>Les resultats apparaitront quand les equipes, joueurs, annonces mercato et tournois seront crees.</p>
                </div>
            }
            else
            {
                <div class="global-results">
                    @foreach (var result in GlobalResults)
                    {
                        <a class="global-result-card" href="@result.Href">
                            <span class="result-kind">@result.Kind</span>
                            <strong>@result.Title</strong>
                            <small>@result.Detail</small>
                        </a>
                    }
                </div>
            }
        }
        else
        {
            <div class="et-locked-search">
                <strong>Connecte-toi pour rechercher.</strong>
                <p>Les annonces publiques restent visibles, mais la recherche et les fiches detaillees sont reservees aux comptes Elite Tournament.</p>
                <div class="et-hero-actions">
                    <a class="button-link primary" href="login">Se connecter</a>
                    <a class="button-link" href="account">Creer un compte</a>
                </div>
            </div>
        }
    </section>
</main>

@if (SelectedClub is not null)
{
    <section class="detail-drawer">
        <div class="detail-drawer-card">
            <div class="drawer-heading">
                <div>
                    <p class="eyebrow">Fiche club</p>
                    <h2>@SelectedClub.TeamName</h2>
                </div>
                <button class="ghost-action" @onclick="CloseClubSheet">Fermer</button>
            </div>

            <div class="drawer-metrics">
                <div><span>Leaderboard</span><strong>#@SelectedClub.Rank</strong></div>
                <div><span>Points</span><strong>@SelectedClub.Points</strong></div>
                <div><span>Record</span><strong>@SelectedClub.Wins V / @SelectedClub.Draws N / @SelectedClub.Losses D</strong></div>
            </div>

            <div class="drawer-data-grid">
                <article>
                    <span class="result-kind">Classement Elite Tournament</span>
                    <div class="player-skill-grid">
                        <div><span>Matchs</span><strong>@SelectedClub.MatchesPlayed</strong></div>
                        <div><span>Diff.</span><strong>@GoalDifferenceLabel(SelectedClub)</strong></div>
                        <div><span>Clean sheets</span><strong>@SelectedClub.CleanSheets</strong></div>
                        <div><span>MAJ</span><strong>@SelectedClub.UpdatedAt.LocalDateTime.ToString("dd/MM HH:mm")</strong></div>
                    </div>
                </article>
                <article>
                    <span class="result-kind">Parcours tournois</span>
                    <dl>
                        <div><dt>Tournois joues</dt><dd>@SelectedClub.TournamentsPlayed</dd></div>
                        <div><dt>Titres</dt><dd>@SelectedClub.Titles</dd></div>
                        <div><dt>Finales</dt><dd>@SelectedClub.Finals</dd></div>
                        <div><dt>Podiums</dt><dd>@SelectedClub.Podiums</dd></div>
                    </dl>
                </article>
            </div>
        </div>
    </section>
}

@code {
    private string SearchQuery { get; set; } = "";
    private string SearchType { get; set; } = "Tout";
    private List<ClubRankingResponse> TopTeams { get; } = [];
    private ClubRankingResponse? SelectedClub;
    private string? LeaderboardMessage { get; set; }

    private string NextTournamentName => "Saturday Goodies Cup";
    private string NextTournamentKickoff => "25/07 - 22:30 CET";
    private DateTimeOffset NextTournamentStartsAt { get; } = new(2026, 7, 25, 22, 30, 0, TimeSpan.FromHours(2));
    private TimeSpan CountdownRemaining { get; set; } = TimeSpan.Zero;
    private int CountdownDays => Math.Max(CountdownRemaining.Days, 0);
    private int CountdownHours => Math.Max(CountdownRemaining.Hours, 0);
    private int CountdownMinutes => Math.Max(CountdownRemaining.Minutes, 0);
    private int CountdownSeconds => Math.Max(CountdownRemaining.Seconds, 0);
    private string RemainingSlotsLabel => "14 places";
    private PeriodicTimer? CountdownTimer { get; set; }
    private CancellationTokenSource? CountdownCancellation { get; set; }

    private IEnumerable<SearchResultItem> GlobalResults => SearchSeed.Where(item =>
        (SearchType == "Tout" || item.Kind == SearchType)
        && (string.IsNullOrWhiteSpace(SearchQuery)
            || item.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || item.Detail.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)));

    private IReadOnlyCollection<SearchResultItem> SearchSeed => HostEnvironment.IsProduction()
        ? []
        :
        [
            new("Equipes", "TheSurvivors", "Club lie EA, 11 joueurs actifs, owner connecte", "teams"),
            new("Mercato", "BU recherche ce soir", "TheSurvivors cherche un buteur disponible avec compte Elite", "mercato"),
            new("Tournois", "Saturday Goodies Cup", "32 equipes max, inscription jusqu'a 21:00", "tournaments"),
            new("Joueurs", "KoffiMarvelous", "Profil joueur, EA Sports ID et club principal", "account")
        ];

    protected override async Task OnInitializedAsync()
    {
        AuthState.Changed += StateHasChanged;
        UpdateCountdown();
        StartCountdown();
        await LoadLeaderboardAsync();
    }

    private void StartCountdown()
    {
        CountdownCancellation = new CancellationTokenSource();
        CountdownTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = RunCountdownAsync(CountdownCancellation.Token);
    }

    private async Task RunCountdownAsync(CancellationToken cancellationToken)
    {
        if (CountdownTimer is null)
        {
            return;
        }

        try
        {
            while (await CountdownTimer.WaitForNextTickAsync(cancellationToken))
            {
                UpdateCountdown();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void UpdateCountdown()
    {
        var remaining = NextTournamentStartsAt - DateTimeOffset.Now;
        CountdownRemaining = remaining > TimeSpan.Zero ? remaining : TimeSpan.Zero;
    }

    private async Task LoadLeaderboardAsync()
    {
        var result = await Api.GetClubRankingsAsync(take: 5);
        TopTeams.Clear();
        if (result.Value is not null)
        {
            TopTeams.AddRange(result.Value);
            LeaderboardMessage = null;
            return;
        }

        LeaderboardMessage = "Classement indisponible pour le moment.";
    }

    private void OpenClubSheet(ClubRankingResponse team)
    {
        SelectedClub = team;
    }

    private void CloseClubSheet()
    {
        SelectedClub = null;
    }

    public void Dispose()
    {
        CountdownCancellation?.Cancel();
        CountdownCancellation?.Dispose();
        CountdownTimer?.Dispose();
        AuthState.Changed -= StateHasChanged;
    }

    private static string GoalDifferenceLabel(ClubRankingResponse team) => team.GoalDifference > 0 ? $"+{team.GoalDifference}" : team.GoalDifference.ToString();
    private sealed record SearchResultItem(string Kind, string Title, string Detail, string Href);
}
