@page "/tournaments"
@implements IDisposable
@inject ApiClient Api
@inject AuthState AuthState

<PageTitle>TS Tournament - Tournois</PageTitle>

<section class="page-title">
    <p class="eyebrow">Espace joueur</p>
    <h1>Tournois disponibles</h1>
    <p>@(AuthState.IsAuthenticated ? "Le owner peut gerer plusieurs clubs, inscrire le bon club au bon tournoi, puis soumettre les 11 joueurs qui doivent confirmer leur presence." : "Consulte les prochains tournois disponibles. Cree ton compte pour inscrire ton equipe et acceder au suivi complet.")</p>
</section>

<section class="tournament-catalog">
    <article class="tournament-product simple" style="@CommunityCupBannerStyle">
        <div>
            <p class="eyebrow">Tournoi simple</p>
            <h2>Community Cup</h2>
            <p>Tournoi ouvert aux equipes Pro Clubs. Il reste des places: cree ton compte et ramene ton equipe pour participer.</p>
        </div>
        <div class="product-rules">
            <span>Date: Dimanche 05/07</span>
            <span>Coup d'envoi: 22:30 CET</span>
            <strong>Dans 7 jours</strong>
            <span>Il reste 14 places</span>
        </div>
        <a class="button-link primary" href="@(AuthState.IsAuthenticated ? "#owner-submit" : "account")">@(AuthState.IsAuthenticated ? "Preparer mon equipe" : "Creer ton compte et ramener ton equipe")</a>
    </article>

    <article class="tournament-product goodies" style="@GoodiesCupBannerStyle">
        <div>
            <p class="eyebrow">Tournoi goodies</p>
            <h2>Friday Goodies Cup</h2>
            <p>Tournoi ouvert aux equipes Pro Clubs. Il reste des places: cree ton compte et ramene ton equipe pour participer.</p>
        </div>
        <div class="product-rules">
            <strong>Goodies</strong>
            <span>Date: Vendredi 03/07</span>
            <span>Coup d'envoi: 22:30 CET</span>
            <strong>Dans 5 jours</strong>
            <span>Il reste 21 places</span>
        </div>
        <a class="button-link primary" href="@(AuthState.IsAuthenticated ? "#owner-submit" : "account")">@(AuthState.IsAuthenticated ? "Preparer mon equipe" : "Creer ton compte et ramener ton equipe")</a>
    </article>
</section>

@if (!AuthState.IsAuthenticated)
{
    <section class="panel public-tournament-lock">
        <div>
            <p class="eyebrow">Acces public</p>
            <h2>Des places sont encore disponibles</h2>
            <p>Pour inscrire une equipe, voir tes tournois, gerer ton roster ou valider les presences, il faut creer un compte TS Tournament.</p>
        </div>
        <div class="public-tournament-actions">
            <a class="button-link primary" href="account">Creer un compte</a>
            <a class="button-link" href="login">Se connecter</a>
        </div>
    </section>
}

@if (AuthState.IsAuthenticated)
{
<section class="panel player-tournament-panel">
    <div class="panel-heading">
        <div>
            <p class="eyebrow">Mes tournois</p>
            <h2>Suivi equipe TheSurvivors</h2>
        </div>
    </div>

    <div class="tournament-tabs">
        <button class="@(PlayerTournamentTab == "live" ? "active" : "")" @onclick='() => PlayerTournamentTab = "live"'>En cours</button>
        <button class="@(PlayerTournamentTab == "upcoming" ? "active" : "")" @onclick='() => PlayerTournamentTab = "upcoming"'>A venir</button>
        <button class="@(PlayerTournamentTab == "past" ? "active" : "")" @onclick='() => PlayerTournamentTab = "past"'>Passes</button>
    </div>

    @if (PlayerTournamentTab == "live")
    {
        <div class="player-tournament-grid">
        <article class="live-team-card">
            <span class="result-kind">TheSurvivors</span>
            <h3>Poule B terminee</h3>
            <span class="presence-pill confirmed">Qualifie phase finale</span>
            <p>2 victoires, 1 nul, 8 points. Prochain match: quart de finale contre HOF 221.</p>
            <div class="ops-metrics">
                <div><span>BP</span><strong>6</strong></div>
                <div><span>BC</span><strong>3</strong></div>
                <div><span>Diff</span><strong>+3</strong></div>
            </div>
        </article>

        <article class="group-table-card">
            <div class="tournament-card-heading">
                <span class="result-kind">Classement poule B</span>
                <small>Top 2 qualifies</small>
            </div>
            <div class="group-table-header">
                <span>#</span>
                <span>Equipe</span>
                <span>Pts</span>
                <span>Forme</span>
            </div>
            @foreach (var row in DemoGroupRows)
            {
                <div class="group-table-row @(row.Team == "TheSurvivors" ? "highlight" : "")">
                    <strong>@row.Rank</strong>
                    <button type="button" class="inline-team-link group-team-name" @onclick="() => OpenClubSheetAsync(row.Team)">@row.Team</button>
                    <span>@row.Points</span>
                    <small>@row.Record</small>
                </div>
            }
        </article>

        <article class="match-history-card">
            <span class="result-kind">Matchs joues</span>
            @foreach (var match in DemoMyTournamentMatches)
            {
                <article class="match-row-action">
                    <div class="match-summary-button" role="button" tabindex="0" @onclick="() => OpenDemoMatch(match)">
                        <span>@match.Stage</span>
                        <strong>
                            <button type="button" class="inline-team-link" @onclick:stopPropagation @onclick="() => OpenClubSheetAsync(match.Home)">@match.Home</button>
                            @match.HomeScore - @match.AwayScore
                            <button type="button" class="inline-team-link" @onclick:stopPropagation @onclick="() => OpenClubSheetAsync(match.Away)">@match.Away</button>
                        </strong>
                        <small>@match.Status</small>
                    </div>
                    @if (match.Players.Count > 0)
                    {
                        <span class="match-player-links">
                            @foreach (var playerName in match.Players)
                            {
                                <button type="button" class="match-player-avatar-link" @onclick="() => OpenPlayerByNameAsync(playerName)">
                                    <span class="player-photo-ring">@GetInitials(playerName)</span>
                                    <span>@playerName</span>
                                </button>
                            }
                        </span>
                    }
                </article>
            }
        </article>

        <article class="award-race-card">
            <span class="result-kind">Courses individuelles</span>
            @foreach (var award in DemoAwardRace)
            {
                <div>
                    <span>@award.Label</span>
                    <button type="button" class="inline-player-link strong-link" @onclick="() => OpenPlayerByNameAsync(award.Player)">@award.Player</button>
                    <small>@award.Value</small>
                </div>
            }
        </article>

        <article class="current-lineup-card">
            <div class="panel-heading compact">
                <div>
                    <p class="eyebrow">Compo engagee</p>
                    <h2>@SelectedFormation</h2>
                </div>
            </div>
            <div class="lineup-board compact" style="--kit-primary: @KitPrimaryColor; --kit-accent: @KitAccentColor;">
                @foreach (var row in LineupRows)
                {
                    <div class="lineup-row" style="grid-template-columns: repeat(@row.Count, minmax(0, 1fr));">
                        @foreach (var slot in row)
                        {
                            <button class="lineup-slot @(slot.Player is null ? "empty" : "") @(slot.Player is not null && !IsHeightEligibleForTournament(slot.Player) ? "invalid" : "")" @onclick="() => OpenLineupPlayerAsync(slot.Player)">
                                <span class="lineup-position">@slot.Position</span>
                                <span class="lineup-marker">@GetPlayerNumber(slot.Player)</span>
                                <strong>@(slot.Player?.DisplayName ?? "A choisir")</strong>
                                <small>@(slot.Player is null ? "Slot ouvert" : $"{slot.Player.Height} cm · {slot.Player.Overall} OVR")</small>
                            </button>
                        }
                    </div>
                }
            </div>
        </article>

        <article class="current-roster-card">
            <span class="result-kind">Joueurs presents</span>
            <div class="compact-player-list">
                @foreach (var player in Roster.Where(player => player.Selected).Take(11))
                {
                    <button @onclick="() => OpenPlayerSheetAsync(player)">
                        <strong>@player.DisplayName</strong>
                        <span>@player.Position · @player.Status · @player.Height cm</span>
                    </button>
                }
            </div>
        </article>
        </div>
    }

    @if (PlayerTournamentTab == "upcoming")
    {
        <div class="player-tournament-grid compact">
            <article class="live-team-card">
                <span class="result-kind">A venir</span>
                <h3>Sunday Community Cup</h3>
                <p>Inscriptions ouvertes jusqu'a 18:00. TheSurvivors peut inscrire son roster des maintenant.</p>
                <div class="ops-metrics">
                    <div><span>Debut</span><strong>22:30</strong></div>
                    <div><span>Type</span><strong>Simple</strong></div>
                    <div><span>Equipes</span><strong>18/32</strong></div>
                </div>
            </article>
            <article class="live-team-card">
                <span class="result-kind">Goodies</span>
                <h3>Friday Goodies Cup #5</h3>
                <p>Restriction taille deja publiee. Lots physiques, 24 equipes minimum.</p>
                <div class="ops-metrics">
                    <div><span>Debut</span><strong>22:30</strong></div>
                    <div><span>Fee</span><strong>50 EUR</strong></div>
                    <div><span>Equipes</span><strong>11/32</strong></div>
                </div>
            </article>
        </div>
    }

    @if (PlayerTournamentTab == "past")
    {
        <div class="past-summary-grid">
            <article class="ops-feature-card history">
                <span class="result-kind">Friday Goodies Cup #3</span>
                <h3>TheSurvivors finaliste</h3>
                <p>Elimine en finale contre HOF 221, score 2-1. Parcours: 2e de poule, victoire en quart, victoire en demi.</p>
                <div class="podium-grid">
                    <div class="podium-card place-1"><span>#1</span><button type="button" class="inline-team-link" @onclick='() => OpenClubSheetAsync("HOF 221")'>HOF 221</button><small>Champion</small></div>
                    <div class="podium-card place-2"><span>#2</span><button type="button" class="inline-team-link" @onclick='() => OpenClubSheetAsync("TheSurvivors")'>TheSurvivors</button><small>Finaliste</small></div>
                    <div class="podium-card place-3"><span>#3</span><button type="button" class="inline-team-link" @onclick='() => OpenClubSheetAsync("FC Toho")'>FC Toho</button><small>Inscription offerte</small></div>
                </div>
            </article>
            <article class="award-race-card">
                <span class="result-kind">Awards tournoi</span>
                <div><span>Meilleur buteur</span><button type="button" class="inline-player-link strong-link" @onclick='() => OpenPlayerByNameAsync("ginga_blaze")'>ginga_blaze</button><small>9 buts</small></div>
                <div><span>Meilleur passeur</span><button type="button" class="inline-player-link strong-link" @onclick='() => OpenPlayerByNameAsync("KoffiMarvelous")'>KoffiMarvelous</button><small>7 assists</small></div>
                <div><span>Homme du tournoi</span><button type="button" class="inline-player-link strong-link" @onclick='() => OpenPlayerByNameAsync("IDRdemon")'>IDRdemon</button><small>4 MVP</small></div>
            </article>
            <article class="award-race-card">
                <span class="result-kind">Awards TheSurvivors</span>
                <div><span>Buteur equipe</span><button type="button" class="inline-player-link strong-link" @onclick='() => OpenPlayerByNameAsync("ginga_blaze")'>ginga_blaze</button><small>6 buts</small></div>
                <div><span>Passeur equipe</span><button type="button" class="inline-player-link strong-link" @onclick='() => OpenPlayerByNameAsync("KoffiMarvelous")'>KoffiMarvelous</button><small>7 assists</small></div>
                <div><span>Homme equipe</span><button type="button" class="inline-player-link strong-link" @onclick='() => OpenPlayerByNameAsync("Tchollismo")'>Tchollismo</button><small>3 MVP</small></div>
            </article>
        </div>
    }
</section>
}

@if (AuthState.IsAuthenticated && PlayerTournamentTab == "upcoming")
{
<section id="owner-submit" class="owner-submit-shell">
    <div class="owner-submit-hero">
        <div>
            <p class="eyebrow">Owner desk</p>
            <h2>Soumettre les 11 joueurs</h2>
            <p>Un owner peut gerer plusieurs clubs. Il choisit le club inscrit ce soir, selectionne 11 joueurs, puis chaque joueur recoit sa confirmation de presence.</p>
        </div>
        <div class="owner-readiness-card">
            <span>Validation</span>
            <strong>@SelectedRosterCount / 11</strong>
            <small>@ReadinessLabel</small>
        </div>
    </div>

    <div class="owner-submit-grid">
        <article class="panel owner-control-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Club</p>
                    <h2>Equipe a inscrire</h2>
                </div>
                <button class="ghost-action" @onclick="LoadOwnerContextAsync">Charger mes clubs</button>
            </div>

            <label>Club owner
                <select @bind="SelectedOwnerTeamId" @bind:after="LoadRosterForSelectedTeamAsync">
                    @foreach (var club in OwnerTeams)
                    {
                        <option value="@club.TeamId">@club.Name</option>
                    }
                </select>
            </label>

            <button class="team-entry-card clickable-card" @onclick="OpenTeamSheetAsync">
                <div class="club-avatar">@SelectedOwnerTeamInitials</div>
                <div>
                    <span class="result-kind">Tournoi goodies</span>
                    <strong>@SelectedOwnerTeamName</strong>
                    <small>Friday Goodies Cup - coup d'envoi 22:30 CET</small>
                </div>
            </button>

            <div class="tournament-rule-card">
                <div>
                    <span class="result-kind">Infos tournoi</span>
                    <strong>Friday Goodies Cup</strong>
                </div>
                <div class="tournament-rule-summary">
                    <div><span>Max general</span><strong>@DefaultMaxHeightCm cm</strong></div>
                    <div><span>Exception DC</span><strong>@CenterBackMaxHeightCm cm</strong></div>
                    <div><span>Debut</span><strong>22:30 CET</strong></div>
                    <div><span>Type</span><strong>Goodies</strong></div>
                </div>
                <div class="club-kit-summary">
                    <div>
                        <span class="kit-swatch" style="background: @KitPrimaryColor;"></span>
                        <span class="kit-swatch accent" style="background: @KitAccentColor;"></span>
                    </div>
                    <small>Couleurs definies dans la configuration du club TheSurvivors.</small>
                </div>
                <div class="formation-control">
                    <label>Formation
                        <select @bind="SelectedFormation">
                            <option>4-2-3-1</option>
                            <option>4-3-3</option>
                            <option>3-5-2</option>
                            <option>4-4-2</option>
                        </select>
                    </label>
                </div>
                <small>Regles fixees par l'admin du tournoi: tous les joueurs max @DefaultMaxHeightCm cm, sauf les DC max @CenterBackMaxHeightCm cm.</small>
            </div>

            <div class="owner-checklist">
                <div class="@(SelectedRosterCount == 11 ? "done" : "")"><strong>11</strong><span>joueurs selectionnes</span></div>
                <div class="@(ConfirmedRosterCount >= 11 ? "done" : "")"><strong>@ConfirmedRosterCount</strong><span>confirmations</span></div>
                <div class="@(LateRosterCount == 0 ? "done" : "warning")"><strong>@LateRosterCount</strong><span>retard signale</span></div>
                <div class="done"><strong>@AvailableRosterCount</strong><span>joueurs disponibles</span></div>
                <div class="@(UnavailableRosterCount == 0 ? "done" : "warning")"><strong>@UnavailableRosterCount</strong><span>pas disponibles</span></div>
                <div class="@(HeightViolationCount == 0 ? "done" : "warning")"><strong>@HeightViolationCount</strong><span>hors restriction taille</span></div>
            </div>

            <div class="row-actions">
                <button class="primary-action" @onclick="SubmitRosterAsync" disabled="@(SelectedRosterCount != 11 || HeightViolationCount > 0 || Busy)">Soumettre les 11</button>
                <button class="ghost-action" @onclick="RemindPendingAsync" disabled="@Busy">Relancer les joueurs</button>
            </div>
        </article>

        <article class="panel roster-submit-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Effectif</p>
                    <h2>Disponibilites puis selection</h2>
                </div>
                <span class="owner-capacity @(SelectedRosterCount > 11 ? "danger" : "")">@SelectedRosterCount / 11</span>
            </div>

            <div class="availability-strip">
                <div><strong>@AvailableRosterCount</strong><span>disponibles</span></div>
                <div><strong>@UnavailableRosterCount</strong><span>absents</span></div>
                <div><strong>@LateRosterCount</strong><span>retards</span></div>
            </div>

            @if (HeightViolationCount > 0)
            {
                <div class="rules-alert">
                    <div>
                        <span>Composition non conforme</span>
                        <strong>@HeightViolationCount joueur(s) hors restriction taille</strong>
                        <small>Le bouton de soumission reste bloque tant que la compo ne respecte pas les regles du tournoi.</small>
                    </div>
                    <div class="rules-alert-list">
                        @foreach (var player in Roster.Where(player => player.Selected && !IsHeightEligibleForTournament(player)))
                        {
                            <button @onclick="() => OpenPlayerSheetAsync(player)">
                                <strong>@player.DisplayName</strong>
                                <span>@player.Position · @player.Height cm / max @GetMaxHeightForPosition(player.Position) cm</span>
                            </button>
                        }
                    </div>
                </div>
            }

            <div class="matchday-roster">
                @foreach (var player in Roster)
                {
                    <article class="matchday-player @(player.Selected ? "selected" : "") @(SelectedPlayer == player ? "focused" : "") @(player.IsUnavailable ? "unavailable" : "") @(!player.HasApp ? "app-required" : "") @(player.Selected && !IsHeightEligibleForTournament(player) ? "height-warning" : "")" @onclick="() => OpenPlayerSheetAsync(player)">
                        <label class="matchday-select">
                            <input type="checkbox" checked="@player.Selected" @onclick:stopPropagation @onchange="args => TogglePlayer(player, args)" disabled="@(!player.CanBeSelected || (!player.Selected && (SelectedRosterCount >= 11 || !IsHeightEligibleForTournament(player))))" />
                            <span></span>
                        </label>
                        <div class="club-avatar small">@GetInitials(player.DisplayName)</div>
                        <div class="player-main">
                            <strong>@player.DisplayName</strong>
                            <small>@player.Gamertag</small>
                            <div class="player-inline-data">
                                <span class="app-state @(player.HasApp ? "in-app" : "outside-app")">@(player.HasApp ? "App installee" : "A inviter")</span>
                                <span>EA @player.EaPosition</span>
                                <span class="@(IsHeightEligibleForTournament(player) ? "" : "rule-alert")">@player.Height cm</span>
                                <span>@player.Overall OVR</span>
                                <span>@player.Matches MJ</span>
                            </div>
                        </div>
                        <select @bind="player.Position" @onclick:stopPropagation>
                            <option>GK</option>
                            <option>DC</option>
                            <option>DG</option>
                            <option>DD</option>
                            <option>MDC</option>
                            <option>MC</option>
                            <option>MOC</option>
                            <option>AG</option>
                            <option>AD</option>
                            <option>BU</option>
                        </select>
                        <span class="presence-pill @player.StatusCss">@player.Status</span>
                    </article>
                }
            </div>
        </article>

        <article class="panel lineup-overview-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow">Compo tournoi</p>
                    <h2>@SelectedFormation</h2>
                </div>
                <span class="owner-capacity @(HeightViolationCount > 0 ? "danger" : "")">@HeightViolationCount alerte(s)</span>
            </div>
            <div class="lineup-board" style="--kit-primary: @KitPrimaryColor; --kit-accent: @KitAccentColor;">
                @foreach (var row in LineupRows)
                {
                    <div class="lineup-row" style="grid-template-columns: repeat(@row.Count, minmax(0, 1fr));">
                        @foreach (var slot in row)
                        {
                            <button class="lineup-slot @(slot.Player is null ? "empty" : "") @(slot.Player is not null && !IsHeightEligibleForTournament(slot.Player) ? "invalid" : "")" @onclick="() => OpenLineupPlayerAsync(slot.Player)">
                                <span class="lineup-position">@slot.Position</span>
                                <span class="lineup-marker">@GetPlayerNumber(slot.Player)</span>
                                <strong>@(slot.Player?.DisplayName ?? "A choisir")</strong>
                                <small>@(slot.Player is null ? "Slot ouvert" : $"{slot.Player.Height} cm · {slot.Player.Overall} OVR")</small>
                            </button>
                        }
                    </div>
                }
            </div>
            <div class="lineup-note">
                <strong>Objectif final</strong>
                <span>Tout gerer ici dans l'app: selection, restrictions, confirmations, compo, notifications. Le bot Discord servira seulement de pont au debut.</span>
            </div>
        </article>
    </div>
</section>
}

@if (OpenedSheet == "team")
{
    <section class="detail-drawer">
        <div class="detail-drawer-card">
            <div class="drawer-heading">
                <div>
                    <p class="eyebrow">Fiche equipe</p>
                    <h2>@OpenedClubName</h2>
                </div>
                <button class="ghost-action" @onclick="CloseSheet">Fermer</button>
            </div>

            <div class="drawer-metrics">
                <div><span>EA club</span><strong>@(TeamClubSnapshot?.EaClubId.ToString() ?? "Demo")</strong></div>
                <div><span>Division</span><strong>@(TeamClubSnapshot?.Division?.ToString() ?? SelectedClubProfile?.Division.ToString() ?? "1")</strong></div>
                <div><span>Forme EA</span><strong>@(SelectedClubProfile?.EaForm ?? "2V 1N 0D")</strong></div>
            </div>

            <div class="drawer-metrics">
                <div><span>Stats tournoi</span><strong>@(SelectedClubProfile?.TournamentRecord ?? "3 matchs")</strong></div>
                <div><span>Buts TS</span><strong>@(SelectedClubProfile?.TournamentGoalsFor.ToString() ?? "6")</strong></div>
                <div><span>Meilleur joueur</span><strong>@(SelectedClubProfile?.KeyPlayer ?? "KoffiMarvelous")</strong></div>
            </div>

            <div class="drawer-data-grid">
                <article>
                    <span class="result-kind">Donnees club</span>
                    <dl>
                        <div><dt>Nom EA</dt><dd>@(TeamClubSnapshot?.Name ?? OpenedClubName)</dd></div>
                        <div><dt>Abbreviation</dt><dd>@(TeamClubSnapshot?.Abbreviation ?? SelectedClubProfile?.ShortName ?? SelectedOwnerTeamInitials)</dd></div>
                        <div><dt>Plateforme</dt><dd>@(TeamClubSnapshot?.Platform ?? "common-gen5")</dd></div>
                        <div><dt>Derniere synchro</dt><dd>@(TeamClubSnapshot?.SyncedAt.LocalDateTime.ToString("dd/MM HH:mm") ?? "Demo locale")</dd></div>
                        <div><dt>Statut TS</dt><dd>@(SelectedClubProfile?.TournamentStatus ?? "Qualifie phase finale")</dd></div>
                    </dl>
                </article>
                <article>
                    <span class="result-kind">Stats tournoi app</span>
                    <div class="player-skill-grid">
                        <div><span>MJ</span><strong>@(SelectedClubProfile?.TournamentPlayed.ToString() ?? "3")</strong></div>
                        <div><span>BP</span><strong>@(SelectedClubProfile?.TournamentGoalsFor.ToString() ?? "6")</strong></div>
                        <div><span>BC</span><strong>@(SelectedClubProfile?.TournamentGoalsAgainst.ToString() ?? "3")</strong></div>
                        <div><span>Classement</span><strong>@(SelectedClubProfile?.Standing ?? "1er poule B")</strong></div>
                    </div>
                </article>
                <article>
                    <span class="result-kind">Stats membres EA</span>
                    @if (TeamEaMembers?.Players.Count > 0)
                    {
                        <div class="compact-player-list">
                            @foreach (var player in TeamEaMembers.Players.Take(6))
                            {
                                <div>
                                    <button type="button" class="inline-player-link strong-link" @onclick="() => OpenPlayerByNameAsync(player.Name)">@player.Name</button>
                                    <span>@(player.Goals?.ToString() ?? "-") buts / @(player.Assists?.ToString() ?? "-") assists</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="muted">On affichera ici les stats membres des que la synchro EA/Tracker les a stockees pour ce club.</p>
                    }
                </article>
            </div>
        </div>
