@code {
    private Guid DemoTournamentId { get; } = Guid.Parse("aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa");
    private const string CommunityCupBannerUrl = "/images/tournaments/community-cup.svg";
    private const string GoodiesCupBannerUrl = "/images/tournaments/friday-goodies.svg";
    private Guid? SelectedOwnerTeamId { get; set; }
    private List<OwnerTeamOption> OwnerTeams { get; } = [];
    private List<RosterPlayerModel> Roster { get; } = [];
    private bool Busy;
    private string? Message;
    private string? OpenedSheet;
    private RosterPlayerModel? SelectedPlayer;
    private string PlayerTournamentTab { get; set; } = "live";
    private EaClubSnapshotResponse? TeamClubSnapshot;
    private EaMemberStatsSummaryResponse? TeamEaMembers;
    private EaPlayerLookupResponse? SelectedPlayerEa;
    private DemoClubProfile? SelectedClubProfile;
    private int DefaultMaxHeightCm { get; set; } = 182;
    private int CenterBackMaxHeightCm { get; set; } = 187;
    private string SelectedFormation { get; set; } = "4-3-3";
    private string KitPrimaryColor { get; set; } = "#057a55";
    private string KitAccentColor { get; set; } = "#d6f35f";
    private int SelectedRosterCount => Roster.Count(player => player.Selected);
    private int ConfirmedRosterCount => Roster.Count(player => player.Selected && player.Status == "Confirme");
    private int LateRosterCount => Roster.Count(player => player.Selected && player.Status == "Retard");
    private int AvailableRosterCount => Roster.Count(player => !player.IsUnavailable);
    private int UnavailableRosterCount => Roster.Count(player => player.IsUnavailable);
    private int HeightViolationCount => Roster.Count(player => player.Selected && !IsHeightEligibleForTournament(player));
    private string ReadinessLabel => SelectedRosterCount == 11 && ConfirmedRosterCount == 11 && HeightViolationCount == 0 ? "Equipe prete" : "En attente joueurs";
    private string SelectedOwnerTeamName => OwnerTeams.FirstOrDefault(team => team.TeamId == SelectedOwnerTeamId)?.Name ?? "TheSurvivors";
    private string SelectedOwnerTeamInitials => GetInitials(SelectedOwnerTeamName);
    private string OpenedClubName => SelectedClubProfile?.Name ?? SelectedOwnerTeamName;
    private IReadOnlyList<IReadOnlyList<LineupSlotModel>> LineupRows => BuildLineupRows();
    private static string CommunityCupBannerStyle => BuildTournamentBannerStyle(CommunityCupBannerUrl);
    private static string GoodiesCupBannerStyle => BuildTournamentBannerStyle(GoodiesCupBannerUrl);

    private static string BuildTournamentBannerStyle(string? bannerUrl)
    {
        return string.IsNullOrWhiteSpace(bannerUrl)
            ? ""
            : $"background-image: linear-gradient(90deg, rgba(0,0,0,.86), rgba(0,0,0,.52)), url('{bannerUrl}');";
    }

    protected override async Task OnInitializedAsync()
    {
        AuthState.Changed += OnAuthStateChanged;
        await LoadOwnerContextAsync();
    }

    private void OnAuthStateChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadOwnerContextAsync();
            StateHasChanged();
        });
    }

    private async Task LoadOwnerContextAsync()
    {
        OwnerTeams.Clear();
        if (AuthState.IsAuthenticated)
        {
            var result = await Api.GetMeAsync();
            if (result.Value is not null)
            {
                OwnerTeams.AddRange(result.Value.Memberships
                    .Where(member => member.TeamId.HasValue && (member.Role is TeamRole.Owner or TeamRole.Manager))
                    .Select(member => new OwnerTeamOption(member.TeamId!.Value, member.TeamName ?? member.DisplayName)));
            }
        }

        if (OwnerTeams.Count == 0)
        {
            OwnerTeams.AddRange(DemoOwnerTeams);
        }

        SelectedOwnerTeamId ??= OwnerTeams[0].TeamId;
        await LoadRosterForSelectedTeamAsync();
    }

    private async Task LoadRosterForSelectedTeamAsync()
    {
        Roster.Clear();
        TeamClubSnapshot = null;
        TeamEaMembers = null;
        SelectedPlayer = null;
        SelectedPlayerEa = null;
        if (SelectedOwnerTeamId.HasValue && AuthState.IsAuthenticated)
        {
            var result = await Api.GetTeamMembersAsync(SelectedOwnerTeamId.Value);
            if (result.Value is not null && result.Value.Count > 0)
            {
                Roster.AddRange(result.Value.Select((member, index) => RosterPlayerModel.FromAppMember(member.UserId, member.DisplayName, member.Gamertag ?? member.DisplayName, DefaultPosition(index), index < 11, DemoStatus(index))));
            }
        }

        if (Roster.Count == 0)
        {
            Roster.AddRange(DemoRoster);
            LoadDemoEaTeamData();
        }
    }

    private async Task OpenTeamSheetAsync()
    {
        SelectedClubProfile = DemoClubProfiles.FirstOrDefault(club => string.Equals(club.Name, SelectedOwnerTeamName, StringComparison.OrdinalIgnoreCase));
        OpenedSheet = "team";
        if (SelectedOwnerTeamId.HasValue && AuthState.IsAuthenticated)
        {
            TeamClubSnapshot = (await Api.GetTeamEaClubAsync(SelectedOwnerTeamId.Value)).Value;
            TeamEaMembers = (await Api.GetTeamEaMembersAsync(SelectedOwnerTeamId.Value)).Value;
        }
        else
        {
            LoadDemoEaTeamData();
        }
    }

    private Task OpenClubSheetAsync(string teamName)
    {
        SelectedClubProfile = DemoClubProfiles.FirstOrDefault(club => string.Equals(club.Name, teamName, StringComparison.OrdinalIgnoreCase))
            ?? new DemoClubProfile(teamName, GetInitials(teamName), 0, "A synchroniser", "Pas encore lie", 0, 0, 0, "Non classe", "Profil a completer", "Club detecte dans le tournoi");

        if (string.Equals(teamName, SelectedOwnerTeamName, StringComparison.OrdinalIgnoreCase))
        {
            return OpenTeamSheetAsync();
        }

        TeamClubSnapshot = new EaClubSnapshotResponse(
            SelectedOwnerTeamId ?? DemoOwnerTeams.First().TeamId,
            0,
            "common-gen5",
            SelectedClubProfile.Name,
            SelectedClubProfile.ShortName,
            SelectedClubProfile.Division,
            11,
            DateTimeOffset.UtcNow.AddMinutes(-18));
        TeamEaMembers = null;
        OpenedSheet = "team";
        return Task.CompletedTask;
    }

    private async Task OpenPlayerSheetAsync(RosterPlayerModel player)
    {
        SelectedPlayer = player;
        SelectedPlayerEa = null;
        OpenedSheet = "player";
        if (player.HasApp)
        {
            var result = await Api.SearchEaPlayerAsync(player.Gamertag);
            SelectedPlayerEa = result.Value;
        }
    }

    private Task OpenPlayerByNameAsync(string? playerName)
    {
        var player = FindPlayerByName(playerName);
        if (player is null)
        {
            Message = $"Fiche joueur indisponible pour {playerName}. On doit encore relier ce joueur a un profil EA stocke.";
            return Task.CompletedTask;
        }

        return OpenPlayerSheetAsync(player);
    }

    private RosterPlayerModel? FindPlayerByName(string? playerName)
    {
        if (string.IsNullOrWhiteSpace(playerName))
        {
            return null;
        }

        return Roster.FirstOrDefault(player => IsSamePlayer(player, playerName))
            ?? DemoRoster.FirstOrDefault(player => IsSamePlayer(player, playerName));
    }

    private static bool IsSamePlayer(RosterPlayerModel player, string playerName)
    {
        return string.Equals(player.DisplayName, playerName, StringComparison.OrdinalIgnoreCase)
            || string.Equals(player.Gamertag, playerName, StringComparison.OrdinalIgnoreCase)
            || string.Equals(player.ProName, playerName, StringComparison.OrdinalIgnoreCase);
    }

    private void CloseSheet()
    {
        OpenedSheet = null;
    }

    private void TogglePlayer(RosterPlayerModel player, ChangeEventArgs args)
    {
        player.Selected = player.CanBeSelected && IsHeightEligibleForTournament(player) && args.Value is bool selected && selected;
    }

    private void RefreshPlayerEaInfo(RosterPlayerModel player)
    {
        player.RefreshEaSnapshot();
        Message = $"{player.DisplayName}: donnees EA mises a jour. Taille actuelle {player.Height} cm, OVR {player.Overall}.";
    }

    private void NotifyPlayer(RosterPlayerModel player, string reason)
    {
        var label = reason switch
        {
            "taille" => "ta taille n'est pas conforme aux restrictions du tournoi",
            "playstyle" => "un playstyle doit etre verifie avant validation",
            _ => "merci de valider ta presence pour le tournoi"
        };

        Message = $"Notification envoyee a {player.DisplayName}: {label}.";
    }

    private void OpenDemoMatch(DemoTournamentMatchRow match)
    {
        Message = $"{match.Home} {match.HomeScore}-{match.AwayScore} {match.Away}: stats detaillees disponibles en demo.";
    }

    private Task OpenLineupPlayerAsync(RosterPlayerModel? player)
    {
        return player is null ? Task.CompletedTask : OpenPlayerSheetAsync(player);
    }

    private bool IsHeightEligibleForTournament(RosterPlayerModel player)
    {
        return player.Height <= GetMaxHeightForPosition(player.Position);
    }

    private int GetMaxHeightForPosition(string position)
    {
        return string.Equals(position, "DC", StringComparison.OrdinalIgnoreCase)
            ? CenterBackMaxHeightCm
            : DefaultMaxHeightCm;
    }

    private IReadOnlyList<IReadOnlyList<LineupSlotModel>> BuildLineupRows()
    {
        var usedPlayerIds = new HashSet<Guid>();
        return GetFormationRows(SelectedFormation)
            .Select(row => row.Select(position => new LineupSlotModel(position, GetLineupPlayer(position, usedPlayerIds))).ToArray())
            .ToArray();
    }

    private RosterPlayerModel? GetLineupPlayer(string slot, HashSet<Guid> usedPlayerIds)
    {
        var selected = Roster.Where(player => player.Selected).ToList();
        var direct = selected.FirstOrDefault(player => !usedPlayerIds.Contains(player.UserId) && string.Equals(player.Position, slot, StringComparison.OrdinalIgnoreCase));
        if (direct is not null)
        {
            usedPlayerIds.Add(direct.UserId);
            return direct;
        }

        var fallback = slot switch
        {
            "DC" => selected.FirstOrDefault(player => !usedPlayerIds.Contains(player.UserId) && player.Position is "DG" or "DD" or "MDC"),
            "DG" or "DD" => selected.FirstOrDefault(player => !usedPlayerIds.Contains(player.UserId) && player.Position is "DC" or "MDC"),
            "MDC" => selected.FirstOrDefault(player => !usedPlayerIds.Contains(player.UserId) && player.Position is "MC" or "DC"),
            "MC" => selected.FirstOrDefault(player => !usedPlayerIds.Contains(player.UserId) && player.Position is "MDC" or "MOC"),
            "MOC" => selected.FirstOrDefault(player => !usedPlayerIds.Contains(player.UserId) && player.Position is "MC" or "AG" or "AD"),
            "AG" or "AD" => selected.FirstOrDefault(player => !usedPlayerIds.Contains(player.UserId) && player.Position is "MOC" or "BU"),
            "BU" => selected.FirstOrDefault(player => !usedPlayerIds.Contains(player.UserId) && player.Position is "AG" or "AD" or "MOC"),
            _ => null
        };

        if (fallback is not null)
        {
            usedPlayerIds.Add(fallback.UserId);
        }

        return fallback;
    }

    private void LoadDemoEaTeamData()
    {
        TeamClubSnapshot = new EaClubSnapshotResponse(SelectedOwnerTeamId ?? DemoOwnerTeams.First().TeamId, 2148207, "common-gen5", SelectedOwnerTeamName, "TSV", 8, Roster.Count, DateTimeOffset.UtcNow.AddMinutes(-14));
        TeamEaMembers = new EaMemberStatsSummaryResponse(
            SelectedOwnerTeamId ?? DemoOwnerTeams.First().TeamId,
            2148207,
            "common-gen5",
            DateTimeOffset.UtcNow.AddMinutes(-14),
            Roster.Count,
            Roster.Select(player => new EaPlayerStatsResponse(player.DisplayName, player.Gamertag, player.Matches, player.Goals, player.Assists, player.AverageRating, player.EaPosition)).ToArray());
    }

    private async Task SubmitRosterAsync()
    {
        Busy = true;
        if (SelectedOwnerTeamId.HasValue && AuthState.IsAuthenticated)
        {
            foreach (var player in Roster.Where(player => player.Selected).Take(11))
            {
                await Api.AddTournamentParticipantAsync(DemoTournamentId, SelectedOwnerTeamId.Value, new AddTournamentParticipantRequest(player.UserId, player.Position));
            }
        }

        Busy = false;
        Message = "Composition soumise. Les 11 joueurs doivent maintenant valider leur presence.";
    }

    private async Task RemindPendingAsync()
    {
        Busy = true;
        if (SelectedOwnerTeamId.HasValue && AuthState.IsAuthenticated)
        {
            await Api.RemindPendingTournamentParticipantsAsync(DemoTournamentId, SelectedOwnerTeamId.Value);
        }

        Busy = false;
        Message = "Relance envoyee aux joueurs qui n'ont pas encore confirme.";
    }

    private static string DefaultPosition(int index)
    {
        var positions = new[] { "GK", "DG", "DC", "DC", "DD", "MDC", "MC", "MOC", "AG", "AD", "BU" };
        return positions[index % positions.Length];
    }

    private static string DemoStatus(int index)
    {
        return index switch
        {
            2 or 8 => "En attente",
            6 => "Retard",
            _ => "Confirme"
        };
    }

    private static string GetInitials(string value)
    {
        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        return parts.Length == 0 ? "CP" : string.Concat(parts.Take(2).Select(part => char.ToUpperInvariant(part[0])));
    }

    private static string GetPlayerNumber(RosterPlayerModel? player)
    {
        if (player is null)
        {
            return "+";
        }

        var stableNumber = Math.Abs(player.DisplayName.GetHashCode()) % 89 + 1;
        return stableNumber.ToString("00");
    }

