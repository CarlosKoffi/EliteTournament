                        <div><dt>Poste EA</dt><dd>@SelectedPlayer.EaPosition</dd></div>
                        <div><dt>Matchs</dt><dd>@SelectedPlayer.Matches</dd></div>
                        <div><dt>Win rate</dt><dd>@SelectedPlayer.WinRate%</dd></div>
                        <div><dt>Buts</dt><dd>@SelectedPlayer.Goals</dd></div>
                        <div><dt>Assists</dt><dd>@SelectedPlayer.Assists</dd></div>
                        <div><dt>Homme du match</dt><dd>@SelectedPlayer.PlayerOfTheMatch</dd></div>
                        <div><dt>PrevGoals</dt><dd>@SelectedPlayer.PrevGoals</dd></div>
                    </dl>
                </article>
                <article>
                    <span class="result-kind">Controle owner</span>
                    <div class="drawer-metrics inline">
                        <div><span>Poste tournoi</span><strong>@SelectedPlayer.Position</strong></div>
                        <div><span>Presence</span><strong>@SelectedPlayer.Status</strong></div>
                    </div>
                    <div class="player-skill-grid">
                        <div><span>Tirs</span><strong>@SelectedPlayer.ShotSuccessRate%</strong></div>
                        <div><span>Passes</span><strong>@SelectedPlayer.PassSuccessRate.ToString("0")%</strong></div>
                        <div><span>Tacles</span><strong>@SelectedPlayer.TackleSuccessRate.ToString("0")%</strong></div>
                        <div><span>App</span><strong>@(SelectedPlayer.HasApp ? "Oui" : "Non")</strong></div>
                    </div>
                    <div class="owner-player-actions">
                        <button class="ghost-action" @onclick="() => RefreshPlayerEaInfo(SelectedPlayer)">Mettre a jour EA</button>
                        <button class="ghost-action" @onclick='() => NotifyPlayer(SelectedPlayer, "presence")'>Notifier presence</button>
                        <button class="ghost-action danger" @onclick='() => NotifyPlayer(SelectedPlayer, "taille")' disabled="@IsHeightEligibleForTournament(SelectedPlayer)">Notifier taille</button>
                        <button class="ghost-action" @onclick='() => NotifyPlayer(SelectedPlayer, "playstyle")'>Notifier playstyle</button>
                    </div>
                    <p class="muted">Le poste EA reste visible pour guider le owner, mais le poste tournoi peut etre ajuste si le joueur depanne ailleurs.</p>
                </article>
            </div>
        </div>
    </section>
}

