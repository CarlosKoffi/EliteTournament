    private static string PositionGroup(string? position)
    {
        if (string.IsNullOrWhiteSpace(position))
        {
            return "GEN";
        }

        var normalized = position.ToUpperInvariant();
        if (normalized.Contains("GK") || normalized.Contains("GARDIEN")) return "GK";
        if (normalized.Contains("CB") || normalized.Contains("DC") || normalized.Contains("LB") || normalized.Contains("RB") || normalized.Contains("DEF") || normalized.Contains("DD") || normalized.Contains("DG")) return "DEF";
        if (normalized.Contains("CM") || normalized.Contains("CDM") || normalized.Contains("CAM") || normalized.Contains("MC") || normalized.Contains("MOC") || normalized.Contains("MDC") || normalized.Contains("MIL")) return "MIL";
        if (normalized.Contains("ST") || normalized.Contains("LW") || normalized.Contains("RW") || normalized.Contains("BU") || normalized.Contains("AG") || normalized.Contains("AD") || normalized.Contains("ATT")) return "ATT";
        return normalized.Length > 3 ? normalized[..3] : normalized;
    }

