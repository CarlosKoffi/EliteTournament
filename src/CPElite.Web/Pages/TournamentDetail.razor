@page "/tournaments/{TournamentId:guid}"
@inject ApiClient Api
@inject AuthState AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Elite Tournament - Detail tournoi</PageTitle>
<HeadContent>
    <link rel="stylesheet" href="css/elite-tournament.tournament-detail.css?v=20260724-2" />
</HeadContent>

<main class="et-detail-page">
    @if (Loading)
    {
        <section class="et-detail-empty">
            <strong>Chargement du tournoi</strong>
            <p>On recupere les equipes inscrites, les matchs et les donnees EA liees.</p>
        </section>
    }
    else if (!AuthState.IsAuthenticated)
    {
        <section class="et-detail-empty">
            <strong>Connexion requise</strong>
            <p>Les informations detaillees du tournoi sont disponibles apres connexion.</p>
            <button type="button" class="etd-primary" @onclick='() => Navigation.NavigateTo("account")'>Se connecter</button>
        </section>
    }
    else if (Detail is null)
    {
        <section class="et-detail-empty">
            <strong>Tournoi introuvable</strong>
            <p>@(ErrorMessage ?? "Impossible de charger ce tournoi depuis la base.")</p>
            <button type="button" class="etd-secondary" @onclick='() => Navigation.NavigateTo("tournaments")'>Retour tournois</button>
        </section>
    }
    else
    {
        <section class="et-detail-hero" style="@BuildBannerStyle(Detail.Tournament.BannerUrl)">
            <button type="button" class="etd-back" @onclick='() => Navigation.NavigateTo("tournaments")'>Retour</button>
            <div>
                <span class="etd-kicker">@TournamentStatusLabel(Detail.Tournament)</span>
                <h1>@Detail.Tournament.Name</h1>
                <p>@TournamentIntro(Detail.Tournament)</p>
            </div>
            <aside class="etd-hero-score">
                <span>@(Detail.Tournament.IsCashPrize ? "Goodies" : "Tournoi")</span>
                <strong>@FormatDate(Detail.Tournament.StartsAt)</strong>
                <small>@FormatTime(Detail.Tournament.StartsAt) @Detail.Tournament.TimeZone</small>
            </aside>
        </section>

        <section class="etd-metrics">
            <article><span>Equipes</span><strong>@Detail.RegistrationSummary.ActiveTeams / @Detail.RegistrationSummary.MaxTeams</strong></article>
            <article><span>Places libres</span><strong>@Math.Max(Detail.RegistrationSummary.MaxTeams - Detail.RegistrationSummary.ActiveTeams, 0)</strong></article>
            <article><span>Inscription</span><strong>@RegistrationWindowLabel</strong></article>
            <article><span>Lots</span><strong>@PrizeLabel(Detail.Tournament)</strong></article>
        </section>

        <section class="etd-registration-panel">
            <div class="etd-panel-head">
                <span>Inscription equipe</span>
                <h2>Tunnel tournoi</h2>
            </div>

            <nav class="etd-stepper" aria-label="Etapes inscription tournoi">
                <button type="button" class="@(RegistrationStep == 1 ? "active" : "") @(IsSelectedTeamRegistered ? "done" : "")" @onclick="() => GoToRegistrationStepAsync(1)">
                    <span>Etape 1</span>
                    <strong>S'inscrire</strong>
                </button>
                <button type="button" class="@(RegistrationStep == 2 ? "active" : "") @(SelectedRosterCount == 11 ? "done" : "")" @onclick="() => GoToRegistrationStepAsync(2)" disabled="@(!IsSelectedTeamRegistered)">
                    <span>Etape 2</span>
                    <strong>Faire l'equipe</strong>
                </button>
                <button type="button" class="@(RegistrationStep == 3 ? "active" : "") @(CanSubmitRoster ? "done" : "")" @onclick="() => GoToRegistrationStepAsync(3)" disabled="@(!IsSelectedTeamRegistered)">
                    <span>Etape 3</span>
                    <strong>Confirmer</strong>
                </button>
            </nav>

            @if (RegistrationStep == 1)
            {
                <article class="etd-register-card etd-step-card">
                    <div class="etd-register-head">
                        <div>
                            <span>Etape 1</span>
                            <strong>S'inscrire au tournoi</strong>
                        </div>
                        <button type="button" class="etd-secondary" @onclick="LoadOwnerContextAsync" disabled="@RosterBusy">Charger mes clubs</button>
                    </div>

                    <div class="etd-tunnel-copy">
                        <p>Le GM inscrit le club, accepte les regles du tournoi et choisit comment l'inscription sera payee. Les matchs devront etre lances a l'heure indiquee; les scores et donnees EA pourront etre controles apres les rencontres.</p>
                        <p>Une fois le club inscrit, tu pourras convoquer 11 joueurs, verifier les restrictions et envoyer des liens aux joueurs qui ne sont pas encore dans l'application.</p>
                    </div>

                    @if (OwnerTeams.Count == 0)
                    {
                        <p class="etd-muted">Aucun club trouve sur ton compte. Associe-toi d'abord a ton club dans Mon compte ou Mon equipe.</p>
                    }
                    else
                    {
                        <label class="etd-field">Club a inscrire
                            <select @bind="SelectedOwnerTeamId" @bind:after="OnOwnerTeamChangedAsync">
                                @foreach (var team in OwnerTeams)
                                {
                                    <option value="@team.TeamId">@team.Name - @team.Role</option>
                                }
                            </select>
                        </label>
                    }

                    <div class="etd-payment-options">
                        <label class="@(SelectedPaymentMode == TournamentPaymentMode.ClubManagerPays ? "selected" : "")">
                            <input type="radio" name="payment-mode" checked="@(SelectedPaymentMode == TournamentPaymentMode.ClubManagerPays)" @onchange="() => ChangePaymentModeAsync(TournamentPaymentMode.ClubManagerPays)" />
                            <span>GM paie pour l'equipe</span>
                            <small>Le manager regle l'inscription du club, puis gere ses joueurs.</small>
                        </label>
                        <label class="@(SelectedPaymentMode == TournamentPaymentMode.IndividualPlayers ? "selected" : "")">
                            <input type="radio" name="payment-mode" checked="@(SelectedPaymentMode == TournamentPaymentMode.IndividualPlayers)" @onchange="() => ChangePaymentModeAsync(TournamentPaymentMode.IndividualPlayers)" />
                            <span>Chaque joueur paie sa place</span>
                            <small>Chaque joueur convoque devra valider sa presence et payer son entree.</small>
                        </label>
                    </div>

                    <label class="etd-rules-accept">
                        <input type="checkbox" @bind="RulesAccepted" @bind:after="async () => await SaveRegistrationDraftAsync()" />
                        <span>J'ai compris les regles: horaires a respecter, effectif conforme, restrictions tournoi et paiement avant validation finale.</span>
                    </label>

                    <div class="etd-rule-grid">
                        <div><span>Prix</span><strong>@Detail.RegistrationSummary.EntryFee @Detail.RegistrationSummary.Currency</strong></div>
                        <div><span>Places</span><strong>@Math.Max(Detail.RegistrationSummary.MaxTeams - Detail.RegistrationSummary.ActiveTeams, 0) libres</strong></div>
                        <div><span>Limite</span><strong>@RegistrationWindowLabel</strong></div>
                        <div><span>Statut</span><strong>@(IsSelectedTeamRegistered ? "Inscrit" : "A inscrire")</strong></div>
                    </div>

                    <div class="etd-action-row">
                        <button type="button" class="etd-primary" @onclick="StartTournamentRegistrationAsync" disabled="@(!CanStartRegistration)">S'inscrire au tournoi</button>
                        @if (IsSelectedTeamRegistered)
                        {
                            <button type="button" class="etd-secondary" @onclick="() => GoToRegistrationStepAsync(2)">Passer a l'equipe</button>
                        }
                    </div>

                    @if (Step1BlockingReasons.Count > 0)
                    {
                        <div class="etd-blocking-reasons">
                            <strong>Pourquoi tu ne peux pas continuer</strong>
                            @foreach (var reason in Step1BlockingReasons)
                            {
                                <span>@reason</span>
                            }
                        </div>
                    }
                </article>
            }

            @if (RegistrationStep == 2)
            {
                <div class="etd-register-grid">
                    <article class="etd-register-card">
                        <div class="etd-register-head">
                            <div>
                                <span>Etape 2</span>
                                <strong>Faire l'equipe</strong>
                            </div>
                            <span class="etd-count-pill">@SelectedRosterCount / 11</span>
                        </div>

                        <label class="etd-field">Formation
                            <select @bind="SelectedFormation" @bind:after="async () => await SaveRegistrationDraftAsync()">
                                <option>4-2-3-1</option>
                                <option>4-3-3</option>
                                <option>3-5-2</option>
                                <option>4-4-2</option>
                            </select>
                        </label>

                        <div class="etd-rule-note">
                            <strong>Restrictions du tournoi</strong>
                            <span>Max general @DefaultMaxHeightCm cm. Exception DC @CenterBackMaxHeightCm cm. Toute alerte devra etre corrigee avant confirmation.</span>
                        </div>

                        <div class="etd-lineup-board">
                            @foreach (var row in LineupRows)
                            {
                                <div class="etd-lineup-row" style="grid-template-columns: repeat(@row.Count, minmax(0, 1fr));">
                                    @foreach (var slot in row)
                                    {
                                        <button type="button" class="etd-lineup-slot @(slot.Player is null ? "empty" : "") @(slot.Player is not null && !IsHeightEligibleForTournament(slot.Player) ? "invalid" : "")" @onclick="() => OpenPositionPicker(slot)">
                                            <span>@slot.Position</span>
                                            <strong>@(slot.Player?.DisplayName ?? "A choisir")</strong>
                                            <small>@(slot.Player is null ? "Slot libre" : $"{slot.Player.HeightLabel} - {slot.Player.OverallLabel}")</small>
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    </article>

                    <article class="etd-register-card">
                        <div class="etd-register-head">
                            <div>
                                <span>Controle</span>
                                <strong>@SelectedOwnerTeamName</strong>
                            </div>
                            <button type="button" class="etd-secondary" @onclick="RefreshSelectedTeamEaRosterAsync" disabled="@(RosterBusy || SelectedOwnerTeamId is null)">Maj effectif EA</button>
                        </div>

                        <div class="etd-rule-grid">
                            <div><span>Selection</span><strong>@SelectedRosterCount / 11</strong></div>
                            <div><span>Restrictions</span><strong>@HeightViolationCount alerte(s)</strong></div>
                            <div><span>App</span><strong>@SelectedAppRosterCount joueur(s)</strong></div>
                            <div><span>A inviter</span><strong>@SelectedInviteRequiredCount lien(s)</strong></div>
                        </div>

                        <div class="etd-action-row">
                            <button type="button" class="etd-secondary" @onclick="() => GoToRegistrationStepAsync(1)">Retour inscription</button>
                            <button type="button" class="etd-primary" @onclick="() => GoToRegistrationStepAsync(3)" disabled="@(SelectedRosterCount != 11)">Continuer vers confirmation</button>
                        </div>

                        @if (Step2BlockingReasons.Count > 0)
                        {
                            <div class="etd-blocking-reasons">
                                <strong>Pourquoi tu ne peux pas continuer</strong>
                                @foreach (var reason in Step2BlockingReasons)
                                {
                                    <span>@reason</span>
                                }
                            </div>
                        }
                    </article>
                </div>

                <article class="etd-roster-card">
                    <div class="etd-register-head">
                        <div>
                            <span>Effectif</span>
                            <strong>@Roster.Count joueur(s)</strong>
                        </div>
                        <span class="etd-count-pill">@SelectedRosterCount / 11</span>
                    </div>

                    @if (RosterBusy)
                    {
                        <p class="etd-muted">Chargement de l'effectif...</p>
                    }
                    else if (Roster.Count == 0)
                    {
                        <p class="etd-muted">Aucun joueur stocke pour ce club. Clique sur Maj effectif EA pour recuperer et sauvegarder le roster.</p>
                    }
                    else
                    {
                        <div class="etd-roster-groups">
                            @foreach (var group in RosterGroups)
                            {
                                <section>
                                    <div class="etd-roster-group-head">
                                        <strong>@group.Label</strong>
                                        <span>@group.Players.Count joueur(s)</span>
                                    </div>
                                    @foreach (var player in group.Players)
                                    {
                                        <article class="etd-roster-player @(player.Selected ? "selected" : "") @(FocusedRosterPlayer == player ? "focused" : "") @(!IsHeightEligibleForTournament(player) && player.Selected ? "invalid" : "")">
                                            <label class="etd-check">
                                                <input type="checkbox" checked="@player.Selected" @onchange="args => TogglePlayerAsync(player, args)" disabled="@(!player.CanBeSelected || (!player.Selected && SelectedRosterCount >= 11))" />
                                                <span></span>
                                            </label>
                                            <div>
                                                <strong>@player.DisplayName</strong>
                                                <small>@player.Gamertag</small>
                                                <div class="etd-player-tags">
                                                    <span class="@(player.HasApp ? "ok" : "warn")">@(player.HasApp ? "Dans l'app" : "A inviter")</span>
                                                    <span>EA @player.EaPositionLabel</span>
                                                    <span class="@(!IsHeightEligibleForTournament(player) ? "danger" : "")">@player.HeightLabel</span>
                                                    <span>@player.OverallLabel</span>
                                                    <span>@player.MatchesLabel</span>
                                                </div>
                                            </div>
                                            <select value="@player.Position" @onchange="args => UpdatePlayerPositionAsync(player, args)">
                                                <option value="">Poste tournoi</option>
                                                <option value="GK">GK</option>
                                                <option value="DC">DC</option>
                                                <option value="DG">DG</option>
                                                <option value="DD">DD</option>
                                                <option value="MDC">MDC</option>
                                                <option value="MC">MC</option>
                                                <option value="MOC">MOC</option>
                                                <option value="AG">AG</option>
                                                <option value="AD">AD</option>
                                                <option value="BU">BU</option>
                                            </select>
                                            @if (!player.HasApp)
                                            {
                                                <button type="button" class="etd-secondary small" @onclick="() => AddInviteLink(player)">Inviter</button>
                                            }
                                        </article>
                                    }
                                </section>
                            }
                        </div>
                    }
                </article>
            }

            @if (RegistrationStep == 3)
            {
                <article class="etd-register-card etd-step-card">
                    <div class="etd-register-head">
                        <div>
                            <span>Etape 3</span>
                            <strong>Confirmation finale</strong>
                        </div>
                        <span class="etd-count-pill @(CanSubmitRoster ? "" : "danger")">@(CanSubmitRoster ? "Pret" : "A corriger")</span>
                    </div>

                    <div class="etd-confirm-grid">
                        <div><span>Club</span><strong>@SelectedOwnerTeamName</strong></div>
                        <div><span>Paiement</span><strong>@PaymentModeLabel(SelectedPaymentMode)</strong></div>
                        <div><span>Joueurs</span><strong>@SelectedRosterCount / 11</strong></div>
                        <div><span>Restrictions</span><strong>@HeightViolationCount alerte(s)</strong></div>
                        <div><span>Postes manquants</span><strong>@MissingTournamentPositionCount</strong></div>
                        <div><span>Invitations</span><strong>@SelectedInviteRequiredCount</strong></div>
                    </div>

                    <section class="etd-selected-summary">
                        <div class="etd-register-head">
                            <div>
                                <span>Recap des 11</span>
                                <strong>Gardien, defense, milieu, attaque</strong>
                            </div>
                            <span class="etd-count-pill">@SelectedRosterCount joueur(s)</span>
                        </div>

                        @foreach (var group in SelectedRosterGroups)
                        {
                            <div class="etd-selected-group">
                                <h3>@group.Label</h3>
                                <div class="etd-selected-list">
                                    @foreach (var player in group.Players)
                                    {
                                        <article class="etd-selected-player @(!IsHeightEligibleForTournament(player) ? "invalid" : "")">
                                            <span>@player.PositionLabel</span>
                                            <strong>@player.DisplayName</strong>
                                            <small>@player.HeightLabel - @player.EaPositionLabel - @(player.HasApp ? "Dans l'app" : "Invitation a envoyer")</small>
                                        </article>
                                    }
                                </div>
                            </div>
                        }
                    </section>

                    <div class="etd-rule-note">
                        <strong>Validation paiement</strong>
                        <span>@PaymentConfirmationText</span>
                    </div>

                    <div class="etd-action-row">
                        <button type="button" class="etd-secondary" @onclick="() => GoToRegistrationStepAsync(2)">Modifier les 11</button>
                        <button type="button" class="etd-primary" @onclick="SubmitRosterAsync" disabled="@(!CanSubmitRoster)">Confirmer l'inscription</button>
                        <button type="button" class="etd-secondary" @onclick="RemindPendingAsync" disabled="@(RosterBusy || SelectedOwnerTeamId is null)">Relancer presences</button>
                    </div>

                    @if (Step3BlockingReasons.Count > 0)
                    {
                        <div class="etd-blocking-reasons">
                            <strong>Pourquoi tu ne peux pas confirmer</strong>
                            @foreach (var reason in Step3BlockingReasons)
                            {
                                <span>@reason</span>
                            }
                        </div>
                    }
                </article>
            }

            @if (!string.IsNullOrWhiteSpace(RosterMessage))
            {
                <p class="etd-register-message">@RosterMessage</p>
            }

            @if (InviteLinks.Count > 0 || TeamInviteLink is not null)
            {
                <article class="etd-roster-card">
                    <div class="etd-register-head">
                        <div>
                            <span>Invitations</span>
                            <strong>Liens pre-remplis</strong>
                        </div>
                        <span class="etd-count-pill">@InviteLinks.Count joueur(s)</span>
                    </div>
                    <div class="etd-invite-list">
                        @if (TeamInviteLink is not null)
                        {
                            <div>
                                <strong>@TeamInviteLink.PlayerName</strong>
                                <input value="@TeamInviteLink.Url" readonly />
                                <button type="button" class="etd-secondary small" @onclick="() => CopyInviteLinkAsync(TeamInviteLink.Url)">Copier</button>
                            </div>
                        }
                        @foreach (var invite in InviteLinks)
                        {
                            <div>
                                <strong>@invite.PlayerName</strong>
                                <input value="@invite.Url" readonly />
                                <button type="button" class="etd-secondary small" @onclick="() => CopyInviteLinkAsync(invite.Url)">Copier</button>
                            </div>
                        }
                    </div>
                </article>
            }

            @if (PositionPickerSlot is not null)
            {
                <div class="etd-modal-backdrop" @onclick="ClosePositionPicker">
                    <section class="etd-player-picker" @onclick:stopPropagation="true">
                        <div class="etd-register-head">
                            <div>
                                <span>Selection poste</span>
                                <strong>@PositionPickerSlot</strong>
                            </div>
                            <button type="button" class="etd-secondary small" @onclick="ClosePositionPicker">Fermer</button>
                        </div>

                        <label class="etd-field">Rechercher un joueur
                            <input value="@PositionPickerSearch" @oninput="args => PositionPickerSearch = args.Value?.ToString() ?? string.Empty" placeholder="Nom, gamertag, poste..." />
                        </label>

                        <div class="etd-picker-list">
                            @foreach (var player in FilteredPickerPlayers)
                            {
                                <button type="button" class="etd-picker-player @(player.Selected ? "selected" : "") @(!IsHeightEligibleForPosition(player, PositionPickerSlot) ? "invalid" : "")" @onclick="() => SelectPlayerForSlotAsync(player)">
                                    <div>
                                        <strong>@player.DisplayName</strong>
                                        <small>@player.Gamertag</small>
                                        <div class="etd-player-tags">
                                            <span class="@(player.HasApp ? "ok" : "warn")">@(player.HasApp ? "Dans l'app" : "A inviter")</span>
                                            <span>EA @player.EaPositionLabel</span>
                                            <span>@player.HeightLabel</span>
                                            <span>@player.OverallLabel</span>
                                        </div>
                                    </div>
                                    <span>@(IsHeightEligibleForPosition(player, PositionPickerSlot) ? "Choisir" : "Restriction")</span>
                                </button>
                            }
                        </div>
                    </section>
                </div>
            }
        </section>

        @if (IsFinished)
        {
            <section class="etd-finished">
                <div>
                    <span class="etd-kicker">Tournoi termine</span>
                    <h2>@WinnerLabel</h2>
                    <p>@FinalLabel</p>
                </div>
                <div class="etd-podium">
                    <span><b>1</b>@WinnerTeamName</span>
                    <span><b>2</b>@FinalistTeamName</span>
                    <span><b>3</b>@ThirdPlaceLabel</span>
                </div>
            </section>
        }

        <section class="etd-content-grid">
            <article class="etd-panel">
                <div class="etd-panel-head">
                    <span>Equipes inscrites</span>
                    <h2>@Detail.RegistrationSummary.Teams.Count equipe(s)</h2>
                </div>
                <div class="etd-team-list">
                    @foreach (var team in Detail.RegistrationSummary.Teams.OrderBy(team => team.CreatedAt))
                    {
                        <div class="etd-team-row">
                            <strong>@team.TeamName</strong>
                            <span>@team.Status</span>
                            <small>@(team.IsPaymentComplete ? "Paiement valide" : "Paiement en attente")</small>
                        </div>
                    }
                </div>
            </article>

            <article class="etd-panel">
                <div class="etd-panel-head">
                    <span>Suivi des matchs</span>
                    <h2>@Detail.Matches.Count match(s)</h2>
                </div>
                <div class="etd-match-list">
                    @foreach (var match in Detail.Matches.OrderBy(match => match.ScheduledAt).ThenBy(match => match.MatchNumber))
                    {
                        <button type="button" class="etd-match-row @(SelectedMatch?.Id == match.Id ? "selected" : "")" @onclick="() => SelectMatchAsync(match)">
                            <span>@StageLabel(match.Stage) @(string.IsNullOrWhiteSpace(match.GroupName) ? string.Empty : match.GroupName)</span>
                            <strong>@TeamName(match.HomeTeamId) @Score(match.HomeScore) - @Score(match.AwayScore) @TeamName(match.AwayTeamId)</strong>
                            <small>@match.Status - @match.ScheduledAt.LocalDateTime.ToString("dd/MM HH:mm")</small>
                        </button>
                    }
                </div>
            </article>
        </section>

        @if (SelectedMatch is not null)
        {
            <section class="etd-match-detail">
                <div class="etd-panel-head">
                    <span>Detail match</span>
                    <h2>@TeamName(SelectedMatch.HomeTeamId) @Score(SelectedMatch.HomeScore) - @Score(SelectedMatch.AwayScore) @TeamName(SelectedMatch.AwayTeamId)</h2>
                </div>

                @if (LoadingMatchDetails)
                {
                    <p class="etd-muted">Chargement des stats EA du match...</p>
                }
                else if (SelectedFriendlyDetails is null)
                {
                    <p class="etd-muted">Aucun detail EA lie a ce match pour le moment. Le score reste visible depuis le tournoi, et les details apparaitront des qu'un match EA sera associe.</p>
                }
                else
                {
                    <div class="etd-score-strip">
                        <span>@SelectedFriendlyDetails.Match.HomeClubName</span>
                        <strong>@SelectedFriendlyDetails.Match.HomeScore - @SelectedFriendlyDetails.Match.AwayScore</strong>
                        <span>@SelectedFriendlyDetails.Match.AwayClubName</span>
                    </div>

                    <div class="etd-player-teams">
                        @foreach (var group in MatchPlayerGroups)
                        {
                            <article class="etd-player-team">
                                <h3>@group.Name</h3>
                                <div class="etd-player-card-grid">
                                    @foreach (var player in group.Players.OrderByDescending(player => player.Rating ?? 0).ThenBy(player => player.PlayerName))
                                    {
                                        <div class="etd-player-card @PositionCss(player.Position)">
                                            <div>
                                                <span>@PositionGroup(player.Position)</span>
                                                <strong>@player.PlayerName</strong>
                                                <small>@PlayerMatchLine(player)</small>
                                                <small>@EaArchetypeMapper.Label(player.ArchetypeId)</small>
                                            </div>
                                            <b>@RatingLabel(player.Rating)</b>
                                        </div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        }
    }
</main>

@code {
    [Parameter] public Guid TournamentId { get; set; }

    private bool Loading { get; set; } = true;
    private bool LoadingMatchDetails { get; set; }
    private string? ErrorMessage { get; set; }
    private Guid? CurrentTeamId { get; set; }
    private TournamentAdminDetailResponse? Detail { get; set; }
    private TournamentMatchResponse? SelectedMatch { get; set; }
    private EaFriendlyMatchDetailsResponse? SelectedFriendlyDetails { get; set; }
    private List<OwnerTeamOption> OwnerTeams { get; } = [];
    private List<RosterPlayerModel> Roster { get; } = [];
    private List<PlayerInviteLink> InviteLinks { get; } = [];
    private HashSet<Guid> LocallyRegisteredTeamIds { get; } = [];
    private IReadOnlyCollection<TournamentRegistrationDraftPlayerRequest> PendingDraftPlayers { get; set; } = [];
    private PlayerInviteLink? TeamInviteLink { get; set; }
    private Guid? SelectedOwnerTeamId { get; set; }
    private RosterPlayerModel? FocusedRosterPlayer { get; set; }
    private string SelectedFormation { get; set; } = "4-2-3-1";
    private int RegistrationStep { get; set; } = 1;
    private TournamentPaymentMode SelectedPaymentMode { get; set; } = TournamentPaymentMode.ClubManagerPays;
    private bool RulesAccepted { get; set; }
    private bool DraftRestored { get; set; }
    private string? PositionPickerSlot { get; set; }
    private string? PositionPickerSlotKey { get; set; }
    private string PositionPickerSearch { get; set; } = string.Empty;
    private bool RosterBusy { get; set; }
    private string? RosterMessage { get; set; }
    private int DefaultMaxHeightCm { get; set; } = 182;
    private int CenterBackMaxHeightCm { get; set; } = 187;

    private string RegistrationWindowLabel => Detail?.Tournament.RegistrationEndsAt is null ? "Ouverte" : $"jusqu'au {Detail.Tournament.RegistrationEndsAt.Value.LocalDateTime:dd/MM HH:mm}";
    private bool IsFinished => Detail?.Tournament.Status == TournamentStatus.Completed || Detail?.Matches.Any(match => match.Stage == TournamentStage.Final && match.WinnerTeamId.HasValue) == true;
    private TournamentMatchResponse? FinalMatch => Detail?.Matches.FirstOrDefault(match => match.Stage == TournamentStage.Final && match.HomeScore.HasValue && match.AwayScore.HasValue);
    private string WinnerTeamName => FinalMatch?.WinnerTeamId is Guid winnerId ? TeamName(winnerId) : "Champion a confirmer";
    private string FinalistTeamName => FinalMatch is null ? "Finaliste a confirmer" : TeamName(FinalMatch.WinnerTeamId == FinalMatch.HomeTeamId ? FinalMatch.AwayTeamId : FinalMatch.HomeTeamId);
    private string ThirdPlaceLabel => Detail?.Matches.FirstOrDefault(match => match.Stage == TournamentStage.ThirdPlace && match.WinnerTeamId.HasValue) is { } third ? TeamName(third.WinnerTeamId!.Value) : "Non renseigne";
    private string WinnerLabel => WinnerTeamName == "Champion a confirmer" ? "Resultat final a confirmer" : $"{WinnerTeamName} remporte le tournoi";
    private string FinalLabel => FinalMatch is null ? "La finale n'est pas encore liee en base." : $"Finale: {TeamName(FinalMatch.HomeTeamId)} {Score(FinalMatch.HomeScore)} - {Score(FinalMatch.AwayScore)} {TeamName(FinalMatch.AwayTeamId)}";
    private string SelectedOwnerTeamName => OwnerTeams.FirstOrDefault(team => team.TeamId == SelectedOwnerTeamId)?.Name ?? "Aucun club";
    private bool IsSelectedTeamRegistered => SelectedOwnerTeamId.HasValue
        && (LocallyRegisteredTeamIds.Contains(SelectedOwnerTeamId.Value) || Detail?.RegistrationSummary.Teams.Any(team => team.TeamId == SelectedOwnerTeamId.Value) == true);
    private bool CanStartRegistration => SelectedOwnerTeamId.HasValue && RulesAccepted && !RosterBusy;
    private int SelectedRosterCount => Roster.Count(player => player.Selected);
    private int SelectedAppRosterCount => Roster.Count(player => player.Selected && player.HasApp);
    private int SelectedInviteRequiredCount => Roster.Count(player => player.Selected && !player.HasApp);
    private int MissingTournamentPositionCount => Roster.Count(player => player.Selected && string.IsNullOrWhiteSpace(player.Position));
    private int HeightViolationCount => Roster.Count(player => player.Selected && !IsHeightEligibleForTournament(player));
    private bool CanSubmitRoster => SelectedOwnerTeamId.HasValue
        && SelectedRosterCount == 11
        && MissingTournamentPositionCount == 0
        && HeightViolationCount == 0
        && SelectedInviteRequiredCount == 0
        && PendingPresenceCount == 0
        && UnavailablePresenceCount == 0
        && !RosterBusy;
    private int MissingPlayerCount => Math.Max(11 - SelectedRosterCount, 0);
    private int PendingPresenceCount => Roster.Count(player => player.Selected && string.Equals(player.Status, TournamentPlayerPresenceStatus.Pending.ToString(), StringComparison.OrdinalIgnoreCase));
    private int UnavailablePresenceCount => Roster.Count(player => player.Selected && string.Equals(player.Status, TournamentPlayerPresenceStatus.Unavailable.ToString(), StringComparison.OrdinalIgnoreCase));
    private int LatePresenceCount => Roster.Count(player => player.Selected && string.Equals(player.Status, TournamentPlayerPresenceStatus.Late.ToString(), StringComparison.OrdinalIgnoreCase));
    private IReadOnlyList<string> Step1BlockingReasons => BuildStep1BlockingReasons();
    private IReadOnlyList<string> Step2BlockingReasons => BuildStep2BlockingReasons();
    private IReadOnlyList<string> Step3BlockingReasons => BuildStep3BlockingReasons();
    private string PaymentConfirmationText => SelectedPaymentMode == TournamentPaymentMode.ClubManagerPays
        ? "Le paiement equipe sera valide cote GM. Pour la V1 web, PayPal reste le flux le plus simple pour encaisser et reverser les lots."
        : "Chaque joueur convoque devra valider sa presence et payer sa place individuellement avant la limite du tournoi.";
    private IReadOnlyList<RosterPlayerModel> FilteredPickerPlayers => Roster
        .Where(player => string.IsNullOrWhiteSpace(PositionPickerSearch)
            || player.DisplayName.Contains(PositionPickerSearch, StringComparison.OrdinalIgnoreCase)
            || player.Gamertag.Contains(PositionPickerSearch, StringComparison.OrdinalIgnoreCase)
            || (player.EaPosition?.Contains(PositionPickerSearch, StringComparison.OrdinalIgnoreCase) ?? false)
            || (player.Position?.Contains(PositionPickerSearch, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(player => IsHeightEligibleForPosition(player, PositionPickerSlot) ? 0 : 1)
        .ThenBy(PositionSort)
        .ThenByDescending(player => player.HasApp)
        .ThenByDescending(player => player.AverageRating ?? 0)
        .ThenBy(player => player.DisplayName)
        .ToArray();
    private IReadOnlyList<RosterPositionGroup> RosterGroups => Roster
        .OrderBy(PositionSort)
        .ThenByDescending(player => player.HasApp)
        .ThenByDescending(player => player.AverageRating ?? 0)
        .ThenBy(player => player.DisplayName)
        .GroupBy(player => PositionGroup(player.EaPosition))
        .Select(group => new RosterPositionGroup(PositionGroupLabel(group.Key), group.ToArray()))
        .ToArray();
    private IReadOnlyList<RosterPositionGroup> SelectedRosterGroups => Roster
        .Where(player => player.Selected)
        .OrderBy(PositionSortFromTournamentPosition)
        .ThenBy(player => player.Position)
        .ThenBy(player => player.DisplayName)
        .GroupBy(player => PositionGroup(player.Position))
        .Select(group => new RosterPositionGroup(PositionGroupLabel(group.Key), group.ToArray()))
        .ToArray();
    private IReadOnlyList<IReadOnlyList<LineupSlotModel>> LineupRows => BuildLineupRows();

    private IReadOnlyCollection<MatchPlayerGroup> MatchPlayerGroups => SelectedFriendlyDetails is null
        ? Array.Empty<MatchPlayerGroup>()
        : new[]
        {
            new MatchPlayerGroup(SelectedFriendlyDetails.Match.HomeClubName ?? "Equipe domicile", SelectedFriendlyDetails.PlayerStats.Where(player => player.EaClubId == SelectedFriendlyDetails.Match.HomeEaClubId).ToArray()),
            new MatchPlayerGroup(SelectedFriendlyDetails.Match.AwayClubName ?? "Equipe exterieure", SelectedFriendlyDetails.PlayerStats.Where(player => player.EaClubId == SelectedFriendlyDetails.Match.AwayEaClubId).ToArray())
        };

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        if (!AuthState.IsAuthenticated)
        {
            Loading = false;
            return;
        }

        try
        {
            var me = await Api.GetMeAsync();
            CurrentTeamId = me.Value?.Memberships.FirstOrDefault(member => member.TeamId.HasValue)?.TeamId;
            var detailResult = await Api.GetTournamentAdminDetailAsync(TournamentId);
            if (!detailResult.Success || detailResult.Value is null)
            {
                ErrorMessage = detailResult.Error ?? "Detail tournoi indisponible.";
                return;
            }

            Detail = detailResult.Value;
            ApplyTournamentRestrictions();
            await LoadOwnerContextAsync();
            SelectedMatch = Detail.Matches.OrderBy(match => match.ScheduledAt).FirstOrDefault(match => match.HomeScore.HasValue || match.AwayScore.HasValue) ?? Detail.Matches.FirstOrDefault();
            if (SelectedMatch is not null)
            {
                await LoadMatchDetailsAsync(SelectedMatch);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task SelectMatchAsync(TournamentMatchResponse match)
    {
        SelectedMatch = match;
        await LoadMatchDetailsAsync(match);
    }

    private async Task GoToRegistrationStepAsync(int step)
    {
        if (step > 1 && !IsSelectedTeamRegistered)
        {
            RosterMessage = "Inscris d'abord le club au tournoi pour debloquer la preparation des 11.";
            RegistrationStep = 1;
            return;
        }

        RegistrationStep = Math.Clamp(step, 1, 3);
        await SaveRegistrationDraftAsync();
    }

    private async Task ChangePaymentModeAsync(TournamentPaymentMode mode)
    {
        SelectedPaymentMode = mode;
        await SaveRegistrationDraftAsync();
    }

    private async Task OnOwnerTeamChangedAsync()
    {
        PendingDraftPlayers = [];
        DraftRestored = false;
        InviteLinks.Clear();
        TeamInviteLink = null;
        await LoadRosterForSelectedTeamAsync();
        await SaveRegistrationDraftAsync(showSavedMessage: true);
    }

    private IReadOnlyList<string> BuildStep1BlockingReasons()
    {
        var reasons = new List<string>();
        if (SelectedOwnerTeamId is null)
        {
            reasons.Add("Aucun club n'est selectionne pour l'inscription.");
        }

        if (!RulesAccepted)
        {
            reasons.Add("Les regles du tournoi doivent etre acceptees.");
        }

        if (RosterBusy)
        {
            reasons.Add("Chargement en cours, attends la fin de la synchronisation.");
        }

        return reasons;
    }

    private IReadOnlyList<string> BuildStep2BlockingReasons()
    {
        var reasons = new List<string>();
        if (!IsSelectedTeamRegistered)
        {
            reasons.Add("Le club doit d'abord etre inscrit au tournoi.");
        }

        if (Roster.Count == 0)
        {
            reasons.Add("L'effectif du club n'est pas encore charge.");
        }

        if (MissingPlayerCount > 0)
        {
            reasons.Add($"Il manque {MissingPlayerCount} joueur(s) pour atteindre les 11 convoques.");
        }

        if (SelectedRosterCount > 11)
        {
            reasons.Add("Il y a plus de 11 joueurs selectionnes.");
        }

        if (MissingTournamentPositionCount > 0)
        {
            reasons.Add($"{MissingTournamentPositionCount} joueur(s) selectionne(s) n'ont pas de poste tournoi.");
        }

        if (HeightViolationCount > 0)
        {
            reasons.Add($"{HeightViolationCount} joueur(s) ne respectent pas les restrictions de taille.");
        }

        return reasons;
    }

    private IReadOnlyList<string> BuildStep3BlockingReasons()
    {
        var reasons = BuildStep2BlockingReasons().ToList();
        if (SelectedInviteRequiredCount > 0)
        {
            reasons.Add($"{SelectedInviteRequiredCount} joueur(s) selectionne(s) ne sont pas encore dans l'application. Envoie les liens d'invitation.");
        }

        if (PendingPresenceCount > 0)
        {
            reasons.Add($"{PendingPresenceCount} joueur(s) doivent encore valider leur presence.");
        }

        if (UnavailablePresenceCount > 0)
        {
            reasons.Add($"{UnavailablePresenceCount} joueur(s) ont indique qu'ils ne sont pas disponibles.");
        }

        if (LatePresenceCount > 0)
        {
            reasons.Add($"{LatePresenceCount} joueur(s) ont indique un retard. Le GM doit verifier si c'est acceptable.");
        }

        return reasons;
    }

    private async Task StartTournamentRegistrationAsync()
    {
        if (!CanStartRegistration || SelectedOwnerTeamId is null)
        {
            return;
        }

        RosterBusy = true;
        RosterMessage = null;

        try
        {
            var registration = await Api.RegisterTeamForTournamentAsync(TournamentId, new RegisterTeamForTournamentRequest(SelectedOwnerTeamId.Value, SelectedPaymentMode));
            if (!registration.Success && !IsAlreadyRegistered(registration.Error))
            {
                RosterMessage = registration.Error ?? "Impossible d'inscrire ce club au tournoi.";
                return;
            }

            LocallyRegisteredTeamIds.Add(SelectedOwnerTeamId.Value);
            RosterMessage = registration.Success
                ? $"Club inscrit provisoirement. Mode paiement: {PaymentModeLabel(SelectedPaymentMode)}."
                : "Club deja inscrit. Tu peux preparer les 11.";
            RegistrationStep = 2;
            await LoadRosterForSelectedTeamAsync(refreshDraft: false);
            await SaveRegistrationDraftAsync();
        }
        finally
        {
            RosterBusy = false;
        }
    }

    private void OpenPositionPicker(LineupSlotModel slot)
    {
        PositionPickerSlot = slot.Position;
        PositionPickerSlotKey = slot.Key;
        PositionPickerSearch = string.Empty;
    }

    private void ClosePositionPicker()
    {
        PositionPickerSlot = null;
        PositionPickerSlotKey = null;
        PositionPickerSearch = string.Empty;
    }

    private async Task SelectPlayerForSlotAsync(RosterPlayerModel player)
    {
        if (PositionPickerSlot is null || PositionPickerSlotKey is null)
        {
            return;
        }

        var currentSlotPlayer = Roster.FirstOrDefault(item => item.Selected && item.AssignedSlotKey == PositionPickerSlotKey);
        if (currentSlotPlayer is not null && currentSlotPlayer != player)
        {
            currentSlotPlayer.Selected = false;
            currentSlotPlayer.Position = string.Empty;
            currentSlotPlayer.AssignedSlotKey = null;
        }

        if (!player.Selected && SelectedRosterCount >= 11)
        {
            RosterMessage = "Tu as deja 11 joueurs. Retire un joueur avant d'en ajouter un autre.";
            return;
        }

        player.Selected = true;
        player.Position = PositionPickerSlot;
        player.AssignedSlotKey = PositionPickerSlotKey;
        FocusedRosterPlayer = player;
        ClosePositionPicker();
        await SaveRegistrationDraftAsync();
    }

    private async Task LoadOwnerContextAsync()
    {
        OwnerTeams.Clear();
        Roster.Clear();
        InviteLinks.Clear();
        TeamInviteLink = null;
        RosterMessage = null;

        var me = await Api.GetMeAsync();
        if (me.Value is null)
        {
            RosterMessage = me.Error ?? "Impossible de charger ton compte.";
            return;
        }

        foreach (var membership in me.Value.Memberships.Where(member => member.TeamId.HasValue))
        {
            OwnerTeams.Add(new OwnerTeamOption(membership.TeamId!.Value, membership.TeamName ?? membership.TeamShortName ?? membership.DisplayName, membership.Role));
        }

        if (OwnerTeams.Count == 0)
        {
            SelectedOwnerTeamId = null;
            return;
        }

        var draftResult = await Api.GetTournamentRegistrationDraftAsync(TournamentId);
        if (draftResult.Value is not null && OwnerTeams.Any(team => team.TeamId == draftResult.Value.TeamId))
        {
            SelectedOwnerTeamId = draftResult.Value.TeamId;
            RegistrationStep = Math.Clamp(draftResult.Value.Step, 1, 3);
            SelectedPaymentMode = draftResult.Value.PaymentMode;
            RulesAccepted = draftResult.Value.RulesAccepted;
            SelectedFormation = string.IsNullOrWhiteSpace(draftResult.Value.Formation) ? SelectedFormation : draftResult.Value.Formation;
            PendingDraftPlayers = draftResult.Value.SelectedPlayers;
            DraftRestored = true;
        }

        if (SelectedOwnerTeamId is null || OwnerTeams.All(team => team.TeamId != SelectedOwnerTeamId.Value))
        {
            SelectedOwnerTeamId = OwnerTeams[0].TeamId;
        }

        await LoadRosterForSelectedTeamAsync();
    }

    private async Task LoadRosterForSelectedTeamAsync(bool refreshDraft = true)
    {
        if (SelectedOwnerTeamId is null)
        {
            return;
        }

        RosterBusy = true;
        RosterMessage = null;
        Roster.Clear();
        InviteLinks.Clear();
        TeamInviteLink = null;

        try
        {
            if (refreshDraft)
            {
                var draftResult = await Api.GetTournamentRegistrationDraftAsync(TournamentId, SelectedOwnerTeamId.Value);
                if (draftResult.Value is not null)
                {
                    RegistrationStep = Math.Clamp(draftResult.Value.Step, 1, 3);
                    SelectedPaymentMode = draftResult.Value.PaymentMode;
                    RulesAccepted = draftResult.Value.RulesAccepted;
                    SelectedFormation = string.IsNullOrWhiteSpace(draftResult.Value.Formation) ? SelectedFormation : draftResult.Value.Formation;
                    PendingDraftPlayers = draftResult.Value.SelectedPlayers;
                    DraftRestored = true;
                }
                else
                {
                    PendingDraftPlayers = [];
                    DraftRestored = false;
                }
            }

            var membersResult = await Api.GetTeamMembersAsync(SelectedOwnerTeamId.Value);
            var profilesResult = await Api.GetTeamEaPlayersAsync(SelectedOwnerTeamId.Value);
            var participantsResult = await Api.GetTournamentParticipantsAsync(TournamentId, SelectedOwnerTeamId.Value);

            var members = membersResult.Value ?? [];
            var participants = participantsResult.Value ?? [];

            if (profilesResult.Value is not null)
            {
                foreach (var profile in profilesResult.Value)
                {
                    var member = FindMatchingAppMember(profile, members);
                    var participant = member is null ? null : participants.FirstOrDefault(item => item.UserId == member.UserId);
                    Roster.Add(RosterPlayerModel.FromEaProfile(profile, member, participant));
                }
            }

            foreach (var member in members.Where(member => Roster.All(player => player.UserId != member.UserId)))
            {
                var participant = participants.FirstOrDefault(item => item.UserId == member.UserId);
                Roster.Add(RosterPlayerModel.FromAppMember(member, participant));
            }

            ApplyDraftToRoster();
            FocusedRosterPlayer = Roster.FirstOrDefault();
            RosterMessage = Roster.Count == 0
                ? "Aucun joueur en base. Lance une mise a jour EA pour recuperer l'effectif."
                : DraftRestored
                    ? $"Brouillon restaure: etape {RegistrationStep}, {SelectedRosterCount} joueur(s) selectionne(s)."
                    : $"Effectif charge: {Roster.Count} joueur(s), {Roster.Count(player => player.HasApp)} dans l'app.";
        }
        finally
        {
            RosterBusy = false;
        }
    }

    private async Task RefreshSelectedTeamEaRosterAsync()
    {
        if (SelectedOwnerTeamId is null)
        {
            return;
        }

        RosterBusy = true;
        var sync = await Api.SyncTeamEaAsync(SelectedOwnerTeamId.Value, forceRefresh: true);
        RosterMessage = sync.Success ? "Effectif EA mis a jour et sauvegarde en base." : sync.Error;
        RosterBusy = false;
        await LoadRosterForSelectedTeamAsync();
    }

    private async Task SaveRegistrationDraftAsync(bool showSavedMessage = false)
    {
        if (SelectedOwnerTeamId is null)
        {
            return;
        }

        var selectedPlayers = Roster
            .Where(player => player.Selected)
            .Take(11)
            .Select(player => new TournamentRegistrationDraftPlayerRequest(
                player.HasApp && player.UserId != Guid.Empty ? player.UserId : null,
                player.EaPlayerId,
                player.DisplayName,
                player.Position,
                player.AssignedSlotKey))
            .ToArray();

        var result = await Api.SaveTournamentRegistrationDraftAsync(
            TournamentId,
            new SaveTournamentRegistrationDraftRequest(
                SelectedOwnerTeamId.Value,
                RegistrationStep,
                SelectedPaymentMode,
                RulesAccepted,
                SelectedFormation,
                selectedPlayers));

        if (result.Success && showSavedMessage)
        {
            RosterMessage = "Brouillon sauvegarde. Tu peux quitter et revenir sans perdre cette equipe.";
        }
        else if (!result.Success && !string.IsNullOrWhiteSpace(result.Error))
        {
            RosterMessage = result.Error;
        }
    }

    private void ApplyDraftToRoster()
    {
        if (PendingDraftPlayers.Count == 0)
        {
            return;
        }

        foreach (var player in Roster)
        {
            player.Selected = false;
            player.AssignedSlotKey = null;
            if (!IsAlreadyParticipant(player))
            {
                player.Position = string.Empty;
            }
        }

        foreach (var draftPlayer in PendingDraftPlayers.Take(11))
        {
            var player = Roster.FirstOrDefault(item =>
                (draftPlayer.UserId.HasValue && item.UserId == draftPlayer.UserId.Value) ||
                SamePlayer(item.EaPlayerId, draftPlayer.EaPlayerId) ||
                SamePlayer(item.DisplayName, draftPlayer.DisplayName) ||
                SamePlayer(item.Gamertag, draftPlayer.DisplayName));

            if (player is null)
            {
                continue;
            }

            player.Selected = true;
            player.Position = draftPlayer.Position;
            player.AssignedSlotKey = draftPlayer.AssignedSlotKey;
        }
    }

    private async Task TogglePlayerAsync(RosterPlayerModel player, ChangeEventArgs args)
    {
        player.Selected = args.Value is bool selected && selected && player.CanBeSelected;
        if (!player.Selected)
        {
            player.AssignedSlotKey = null;
        }

        if (player.Selected && string.IsNullOrWhiteSpace(player.Position))
        {
            player.Position = SuggestTournamentPosition(player.EaPosition);
        }

        FocusedRosterPlayer = player;
        await SaveRegistrationDraftAsync();
    }

    private async Task UpdatePlayerPositionAsync(RosterPlayerModel player, ChangeEventArgs args)
    {
        player.Position = args.Value?.ToString() ?? string.Empty;
        player.AssignedSlotKey = null;
        FocusedRosterPlayer = player;
        await SaveRegistrationDraftAsync();
    }

    private async Task SubmitRosterAsync()
    {
        if (!CanSubmitRoster || SelectedOwnerTeamId is null)
        {
            return;
        }

        RosterBusy = true;
        InviteLinks.Clear();
        TeamInviteLink = null;

        try
        {
            var registration = await Api.RegisterTeamForTournamentAsync(TournamentId, new RegisterTeamForTournamentRequest(SelectedOwnerTeamId.Value, SelectedPaymentMode));
            if (!registration.Success && !IsAlreadyRegistered(registration.Error))
            {
                RosterMessage = registration.Error;
                return;
            }

            LocallyRegisteredTeamIds.Add(SelectedOwnerTeamId.Value);

            foreach (var player in Roster.Where(player => player.Selected).Take(11))
            {
                if (!player.HasApp)
                {
                    AddInviteLink(player);
                    continue;
                }

                var participant = await Api.AddTournamentParticipantAsync(TournamentId, SelectedOwnerTeamId.Value, new AddTournamentParticipantRequest(player.UserId, player.Position));
                if (!participant.Success && !IsAlreadyRegistered(participant.Error))
                {
                    RosterMessage = participant.Error;
                    return;
                }
            }

            TeamInviteLink = InviteLinks.Count > 0 ? BuildTeamInviteLink() : null;
            RosterMessage = InviteLinks.Count > 0
                ? $"Equipe inscrite provisoirement: {SelectedAppRosterCount} joueur(s) app ajoutes, {InviteLinks.Count} invitation(s) a envoyer."
                : "Equipe inscrite et 11 joueurs convoques. Les joueurs doivent valider leur presence.";
            RegistrationStep = 3;
        }
        finally
        {
            RosterBusy = false;
        }
    }

    private async Task RemindPendingAsync()
    {
        if (SelectedOwnerTeamId is null)
        {
            return;
        }

        var result = await Api.RemindPendingTournamentParticipantsAsync(TournamentId, SelectedOwnerTeamId.Value);
        RosterMessage = result.Value is not null
            ? $"Relance envoyee: {result.Value.PendingPlayers} joueur(s) en attente."
            : result.Error ?? "Relance envoyee aux joueurs en attente.";
    }

    private void AddInviteLink(RosterPlayerModel player)
    {
        if (InviteLinks.Any(invite => invite.EaPlayerId == player.EaPlayerId))
        {
            return;
        }

        InviteLinks.Add(BuildInviteLink(player));
    }

    private async Task CopyInviteLinkAsync(string url)
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
            RosterMessage = "Lien copie.";
        }
        catch
        {
            RosterMessage = "Copie automatique indisponible. Le lien reste visible dans le champ.";
        }
    }

    private void FocusRosterPlayer(RosterPlayerModel? player)
    {
        if (player is not null)
        {
            FocusedRosterPlayer = player;
        }
    }

    private async Task LoadMatchDetailsAsync(TournamentMatchResponse match)
    {
        SelectedFriendlyDetails = null;
        LoadingMatchDetails = true;
        try
        {
            var candidates = new[] { CurrentTeamId, match.HomeTeamId, match.AwayTeamId }
                .Where(id => id.HasValue)
                .Select(id => id!.Value)
                .Distinct()
                .ToArray();

            foreach (var teamId in candidates)
            {
                var friendlies = await Api.GetTeamEaFriendliesAsync(teamId, 4, match.Id);
                var friendly = friendlies.Value?.FirstOrDefault();
                if (friendly is null)
                {
                    continue;
                }

                var details = await Api.GetTeamEaFriendlyDetailsAsync(teamId, friendly.EaMatchId);
                if (details.Value is not null)
                {
                    SelectedFriendlyDetails = details.Value;
                    return;
                }
            }
        }
        finally
        {
            LoadingMatchDetails = false;
        }
    }

    private string TeamName(Guid teamId)
    {
        return Detail?.RegistrationSummary.Teams.FirstOrDefault(team => team.TeamId == teamId)?.TeamName ?? "Equipe";
    }

    private void ApplyTournamentRestrictions()
    {
        var json = Detail?.Tournament.PlayerRestrictionsJson;
        if (string.IsNullOrWhiteSpace(json))
        {
            return;
        }

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(json);
            var root = document.RootElement;
            DefaultMaxHeightCm = ReadRestrictionInt(root, "defaultMaxHeightCm", DefaultMaxHeightCm);
            DefaultMaxHeightCm = ReadRestrictionInt(root, "maxHeightCm", DefaultMaxHeightCm);
            CenterBackMaxHeightCm = ReadRestrictionInt(root, "centerBackMaxHeightCm", CenterBackMaxHeightCm);
            CenterBackMaxHeightCm = ReadRestrictionInt(root, "dcMaxHeightCm", CenterBackMaxHeightCm);
        }
        catch
        {
            RosterMessage = "Restrictions tournoi non lisibles, valeurs par defaut appliquees.";
        }
    }

    private bool IsHeightEligibleForTournament(RosterPlayerModel player)
    {
        if (!player.Height.HasValue)
        {
            return true;
        }

        return player.Height.Value <= GetMaxHeightForPosition(string.IsNullOrWhiteSpace(player.Position) ? player.EaPosition : player.Position);
    }

    private bool IsHeightEligibleForPosition(RosterPlayerModel player, string? position)
    {
        if (!player.Height.HasValue || string.IsNullOrWhiteSpace(position))
        {
            return true;
        }

        return player.Height.Value <= GetMaxHeightForPosition(position);
    }

    private int GetMaxHeightForPosition(string? position)
    {
        return string.Equals(position, "DC", StringComparison.OrdinalIgnoreCase)
            ? CenterBackMaxHeightCm
            : DefaultMaxHeightCm;
    }

    private IReadOnlyList<IReadOnlyList<LineupSlotModel>> BuildLineupRows()
    {
        var usedPlayerKeys = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var slotCounters = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
        return GetFormationRows(SelectedFormation)
            .Select(row => row.Select(position =>
            {
                slotCounters[position] = slotCounters.TryGetValue(position, out var count) ? count + 1 : 1;
                var key = $"{position}-{slotCounters[position]}";
                return new LineupSlotModel(key, position, GetLineupPlayer(key, position, usedPlayerKeys));
            }).ToArray())
            .ToArray();
    }

    private RosterPlayerModel? GetLineupPlayer(string slotKey, string slot, HashSet<string> usedPlayerKeys)
    {
        var selected = Roster.Where(player => player.Selected).ToList();
        var assigned = selected.FirstOrDefault(player => player.AssignedSlotKey == slotKey);
        if (assigned is not null)
        {
            usedPlayerKeys.Add(assigned.RosterKey);
            return assigned;
        }

        var direct = selected.FirstOrDefault(player => string.IsNullOrWhiteSpace(player.AssignedSlotKey) && !usedPlayerKeys.Contains(player.RosterKey) && string.Equals(player.Position, slot, StringComparison.OrdinalIgnoreCase));
        if (direct is not null)
        {
            usedPlayerKeys.Add(direct.RosterKey);
            return direct;
        }

        var fallback = slot switch
        {
            "DC" => selected.FirstOrDefault(player => string.IsNullOrWhiteSpace(player.AssignedSlotKey) && !usedPlayerKeys.Contains(player.RosterKey) && player.Position is "DG" or "DD" or "MDC"),
            "DG" or "DD" => selected.FirstOrDefault(player => string.IsNullOrWhiteSpace(player.AssignedSlotKey) && !usedPlayerKeys.Contains(player.RosterKey) && player.Position is "DC" or "MDC"),
            "MDC" => selected.FirstOrDefault(player => string.IsNullOrWhiteSpace(player.AssignedSlotKey) && !usedPlayerKeys.Contains(player.RosterKey) && player.Position is "MC" or "DC"),
            "MC" => selected.FirstOrDefault(player => string.IsNullOrWhiteSpace(player.AssignedSlotKey) && !usedPlayerKeys.Contains(player.RosterKey) && player.Position is "MDC" or "MOC"),
            "MOC" => selected.FirstOrDefault(player => string.IsNullOrWhiteSpace(player.AssignedSlotKey) && !usedPlayerKeys.Contains(player.RosterKey) && player.Position is "MC" or "AG" or "AD"),
            "AG" or "AD" => selected.FirstOrDefault(player => string.IsNullOrWhiteSpace(player.AssignedSlotKey) && !usedPlayerKeys.Contains(player.RosterKey) && player.Position is "MOC" or "BU"),
            "BU" => selected.FirstOrDefault(player => string.IsNullOrWhiteSpace(player.AssignedSlotKey) && !usedPlayerKeys.Contains(player.RosterKey) && player.Position is "AG" or "AD" or "MOC"),
            _ => null
        };

        if (fallback is not null)
        {
            usedPlayerKeys.Add(fallback.RosterKey);
        }

        return fallback;
    }

