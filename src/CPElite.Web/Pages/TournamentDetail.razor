            "DEF" => $"{player.TacklesMade ?? 0} tacles - {Percent(player.TackleSuccessRate)} tacles - clean sheet {player.CleanSheetsDef ?? 0}",
            "MIL" => $"{Percent(player.PassSuccessRate)} passes - {player.PassesMade ?? 0} passes reussies - {player.TacklesMade ?? 0} tacles - {player.Assists ?? 0} assist",
            "ATT" => $"{player.Goals ?? 0} buts - {player.Assists ?? 0} assist - {player.Shots ?? 0} tirs",
            _ => $"{player.Goals ?? 0} buts - {player.Assists ?? 0} assists - {Percent(player.PassSuccessRate)} passes"
        };
    }

