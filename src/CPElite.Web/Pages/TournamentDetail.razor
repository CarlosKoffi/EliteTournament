    private static TeamMemberResponse? FindMatchingAppMember(EaPlayerProfileSnapshotResponse profile, IReadOnlyCollection<TeamMemberResponse> members)
    {
        return members.FirstOrDefault(member =>
            SamePlayer(member.Gamertag, profile.EaPlayerId) ||
            SamePlayer(member.Gamertag, profile.PlayerName) ||
            SamePlayer(member.DisplayName, profile.PlayerName) ||
            SamePlayer(member.DisplayName, profile.ProName));
    }

    private static bool SamePlayer(string? left, string? right)
    {
        return !string.IsNullOrWhiteSpace(left)
            && !string.IsNullOrWhiteSpace(right)
            && string.Equals(NormalizePlayerKey(left), NormalizePlayerKey(right), StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizePlayerKey(string value)
    {
        return new string(value.Where(char.IsLetterOrDigit).Select(char.ToLowerInvariant).ToArray());
    }

    private static bool IsAlreadyRegistered(string? error)
    {
        return error?.Contains("already", StringComparison.OrdinalIgnoreCase) == true
            || error?.Contains("duplicate", StringComparison.OrdinalIgnoreCase) == true
            || error?.Contains("existe", StringComparison.OrdinalIgnoreCase) == true
            || error?.Contains("deja", StringComparison.OrdinalIgnoreCase) == true;
    }

    private static bool IsAlreadyParticipant(RosterPlayerModel player)
    {
        return !string.Equals(player.Status, "Disponible", StringComparison.OrdinalIgnoreCase);
    }

    private static int ReadRestrictionInt(System.Text.Json.JsonElement root, string propertyName, int fallback)
    {
        if (root.TryGetProperty(propertyName, out var value) && value.TryGetInt32(out var number))
        {
            return number;
        }

        return fallback;
    }

