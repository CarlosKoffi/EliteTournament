@page "/tournaments/{TournamentId:guid}"
@inject ApiClient Api
@inject AuthState AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Elite Tournament - Detail tournoi</PageTitle>
<HeadContent>
    <link rel="stylesheet" href="css/elite-tournament.tournament-detail.css?v=20260724-2" />
</HeadContent>

<main class="et-detail-page">
    @if (Loading)
    {
        <section class="et-detail-empty">
            <strong>Chargement du tournoi</strong>
            <p>On recupere les equipes inscrites, les matchs et les donnees EA liees.</p>
        </section>
    }
    else if (!AuthState.IsAuthenticated)
    {
        <section class="et-detail-empty">
            <strong>Connexion requise</strong>
            <p>Les informations detaillees du tournoi sont disponibles apres connexion.</p>
            <button type="button" class="etd-primary" @onclick='() => Navigation.NavigateTo("account")'>Se connecter</button>
        </section>
    }
    else if (Detail is null)
    {
        <section class="et-detail-empty">
            <strong>Tournoi introuvable</strong>
            <p>@(ErrorMessage ?? "Impossible de charger ce tournoi depuis la base.")</p>
            <button type="button" class="etd-secondary" @onclick='() => Navigation.NavigateTo("tournaments")'>Retour tournois</button>
        </section>
    }
    else
    {
        <section class="et-detail-hero" style="@BuildBannerStyle(Detail.Tournament.BannerUrl)">
            <button type="button" class="etd-back" @onclick='() => Navigation.NavigateTo("tournaments")'>Retour</button>
            <div>
                <span class="etd-kicker">@TournamentStatusLabel(Detail.Tournament)</span>
                <h1>@Detail.Tournament.Name</h1>
                <p>@TournamentIntro(Detail.Tournament)</p>
            </div>
            <aside class="etd-hero-score">
                <span>@(Detail.Tournament.IsCashPrize ? "Goodies" : "Tournoi")</span>
                <strong>@FormatDate(Detail.Tournament.StartsAt)</strong>
                <small>@FormatTime(Detail.Tournament.StartsAt) @Detail.Tournament.TimeZone</small>
            </aside>
        </section>

        <section class="etd-metrics">
            <article><span>Equipes</span><strong>@Detail.RegistrationSummary.ActiveTeams / @Detail.RegistrationSummary.MaxTeams</strong></article>
            <article><span>Places libres</span><strong>@Math.Max(Detail.RegistrationSummary.MaxTeams - Detail.RegistrationSummary.ActiveTeams, 0)</strong></article>
            <article><span>Inscription</span><strong>@RegistrationWindowLabel</strong></article>
            <article><span>Lots</span><strong>@PrizeLabel(Detail.Tournament)</strong></article>
        </section>

        <section class="etd-registration-panel">
            <div class="etd-panel-head">
                <span>Inscription equipe</span>
                <h2>Preparer les 11 convoques</h2>
            </div>

            <div class="etd-register-grid">
                <article class="etd-register-card">
                    <div class="etd-register-head">
                        <div>
                            <span>Club</span>
                            <strong>@SelectedOwnerTeamName</strong>
                        </div>
                        <button type="button" class="etd-secondary" @onclick="LoadOwnerContextAsync" disabled="@RosterBusy">Charger mes clubs</button>
                    </div>

                    @if (OwnerTeams.Count == 0)
                    {
                        <p class="etd-muted">Aucun club GM/Manager trouve sur ton compte. Va dans Mon compte ou Mon equipe pour associer ton joueur au club.</p>
                    }
                    else
                    {
                        <label class="etd-field">Club a inscrire
                            <select @bind="SelectedOwnerTeamId" @bind:after="LoadRosterForSelectedTeamAsync">
                                @foreach (var team in OwnerTeams)
                                {
                                    <option value="@team.TeamId">@team.Name - @team.Role</option>
                                }
                            </select>
                        </label>
                    }

                    <div class="etd-rule-grid">
                        <div><span>Selection</span><strong>@SelectedRosterCount / 11</strong></div>
                        <div><span>Restrictions</span><strong>@HeightViolationCount alerte(s)</strong></div>
                        <div><span>App</span><strong>@SelectedAppRosterCount joueur(s)</strong></div>
                        <div><span>Invitations</span><strong>@SelectedInviteRequiredCount lien(s)</strong></div>
                    </div>

                    <div class="etd-rule-note">
                        <strong>Regles taille</strong>
                        <span>Max general @DefaultMaxHeightCm cm. Exception DC @CenterBackMaxHeightCm cm. Les restrictions admin bloquent la soumission si elles ne sont pas respectees.</span>
                    </div>

                    <label class="etd-field">Formation
                        <select @bind="SelectedFormation">
                            <option>4-2-3-1</option>
                            <option>4-3-3</option>
                            <option>3-5-2</option>
                            <option>4-4-2</option>
                        </select>
                    </label>

                    <div class="etd-action-row">
                        <button type="button" class="etd-primary" @onclick="SubmitRosterAsync" disabled="@(!CanSubmitRoster)">Soumettre les 11</button>
                        <button type="button" class="etd-secondary" @onclick="RefreshSelectedTeamEaRosterAsync" disabled="@(RosterBusy || SelectedOwnerTeamId is null)">Maj effectif EA</button>
                        <button type="button" class="etd-secondary" @onclick="RemindPendingAsync" disabled="@(RosterBusy || SelectedOwnerTeamId is null)">Relancer</button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(RosterMessage))
                    {
                        <p class="etd-register-message">@RosterMessage</p>
                    }
                </article>

                <article class="etd-register-card">
                    <div class="etd-register-head">
                        <div>
                            <span>Compo</span>
                            <strong>@SelectedFormation</strong>
                        </div>
                        <span class="etd-count-pill @(HeightViolationCount > 0 ? "danger" : "")">@HeightViolationCount alerte(s)</span>
                    </div>
                    <div class="etd-lineup-board">
                        @foreach (var row in LineupRows)
                        {
                            <div class="etd-lineup-row" style="grid-template-columns: repeat(@row.Count, minmax(0, 1fr));">
                                @foreach (var slot in row)
                                {
                                    <button type="button" class="etd-lineup-slot @(slot.Player is null ? "empty" : "") @(slot.Player is not null && !IsHeightEligibleForTournament(slot.Player) ? "invalid" : "")" @onclick="() => FocusRosterPlayer(slot.Player)">
                                        <span>@slot.Position</span>
                                        <strong>@(slot.Player?.DisplayName ?? "A choisir")</strong>
                                        <small>@(slot.Player is null ? "Slot libre" : $"{slot.Player.HeightLabel} - {slot.Player.OverallLabel}")</small>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </article>
            </div>

            <article class="etd-roster-card">
                <div class="etd-register-head">
                    <div>
                        <span>Effectif</span>
                        <strong>@Roster.Count joueur(s)</strong>
                    </div>
                    <span class="etd-count-pill">@SelectedRosterCount / 11</span>
                </div>

                @if (RosterBusy)
                {
                    <p class="etd-muted">Chargement de l'effectif...</p>
                }
                else if (Roster.Count == 0)
                {
                    <p class="etd-muted">Aucun joueur stocke pour ce club. Lance une mise a jour EA pour recuperer et sauvegarder le roster.</p>
                }
                else
                {
                    <div class="etd-roster-groups">
                        @foreach (var group in RosterGroups)
                        {
                            <section>
                                <div class="etd-roster-group-head">
                                    <strong>@group.Label</strong>
                                    <span>@group.Players.Count joueur(s)</span>
                                </div>
                                @foreach (var player in group.Players)
                                {
                                    <article class="etd-roster-player @(player.Selected ? "selected" : "") @(FocusedRosterPlayer == player ? "focused" : "") @(!IsHeightEligibleForTournament(player) && player.Selected ? "invalid" : "")">
                                        <label class="etd-check">
                                            <input type="checkbox" checked="@player.Selected" @onchange="args => TogglePlayerAsync(player, args)" disabled="@(!player.CanBeSelected || (!player.Selected && SelectedRosterCount >= 11))" />
                                            <span></span>
                                        </label>
                                        <div>
                                            <strong>@player.DisplayName</strong>
                                            <small>@player.Gamertag</small>
                                            <div class="etd-player-tags">
                                                <span class="@(player.HasApp ? "ok" : "warn")">@(player.HasApp ? "Dans l'app" : "A inviter")</span>
                                                <span>EA @player.EaPositionLabel</span>
                                                <span class="@(!IsHeightEligibleForTournament(player) ? "danger" : "")">@player.HeightLabel</span>
                                                <span>@player.OverallLabel</span>
                                                <span>@player.MatchesLabel</span>
                                            </div>
                                        </div>
                                        <select value="@player.Position" @onchange="args => UpdatePlayerPositionAsync(player, args)">
                                            <option value="">Poste tournoi</option>
                                            <option value="GK">GK</option>
                                            <option value="DC">DC</option>
                                            <option value="DG">DG</option>
                                            <option value="DD">DD</option>
                                            <option value="MDC">MDC</option>
                                            <option value="MC">MC</option>
                                            <option value="MOC">MOC</option>
                                            <option value="AG">AG</option>
                                            <option value="AD">AD</option>
                                            <option value="BU">BU</option>
                                        </select>
                                        @if (!player.HasApp)
                                        {
                                            <button type="button" class="etd-secondary small" @onclick="() => AddInviteLink(player)">Inviter</button>
                                        }
                                    </article>
                                }
                            </section>
                        }
                    </div>
                }
            </article>

            @if (InviteLinks.Count > 0 || TeamInviteLink is not null)
            {
                <article class="etd-roster-card">
                    <div class="etd-register-head">
                        <div>
                            <span>Invitations</span>
                            <strong>Liens pre-remplis</strong>
                        </div>
                        <span class="etd-count-pill">@InviteLinks.Count joueur(s)</span>
                    </div>
                    <div class="etd-invite-list">
                        @if (TeamInviteLink is not null)
                        {
                            <div>
                                <strong>@TeamInviteLink.PlayerName</strong>
                                <input value="@TeamInviteLink.Url" readonly />
                                <button type="button" class="etd-secondary small" @onclick="() => CopyInviteLinkAsync(TeamInviteLink.Url)">Copier</button>
                            </div>
                        }
                        @foreach (var invite in InviteLinks)
                        {
                            <div>
                                <strong>@invite.PlayerName</strong>
                                <input value="@invite.Url" readonly />
                                <button type="button" class="etd-secondary small" @onclick="() => CopyInviteLinkAsync(invite.Url)">Copier</button>
                            </div>
                        }
                    </div>
                </article>
            }
        </section>

        @if (IsFinished)
        {
            <section class="etd-finished">
                <div>
                    <span class="etd-kicker">Tournoi termine</span>
                    <h2>@WinnerLabel</h2>
                    <p>@FinalLabel</p>
                </div>
                <div class="etd-podium">
                    <span><b>1</b>@WinnerTeamName</span>
                    <span><b>2</b>@FinalistTeamName</span>
                    <span><b>3</b>@ThirdPlaceLabel</span>
                </div>
            </section>
        }

        <section class="etd-content-grid">
            <article class="etd-panel">
                <div class="etd-panel-head">
                    <span>Equipes inscrites</span>
                    <h2>@Detail.RegistrationSummary.Teams.Count equipe(s)</h2>
                </div>
                <div class="etd-team-list">
                    @foreach (var team in Detail.RegistrationSummary.Teams.OrderBy(team => team.CreatedAt))
                    {
                        <div class="etd-team-row">
                            <strong>@team.TeamName</strong>
                            <span>@team.Status</span>
                            <small>@(team.IsPaymentComplete ? "Paiement valide" : "Paiement en attente")</small>
                        </div>
                    }
                </div>
            </article>

            <article class="etd-panel">
                <div class="etd-panel-head">
                    <span>Suivi des matchs</span>
                    <h2>@Detail.Matches.Count match(s)</h2>
                </div>
                <div class="etd-match-list">
                    @foreach (var match in Detail.Matches.OrderBy(match => match.ScheduledAt).ThenBy(match => match.MatchNumber))
                    {
                        <button type="button" class="etd-match-row @(SelectedMatch?.Id == match.Id ? "selected" : "")" @onclick="() => SelectMatchAsync(match)">
                            <span>@StageLabel(match.Stage) @(string.IsNullOrWhiteSpace(match.GroupName) ? string.Empty : match.GroupName)</span>
                            <strong>@TeamName(match.HomeTeamId) @Score(match.HomeScore) - @Score(match.AwayScore) @TeamName(match.AwayTeamId)</strong>
                            <small>@match.Status - @match.ScheduledAt.LocalDateTime.ToString("dd/MM HH:mm")</small>
                        </button>
                    }
                </div>
            </article>
        </section>

        @if (SelectedMatch is not null)
        {
            <section class="etd-match-detail">
                <div class="etd-panel-head">
                    <span>Detail match</span>
                    <h2>@TeamName(SelectedMatch.HomeTeamId) @Score(SelectedMatch.HomeScore) - @Score(SelectedMatch.AwayScore) @TeamName(SelectedMatch.AwayTeamId)</h2>
                </div>

                @if (LoadingMatchDetails)
                {
                    <p class="etd-muted">Chargement des stats EA du match...</p>
                }
                else if (SelectedFriendlyDetails is null)
                {
                    <p class="etd-muted">Aucun detail EA lie a ce match pour le moment. Le score reste visible depuis le tournoi, et les details apparaitront des qu'un match EA sera associe.</p>
                }
                else
                {
                    <div class="etd-score-strip">
                        <span>@SelectedFriendlyDetails.Match.HomeClubName</span>
                        <strong>@SelectedFriendlyDetails.Match.HomeScore - @SelectedFriendlyDetails.Match.AwayScore</strong>
                        <span>@SelectedFriendlyDetails.Match.AwayClubName</span>
                    </div>

                    <div class="etd-player-teams">
                        @foreach (var group in MatchPlayerGroups)
                        {
                            <article class="etd-player-team">
                                <h3>@group.Name</h3>
                                <div class="etd-player-card-grid">
                                    @foreach (var player in group.Players.OrderByDescending(player => player.Rating ?? 0).ThenBy(player => player.PlayerName))
                                    {
                                        <div class="etd-player-card @PositionCss(player.Position)">
                                            <div>
                                                <span>@PositionGroup(player.Position)</span>
                                                <strong>@player.PlayerName</strong>
                                                <small>@PlayerMatchLine(player)</small>
                                                <small>@EaArchetypeMapper.Label(player.ArchetypeId)</small>
                                            </div>
                                            <b>@RatingLabel(player.Rating)</b>
                                        </div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        }
    }
</main>

@code {
    [Parameter] public Guid TournamentId { get; set; }

    private bool Loading { get; set; } = true;
    private bool LoadingMatchDetails { get; set; }
    private string? ErrorMessage { get; set; }
    private Guid? CurrentTeamId { get; set; }
    private TournamentAdminDetailResponse? Detail { get; set; }
    private TournamentMatchResponse? SelectedMatch { get; set; }
    private EaFriendlyMatchDetailsResponse? SelectedFriendlyDetails { get; set; }
    private List<OwnerTeamOption> OwnerTeams { get; } = [];
    private List<RosterPlayerModel> Roster { get; } = [];
    private List<PlayerInviteLink> InviteLinks { get; } = [];
    private PlayerInviteLink? TeamInviteLink { get; set; }
    private Guid? SelectedOwnerTeamId { get; set; }
    private RosterPlayerModel? FocusedRosterPlayer { get; set; }
    private string SelectedFormation { get; set; } = "4-2-3-1";
    private bool RosterBusy { get; set; }
    private string? RosterMessage { get; set; }
    private int DefaultMaxHeightCm { get; set; } = 182;
    private int CenterBackMaxHeightCm { get; set; } = 187;

    private string RegistrationWindowLabel => Detail?.Tournament.RegistrationEndsAt is null ? "Ouverte" : $"jusqu'au {Detail.Tournament.RegistrationEndsAt.Value.LocalDateTime:dd/MM HH:mm}";
    private bool IsFinished => Detail?.Tournament.Status == TournamentStatus.Completed || Detail?.Matches.Any(match => match.Stage == TournamentStage.Final && match.WinnerTeamId.HasValue) == true;
    private TournamentMatchResponse? FinalMatch => Detail?.Matches.FirstOrDefault(match => match.Stage == TournamentStage.Final && match.HomeScore.HasValue && match.AwayScore.HasValue);
    private string WinnerTeamName => FinalMatch?.WinnerTeamId is Guid winnerId ? TeamName(winnerId) : "Champion a confirmer";
    private string FinalistTeamName => FinalMatch is null ? "Finaliste a confirmer" : TeamName(FinalMatch.WinnerTeamId == FinalMatch.HomeTeamId ? FinalMatch.AwayTeamId : FinalMatch.HomeTeamId);
    private string ThirdPlaceLabel => Detail?.Matches.FirstOrDefault(match => match.Stage == TournamentStage.ThirdPlace && match.WinnerTeamId.HasValue) is { } third ? TeamName(third.WinnerTeamId!.Value) : "Non renseigne";
    private string WinnerLabel => WinnerTeamName == "Champion a confirmer" ? "Resultat final a confirmer" : $"{WinnerTeamName} remporte le tournoi";
    private string FinalLabel => FinalMatch is null ? "La finale n'est pas encore liee en base." : $"Finale: {TeamName(FinalMatch.HomeTeamId)} {Score(FinalMatch.HomeScore)} - {Score(FinalMatch.AwayScore)} {TeamName(FinalMatch.AwayTeamId)}";
    private string SelectedOwnerTeamName => OwnerTeams.FirstOrDefault(team => team.TeamId == SelectedOwnerTeamId)?.Name ?? "Aucun club";
    private int SelectedRosterCount => Roster.Count(player => player.Selected);
    private int SelectedAppRosterCount => Roster.Count(player => player.Selected && player.HasApp);
    private int SelectedInviteRequiredCount => Roster.Count(player => player.Selected && !player.HasApp);
    private int MissingTournamentPositionCount => Roster.Count(player => player.Selected && string.IsNullOrWhiteSpace(player.Position));
    private int HeightViolationCount => Roster.Count(player => player.Selected && !IsHeightEligibleForTournament(player));
    private bool CanSubmitRoster => SelectedOwnerTeamId.HasValue && SelectedRosterCount == 11 && MissingTournamentPositionCount == 0 && HeightViolationCount == 0 && !RosterBusy;
    private IReadOnlyList<RosterPositionGroup> RosterGroups => Roster
        .OrderBy(PositionSort)
        .ThenByDescending(player => player.HasApp)
        .ThenByDescending(player => player.AverageRating ?? 0)
        .ThenBy(player => player.DisplayName)
        .GroupBy(player => PositionGroup(player.EaPosition))
        .Select(group => new RosterPositionGroup(PositionGroupLabel(group.Key), group.ToArray()))
        .ToArray();
    private IReadOnlyList<IReadOnlyList<LineupSlotModel>> LineupRows => BuildLineupRows();

    private IReadOnlyCollection<MatchPlayerGroup> MatchPlayerGroups => SelectedFriendlyDetails is null
        ? Array.Empty<MatchPlayerGroup>()
        : new[]
        {
            new MatchPlayerGroup(SelectedFriendlyDetails.Match.HomeClubName ?? "Equipe domicile", SelectedFriendlyDetails.PlayerStats.Where(player => player.EaClubId == SelectedFriendlyDetails.Match.HomeEaClubId).ToArray()),
            new MatchPlayerGroup(SelectedFriendlyDetails.Match.AwayClubName ?? "Equipe exterieure", SelectedFriendlyDetails.PlayerStats.Where(player => player.EaClubId == SelectedFriendlyDetails.Match.AwayEaClubId).ToArray())
        };

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        if (!AuthState.IsAuthenticated)
        {
            Loading = false;
            return;
        }

        try
        {
            var me = await Api.GetMeAsync();
            CurrentTeamId = me.Value?.Memberships.FirstOrDefault(member => member.TeamId.HasValue)?.TeamId;
            var detailResult = await Api.GetTournamentAdminDetailAsync(TournamentId);
            if (!detailResult.Success || detailResult.Value is null)
            {
                ErrorMessage = detailResult.Error ?? "Detail tournoi indisponible.";
                return;
            }

            Detail = detailResult.Value;
            ApplyTournamentRestrictions();
            await LoadOwnerContextAsync();
            SelectedMatch = Detail.Matches.OrderBy(match => match.ScheduledAt).FirstOrDefault(match => match.HomeScore.HasValue || match.AwayScore.HasValue) ?? Detail.Matches.FirstOrDefault();
            if (SelectedMatch is not null)
            {
                await LoadMatchDetailsAsync(SelectedMatch);
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            Loading = false;
        }
    }

    private async Task SelectMatchAsync(TournamentMatchResponse match)
    {
        SelectedMatch = match;
        await LoadMatchDetailsAsync(match);
    }

    private async Task LoadOwnerContextAsync()
    {
        OwnerTeams.Clear();
        Roster.Clear();
        InviteLinks.Clear();
        TeamInviteLink = null;
        RosterMessage = null;

        var me = await Api.GetMeAsync();
        if (me.Value is null)
        {
            RosterMessage = me.Error ?? "Impossible de charger ton compte.";
            return;
        }

        foreach (var membership in me.Value.Memberships.Where(member => member.TeamId.HasValue && member.Role is TeamRole.Owner or TeamRole.Manager))
        {
            OwnerTeams.Add(new OwnerTeamOption(membership.TeamId!.Value, membership.TeamName ?? membership.TeamShortName ?? membership.DisplayName, membership.Role));
        }

        if (OwnerTeams.Count == 0)
        {
            SelectedOwnerTeamId = null;
            return;
        }

        if (SelectedOwnerTeamId is null || OwnerTeams.All(team => team.TeamId != SelectedOwnerTeamId.Value))
        {
            SelectedOwnerTeamId = OwnerTeams[0].TeamId;
        }

        await LoadRosterForSelectedTeamAsync();
    }

    private async Task LoadRosterForSelectedTeamAsync()
    {
        if (SelectedOwnerTeamId is null)
        {
            return;
        }

        RosterBusy = true;
        RosterMessage = null;
        Roster.Clear();
        InviteLinks.Clear();
        TeamInviteLink = null;

        try
        {
            var membersResult = await Api.GetTeamMembersAsync(SelectedOwnerTeamId.Value);
            var profilesResult = await Api.GetTeamEaPlayersAsync(SelectedOwnerTeamId.Value);
            var participantsResult = await Api.GetTournamentParticipantsAsync(TournamentId, SelectedOwnerTeamId.Value);

            var members = membersResult.Value ?? [];
            var participants = participantsResult.Value ?? [];

            if (profilesResult.Value is not null)
            {
                foreach (var profile in profilesResult.Value)
                {
                    var member = FindMatchingAppMember(profile, members);
                    var participant = member is null ? null : participants.FirstOrDefault(item => item.UserId == member.UserId);
                    Roster.Add(RosterPlayerModel.FromEaProfile(profile, member, participant));
                }
            }

            foreach (var member in members.Where(member => Roster.All(player => player.UserId != member.UserId)))
            {
                var participant = participants.FirstOrDefault(item => item.UserId == member.UserId);
                Roster.Add(RosterPlayerModel.FromAppMember(member, participant));
            }

            FocusedRosterPlayer = Roster.FirstOrDefault();
            RosterMessage = Roster.Count == 0
                ? "Aucun joueur en base. Lance une mise a jour EA pour recuperer l'effectif."
                : $"Effectif charge: {Roster.Count} joueur(s), {Roster.Count(player => player.HasApp)} dans l'app.";
        }
        finally
        {
            RosterBusy = false;
        }
    }

    private async Task RefreshSelectedTeamEaRosterAsync()
    {
        if (SelectedOwnerTeamId is null)
        {
            return;
        }

        RosterBusy = true;
        var sync = await Api.SyncTeamEaAsync(SelectedOwnerTeamId.Value, forceRefresh: true);
        RosterMessage = sync.Success ? "Effectif EA mis a jour et sauvegarde en base." : sync.Error;
        RosterBusy = false;
        await LoadRosterForSelectedTeamAsync();
    }

    private async Task TogglePlayerAsync(RosterPlayerModel player, ChangeEventArgs args)
    {
        player.Selected = args.Value is bool selected && selected && player.CanBeSelected;
        if (player.Selected && string.IsNullOrWhiteSpace(player.Position))
        {
            player.Position = SuggestTournamentPosition(player.EaPosition);
        }

        FocusedRosterPlayer = player;
        await Task.CompletedTask;
    }

    private async Task UpdatePlayerPositionAsync(RosterPlayerModel player, ChangeEventArgs args)
    {
        player.Position = args.Value?.ToString() ?? string.Empty;
        FocusedRosterPlayer = player;
        await Task.CompletedTask;
    }

    private async Task SubmitRosterAsync()
    {
        if (!CanSubmitRoster || SelectedOwnerTeamId is null)
        {
            return;
        }

        RosterBusy = true;
        InviteLinks.Clear();
        TeamInviteLink = null;

        try
        {
            var registration = await Api.RegisterTeamForTournamentAsync(TournamentId, new RegisterTeamForTournamentRequest(SelectedOwnerTeamId.Value, TournamentPaymentMode.IndividualPlayers));
            if (!registration.Success && !IsAlreadyRegistered(registration.Error))
            {
                RosterMessage = registration.Error;
                return;
            }

            foreach (var player in Roster.Where(player => player.Selected).Take(11))
            {
                if (!player.HasApp)
                {
                    AddInviteLink(player);
                    continue;
                }

                var participant = await Api.AddTournamentParticipantAsync(TournamentId, SelectedOwnerTeamId.Value, new AddTournamentParticipantRequest(player.UserId, player.Position));
                if (!participant.Success && !IsAlreadyRegistered(participant.Error))
                {
                    RosterMessage = participant.Error;
                    return;
                }
            }

            TeamInviteLink = InviteLinks.Count > 0 ? BuildTeamInviteLink() : null;
            RosterMessage = InviteLinks.Count > 0
                ? $"Equipe inscrite provisoirement: {SelectedAppRosterCount} joueur(s) app ajoutes, {InviteLinks.Count} invitation(s) a envoyer."
                : "Equipe inscrite et 11 joueurs convoques. Les joueurs doivent valider leur presence.";
        }
        finally
        {
            RosterBusy = false;
        }
    }

