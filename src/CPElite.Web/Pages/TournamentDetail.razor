    private sealed class RosterPlayerModel
    {
        private RosterPlayerModel(
            Guid userId,
            string displayName,
            string? gamertag,
            string eaPlayerId,
            string? eaPosition,
            string position,
            bool selected,
            bool hasApp,
            string status,
            int? height,
            int? overall,
            int? matches,
            double? averageRating)
        {
            UserId = userId;
            DisplayName = displayName;
            Gamertag = string.IsNullOrWhiteSpace(gamertag) ? eaPlayerId : gamertag!;
            EaPlayerId = eaPlayerId;
            EaPosition = eaPosition;
            Position = position;
            Selected = selected;
            HasApp = hasApp;
            Status = status;
            Height = height;
            Overall = overall;
            Matches = matches;
            AverageRating = averageRating;
        }

        public Guid UserId { get; }
        public string DisplayName { get; }
        public string Gamertag { get; }
        public string EaPlayerId { get; }
        public string? EaPosition { get; }
        public string Position { get; set; }
        public string? AssignedSlotKey { get; set; }
        public bool Selected { get; set; }
        public bool HasApp { get; }
        public string Status { get; }
        public int? Height { get; }
        public int? Overall { get; }
        public int? Matches { get; }
        public double? AverageRating { get; }
        public bool CanBeSelected => Status != "Pas dispo";
        public string RosterKey => HasApp ? UserId.ToString() : $"{EaPlayerId}:{DisplayName}";
        public string EaPositionLabel => string.IsNullOrWhiteSpace(EaPosition) ? "-" : EaPosition!;
        public string HeightLabel => Height.HasValue ? $"{Height} cm" : "-";
        public string OverallLabel => Overall.HasValue ? $"{Overall} OVR" : "-";
        public string MatchesLabel => Matches.HasValue ? $"{Matches} MJ" : "-";
        public string PositionLabel => string.IsNullOrWhiteSpace(Position) ? "Poste -" : Position;

        public static RosterPlayerModel FromEaProfile(EaPlayerProfileSnapshotResponse profile, TeamMemberResponse? member, TournamentParticipantResponse? participant)
        {
            var selected = participant is not null;
            var position = participant?.Position ?? string.Empty;
            return new RosterPlayerModel(
                member?.UserId ?? Guid.Empty,
                profile.PlayerName,
                member?.Gamertag,
                profile.EaPlayerId,
                profile.Position,
                position,
                selected,
                member is not null,
                participant is null ? "Disponible" : participant.Status.ToString(),
                profile.Height,
                profile.Overall,
                profile.Matches,
                profile.AverageRating);
        }

        public static RosterPlayerModel FromAppMember(TeamMemberResponse member, TournamentParticipantResponse? participant)
        {
            return new RosterPlayerModel(
                member.UserId,
                member.DisplayName,
                member.Gamertag,
                member.Gamertag ?? member.DisplayName,
                null,
                participant?.Position ?? string.Empty,
                participant is not null,
                true,
                participant is null ? "Disponible" : participant.Status.ToString(),
                null,
                null,
                null,
                null);
        }
    }
