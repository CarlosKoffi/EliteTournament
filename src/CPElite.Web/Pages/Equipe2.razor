    private void RebuildRosterPlayers()
    {
        RosterPlayers.Clear();
        var byEaId = new Dictionary<string, RosterPlayerView>(StringComparer.OrdinalIgnoreCase);
        var matchedTournamentStatIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var profile in Players)
        {
            var stats = FindTournamentStatsForProfile(profile);
            if (stats is not null)
            {
                matchedTournamentStatIds.Add(stats.EaPlayerId);
            }

            byEaId[profile.EaPlayerId] = RosterPlayerView.FromProfile(profile, stats);
        }

        foreach (var stat in TournamentPlayerStats.Values)
        {
            if (!matchedTournamentStatIds.Contains(stat.EaPlayerId) && !byEaId.ContainsKey(stat.EaPlayerId))
            {
                byEaId[stat.EaPlayerId] = RosterPlayerView.FromTournamentStats(stat);
            }
        }

        RosterPlayers.AddRange(byEaId.Values
            .OrderBy(PositionSort)
            .ThenByDescending(player => player.TournamentStats?.AverageRating ?? player.AverageRating ?? 0)
            .ThenBy(player => player.PlayerName));
    }

    private EaTournamentPlayerStatsResponse? FindTournamentStatsForProfile(EaPlayerProfileSnapshotResponse profile)
    {
        if (TournamentPlayerStats.TryGetValue(profile.EaPlayerId, out var byId))
        {
            return byId;
        }

        var profileKeys = new[]
        {
            NormalizePlayerKey(profile.PlayerName),
            NormalizePlayerKey(profile.ProName),
            NormalizePlayerKey(profile.EaPlayerId)
        }.Where(key => !string.IsNullOrWhiteSpace(key)).ToHashSet(StringComparer.OrdinalIgnoreCase);

        return TournamentPlayerStats.Values.FirstOrDefault(stat =>
            profileKeys.Contains(NormalizePlayerKey(stat.PlayerName)) ||
            profileKeys.Contains(NormalizePlayerKey(stat.EaPlayerId)));
    }

    private string TabClass(string tab) => ActiveTab == tab ? "active" : "";

    private bool IsWin(EaFriendlyMatchResponse match)
    {
        var clubId = Team?.EaClubId ?? Club?.EaClubId;
        if (clubId is null)
        {
            return false;
        }

        return match.HomeEaClubId == clubId && match.HomeScore > match.AwayScore
            || match.AwayEaClubId == clubId && match.AwayScore > match.HomeScore;
    }

    private int GoalsForMatch(EaFriendlyMatchResponse match)
    {
        var clubId = Team?.EaClubId ?? Club?.EaClubId;
        if (clubId is null)
        {
            return 0;
        }

        return match.HomeEaClubId == clubId ? match.HomeScore : match.AwayEaClubId == clubId ? match.AwayScore : 0;
    }

    private int GoalsAgainstMatch(EaFriendlyMatchResponse match)
    {
        var clubId = Team?.EaClubId ?? Club?.EaClubId;
        if (clubId is null)
        {
            return 0;
        }

        return match.HomeEaClubId == clubId ? match.AwayScore : match.AwayEaClubId == clubId ? match.HomeScore : 0;
    }

    private static int PositionSort(EaPlayerProfileSnapshotResponse player) => PositionGroup(player.Position) switch
    {
        "GK" => 0,
        "DEF" => 1,
        "MIL" => 2,
        "ATT" => 3,
        _ => 4
    };

    private static int PositionSort(RosterPlayerView player) => PositionGroup(player.Position) switch
    {
        "GK" => 0,
        "DEF" => 1,
        "MIL" => 2,
        "ATT" => 3,
        _ => 4
    };

    private static string PositionGroup(string? position)
    {
        if (string.IsNullOrWhiteSpace(position))
        {
            return "-";
        }

        var normalized = position.ToUpperInvariant();
        if (normalized.Contains("GK") || normalized.Contains("GARDIEN"))
        {
            return "GK";
        }

        if (normalized.Contains("CB") || normalized.Contains("DC") || normalized.Contains("LB") || normalized.Contains("RB") || normalized.Contains("DEF") || normalized.Contains("DD") || normalized.Contains("DG"))
        {
            return "DEF";
        }

        if (normalized.Contains("CM") || normalized.Contains("CDM") || normalized.Contains("CAM") || normalized.Contains("MC") || normalized.Contains("MOC") || normalized.Contains("MDC") || normalized.Contains("MIL"))
        {
            return "MIL";
        }

        if (normalized.Contains("ST") || normalized.Contains("LW") || normalized.Contains("RW") || normalized.Contains("BU") || normalized.Contains("AG") || normalized.Contains("AD") || normalized.Contains("ATT"))
        {
            return "ATT";
        }

        return normalized.Length > 3 ? normalized[..3] : normalized;
    }

