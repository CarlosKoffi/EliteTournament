    private RenderFragment AwardCard(string title, TeamTournamentPlayerAwardResponse? player, string metric) => @<article class="el-award-card">
        <span>@title</span>
        @if (player is null)
        {
            <strong>-</strong>
            <small>Aucune donnee suffisante</small>
        }
        else
        {
            <strong>@player.PlayerName</strong>
            <small>@AwardSummary(player, metric)</small>
        }
    </article>;

    private static string AwardSummary(TeamTournamentPlayerAwardResponse player, string metric)
    {
        return metric switch
        {
            "Note moyenne" => $"{RatingLabel(player.Rating)} note - {player.Matches} match(s)",
            "Buts" => $"{player.Goals} buts - {player.Shots} tirs - {RatingLabel(player.Rating)} note",
            "Assists" => $"{player.Assists} assists - {player.PassesMade} passes - {PercentLabel(player.PassSuccessRate)}",
            _ => $"{player.TacklesMade} tacles - {player.Saves} arrets - {player.CleanSheets} clean sheets"
        };
    }
    private static string ScoreLabel(int? score) => score?.ToString() ?? "-";

    private static string ResultLabel(TeamTournamentMatchSummaryResponse match)
    {
        if (!match.HomeScore.HasValue || !match.AwayScore.HasValue)
        {
            return "Score en attente";
        }

        if (match.IsDraw)
        {
            return "Match nul";
        }

        return match.IsWin ? "Victoire" : "Defaite";
    }

    private static string StageLabel(CPElite.Contracts.Common.TournamentStage stage) => stage switch
    {
        CPElite.Contracts.Common.TournamentStage.Group => "Poule",
        CPElite.Contracts.Common.TournamentStage.RoundOf16 => "Phase finale",
        CPElite.Contracts.Common.TournamentStage.QuarterFinal => "Quart",
        CPElite.Contracts.Common.TournamentStage.SemiFinal => "Demi",
        CPElite.Contracts.Common.TournamentStage.Final => "Finale",
        CPElite.Contracts.Common.TournamentStage.ThirdPlace => "Petite finale",
        _ => stage.ToString()
    };

    private static string NormalizePlayerKey(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value.Where(char.IsLetterOrDigit).Select(char.ToLowerInvariant).ToArray());
    }

