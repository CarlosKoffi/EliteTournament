    private sealed record DemoMatchRow(string Stage, string Home, int HomeScore, string Away, int AwayScore, string Status);
    private sealed record AdminLiveMatchRow(string Code, string Home, string ScoreLabel, string Away, string Status, string StatusCss, string EaLookupWindow);
    private sealed record DemoUpcomingTournament(string Name, string DateLabel, string Type, int TeamsRegistered, int MaxTeams);
    private sealed record DemoPastTournamentModel(string Name, string DateLabel, int Teams, IReadOnlyCollection<DemoPodiumRow> Podium, IReadOnlyCollection<DemoAwardRow> Awards);
    private sealed record DemoPodiumRow(int Place, string TeamName, string Reward);
    private sealed record DemoAwardRow(string Label, string Player, string Value);
