@inherits LayoutComponentBase
@implements IDisposable
@inject AuthState AuthState

<div class="page">
    <header class="sidebar">
        <NavMenu />
    </header>

    <main class="shell">
        <article class="content">
            @if (!AuthState.IsInitialized)
            {
                <section class="empty-state auth-loading-state" role="status" aria-live="polite">
                    <p class="eyebrow">Session</p>
                    <h1>Chargement de ta session</h1>
                    <p>On verifie ton acces avant d'afficher les pages.</p>
                </section>
            }
            else
            {
                @Body
            }
        </article>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        AuthState.Changed += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await AuthState.InitializeAsync();
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Main layout auth initialization failed. {ex.Message}");
            }
        }
    }

    public void Dispose()
    {
        AuthState.Changed -= StateHasChanged;
    }
}
