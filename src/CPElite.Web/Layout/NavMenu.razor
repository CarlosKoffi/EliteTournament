@inject AuthState AuthState
@inject ApiClient Api
@implements IDisposable

<div class="et-header-inner">
    <div class="brand-row">
        <div class="brand-mark">ET</div>
        <div>
            <a class="brand-name" href="">Elite <span>Tournament</span></a>
            <span class="brand-subtitle">EAFC Club Pro</span>
        </div>
        <button title="Ouvrir le menu" aria-label="Ouvrir le menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
            </span>
        </button>
    </div>

    <div class="@NavMenuCssClass nav-scrollable">
        <nav class="nav-list" @onclick="CloseOnMobile">
            @if (!AuthState.IsInitialized)
            {
                <span class="nav-link">
                    <span class="nav-icon">...</span> Session
                </span>
            }
            else if (AuthState.IsAuthenticated)
            {
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="nav-icon">01</span> Accueil
                </NavLink>
                <NavLink class="nav-link" href="account">
                    <span class="nav-icon">02</span> Compte
                </NavLink>
                <NavLink class="nav-link" href="teams">
                    <span class="nav-icon">03</span> Mon equipe
                </NavLink>
                <NavLink class="nav-link" href="mercato">
                    <span class="nav-icon">04</span> Mercato
                </NavLink>
                <NavLink class="nav-link" href="tournaments">
                    <span class="nav-icon">05</span> Tournois
                </NavLink>
                @if (AuthState.User?.IsAdmin == true)
                {
                    <NavLink class="nav-link admin-link" href="admin/tournaments">
                        <span class="nav-icon">AD</span> Admin
                    </NavLink>
                    <NavLink class="nav-link admin-link" href="admin/content">
                        <span class="nav-icon">TX</span> Textes
                    </NavLink>
                }
            }
            else
            {
                <NavLink class="nav-link" href="login">
                    <span class="nav-icon">IN</span> Se connecter
                </NavLink>
                <NavLink class="nav-link" href="account">
                    <span class="nav-icon">+</span> Creer un compte
                </NavLink>
            }
        </nav>

        <div class="sidebar-card">
            @if (AuthState.IsAuthenticated)
            {
                <span class="eyebrow">@MenuTeamName</span>
                <strong>@MenuPlayerName</strong>
                <p>@MenuRoleLabel</p>
            }
            else if (!AuthState.IsInitialized)
            {
                <span class="eyebrow">Session</span>
                <strong>Chargement</strong>
                <p>On restaure ton acces.</p>
            }
            else
            {
                <span class="eyebrow">Bienvenue</span>
                <strong>Compte requis</strong>
                <p>Connecte-toi ou cree ton compte pour rejoindre un club et rechercher.</p>
            }
        </div>
    </div>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? TeamName;
    private string? RoleName;

    private string? NavMenuCssClass => collapseNavMenu ? "nav-collapsed" : null;
    private string MenuPlayerName => AuthState.User?.DisplayName ?? AuthState.User?.Gamertag ?? "Joueur";
    private string MenuTeamName => TeamName ?? "Aucun club actif";
    private string MenuRoleLabel => string.IsNullOrWhiteSpace(RoleName) ? "Role a completer" : RoleName;

    protected override async Task OnInitializedAsync()
    {
        AuthState.Changed += OnAuthChanged;
        await SafeLoadIdentityAsync();
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void CloseOnMobile()
    {
        collapseNavMenu = true;
    }

    private void OnAuthChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await SafeLoadIdentityAsync();
            StateHasChanged();
        });
    }

    private async Task SafeLoadIdentityAsync()
    {
        try
        {
            await LoadIdentityAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Navigation identity loading failed. {ex.Message}");
            TeamName = null;
            RoleName = null;
        }
    }

    private async Task LoadIdentityAsync()
    {
        TeamName = null;
        RoleName = null;

        if (!AuthState.IsInitialized || !AuthState.IsAuthenticated)
        {
            return;
        }

        var result = await Api.GetMeAsync();
        if (result.Value is null && IsInvalidStoredSession(result.Error))
        {
            await AuthState.SignOutAsync();
            return;
        }

        var membership = result.Value?.Memberships.FirstOrDefault(member => member.TeamId.HasValue);
        TeamName = membership?.TeamName;
        RoleName = membership?.Role.ToString();
    }

    public void Dispose()
    {
        AuthState.Changed -= OnAuthChanged;
    }

    private static bool IsInvalidStoredSession(string? error)
    {
        if (string.IsNullOrWhiteSpace(error))
        {
            return false;
        }

        return error.Contains("User was not found", StringComparison.OrdinalIgnoreCase)
            || error.Contains("user.not_found", StringComparison.OrdinalIgnoreCase)
            || error.Contains("Unauthorized", StringComparison.OrdinalIgnoreCase)
            || error.Contains("401", StringComparison.OrdinalIgnoreCase);
    }
}

